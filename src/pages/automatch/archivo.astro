---
import Layout from "../../layouts/Layout.astro";
import AutoMatch from "../../components/automatch/automatch.astro";
import { getApiUrl, fetchWithTimeout } from "../../lib/api";
import {
  buildAutomatchCarousel,
  type AutomatchDbNote,
} from "../../lib/automatch-catalog";

let autos: ReturnType<typeof buildAutomatchCarousel> = [];

try {
  const apiUrl = getApiUrl("get-notes");
  const data = await fetchWithTimeout(apiUrl);

  if (data && Array.isArray(data)) {
    const automatchNotes: AutomatchDbNote[] = data
      .filter((note: any) => note.category?.toLowerCase() === "automatch")
      .map((note: any) => ({
        id: note.id,
        title: note.title,
        subtitle: note.subtitle,
        content: note.content || "",
        created_at: note.created_at,
        image1: note.image1,
        image2: note.image2,
        image3: note.image3,
        image4: note.image4,
        image5: note.image5,
        image6: note.image6,
      }));

    autos = buildAutomatchCarousel(automatchNotes, { skipEditorialCover: true });
  }
} catch (err) {
  console.error("Error cargando autos en archivo AutoMatch:", err);
  autos = buildAutomatchCarousel([], { skipEditorialCover: true });
}
---

<Layout
  title="AutoMatch | Archivo de Fichas"
  description="Archivo de fichas AutoMatch con tarjetas y carruseles para seguir explorando modelos."
>
  <section class="automatch-archivo">
    <p class="automatch-archivo__back">
      <a href="/automatch">
        <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
        Volver a AutoMatch
      </a>
    </p>
    <AutoMatch autos={autos} mode="archive" />
  </section>
</Layout>

<style>
  .automatch-archivo {
    background: white;
    padding: 0.5rem 0 1.5rem;
  }

  .automatch-archivo__back {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.25rem 0;
  }

  .automatch-archivo__back a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: #08341f;
    font-weight: 600;
    text-decoration: none;
  }

  .automatch-archivo__back a:hover {
    color: #0a4228;
    text-decoration: underline;
  }
</style>

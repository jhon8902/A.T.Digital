---
import Layout from "../../layouts/Layout.astro";
import TestDriveCTA from "../../components/leads/TestDriveCTA.astro";
import AutoMatchCTA from "../../components/leads/AutoMatchCTA.astro";
import RelatedNotes from "./RelatedNotes.astro";
import { getDealerForNote, type NoteDealerInfo } from "../../lib/leads";
import {
  getNewsCardTitle,
  getNewsTitleHook,
  splitEditorialParagraph,
} from "../../lib/editorial";
import {
  formatNotePublishDateLong,
  getNotePublishDate,
} from "../../lib/note-scheduling";
import { buildNewsArticleJsonLd } from "../../lib/note-seo";
import { resolvePublishedNoteById } from "../../lib/load-published-note";
import { isPruebasSoloVideo, stripPruebasSoloMeta } from "../../lib/pruebas-solo";
export const prerender = false;

// ✅ Definimos la interfaz del tipo de nota
interface Note {
  id: number;
  title: string;
  subtitle?: string;
  editor?: string;
  source_scope?: string;
  category?: string;
  content: string;
  created_at?: string;
  scheduled_at?: string | null;
  image1?: string;
  image2?: string;
  image3?: string;
  image4?: string;
  image5?: string;
  image6?: string;
  video1?: string;
  video2?: string;
  video3?: string;
  video4?: string;
  video5?: string;
  video6?: string;
  video7?: string;
  spec_segmento?: string;
  spec_origen?: string;
  spec_precio_estimado?: string;
  spec_versiones?: string;
  spec_motorizacion?: string;
  spec_potencia_hp?: string;
  spec_torque_nm?: string;
  spec_bateria_autonomia?: string;
  spec_bateria_kwh?: string;
  spec_autonomia_km?: string;
  spec_carga?: string;
  spec_carga_ac_kw?: string;
  spec_carga_dc_kw?: string;
  spec_aceleracion_0_100?: string;
  spec_seguridad?: string;
  spec_equipamiento?: string;
  spec_pros?: string;
  spec_contras?: string;
  spec_competidores?: string;
  spec_traccion?: string;
  spec_precio_cop?: string;
  block_titles?: string;
}

// ✅ Parámetro recibido desde la URL
const { id } = Astro.params;
const parsedId = Number(id);
const hasValidNoteId =
  Number.isInteger(parsedId) && parsedId > 0 && String(parsedId) === String(id).trim();

// ✅ Definimos note con tipo explícito
let note: Note | null = null;

const siteOrigin =
  Astro.site?.href?.replace(/\/$/, "") || Astro.url.origin;

if (hasValidNoteId) {
  try {
    note = (await resolvePublishedNoteById(parsedId, siteOrigin)) as Note | null;
  } catch (err) {
    console.error("❌ Error al obtener nota:", err);
  }
}

if (note && isPruebasSoloVideo(note)) {
  return Astro.redirect("/pruebas#pruebas", 302);
}

const isNoteMissing = !note;
if (isNoteMissing) {
  Astro.response.status = 404;
  Astro.response.headers.set("Cache-Control", "no-store");
}

type NoteCtaKind = "test-drive" | "automatch";
type AutoMatchCtaReason = "internacional" | "sin-dealer" | "deportes";

let noteCta: NoteCtaKind = "automatch";
let automatchReason: AutoMatchCtaReason = "sin-dealer";
let dealerInfo: NoteDealerInfo | null = null;

if (note) {
  const category = (note.category || "").toLowerCase();
  const scope = (note.source_scope || "nacional").toLowerCase();

  if (category === "deportes") {
    noteCta = "automatch";
    automatchReason = "deportes";
  } else if (scope === "internacional") {
    noteCta = "automatch";
    automatchReason = "internacional";
  } else {
    dealerInfo = await getDealerForNote(note.id);
    if (dealerInfo) {
      noteCta = "test-drive";
    } else {
      noteCta = "automatch";
      automatchReason = "sin-dealer";
    }
  }
}

// ✅ Extraer primera imagen
function extractFirstImage(html: string | undefined) {
  if (!html) return null;
  const match = html.match(/<img[^>]+src=["']([^"']+)["'][^>]*>/i);
  return match ? match[1] : null;
}

function normalizeMediaUrl(url: string | undefined) {
  if (!url) return null;
  const cleaned = url.trim().replace(/^['\"]+|['\"]+$/g, "");
  if (!cleaned) return null;
  if (cleaned.startsWith("img/")) return `/${cleaned}`;
  return cleaned;
}

const coverImage =
  normalizeMediaUrl(note?.image1) ||
  normalizeMediaUrl(extractFirstImage(note?.content) || undefined) ||
  null;
const contentText = stripPruebasSoloMeta(
  (note?.content || "").replace(/<!--AUTOMATCH_META:[^>]*-->/gi, "").trim(),
);

// Mejorar el parseo: dividir cada bloque que comience con 'Titulo:' (sin depender de saltos de línea dobles)
const contentParagraphs = contentText
  .replace(/<\/(p|div|article|section|h1|h2|h3|h4|h5|h6|li)>/gi, "\n\n")
  .replace(/<br\s*\/?\s*>/gi, "\n")
  .replace(/<[^>]*>/g, "")
  .split(/(?=^t[ií]tulo\s*:)/gmi)
  .map((block) => block.trim())
  .filter(Boolean);

const galleryImages = [
  note?.image2,
  note?.image3,
  note?.image4,
  note?.image5,
  note?.image6,
]
  .map((img) => normalizeMediaUrl(img))
  .filter((img): img is string => Boolean(img));

const galleryVideos = [
  note?.video1,
  note?.video2,
  note?.video3,
  note?.video4,
  note?.video5,
  note?.video6,
  note?.video7,
].filter((video): video is string => Boolean(video && video.trim()));

function isDirectVideoFile(url: string) {
  return /\.(mp4|webm|ogg|mov)(\?.*)?$/i.test(url);
}

const editorialFallbackTitles = [
  "Contexto del mercado",
  "Diseno y propuesta",
  "Cabina y tecnologia",
  "Rendimiento y eficiencia",
  "Impacto en Colombia",
  "Analisis editorial",
  "Conclusiones clave",
];

const ENABLE_INLINE_MANUAL_TITLES = true;

function extractInlineManualTitle(block: string) {
  if (!ENABLE_INLINE_MANUAL_TITLES) return null;

  // Sintaxis flexible: acepta salto de línea después del |
  // Titulo: Mi encabezado | Texto del bloque (en la misma línea o en la siguiente)
  const match = block.match(/^t[ií]tulo\s*:\s*([^|\n]{3,120})\|[ \t]*[\r\n]*([\s\S]*)$/i);
  if (!match) return null;

  const title = (match[1] || "").trim();
  const paragraph = (match[2] || "").trim();
  if (!title || !paragraph) return null;

  return { title, paragraph };
}

function makeBlockTitle(text: string, index: number) {
  const normalized = (text || "").toLowerCase();

  if (/autonomia|bateria|carga|kwh|km/i.test(normalized)) {
    return "Autonomia y energia";
  }
  if (/interior|cabina|pantalla|conectividad|tecnolog/i.test(normalized)) {
    return "Interior y conectividad";
  }
  if (/diseno|estetica|exterior|silueta|firma luminica/i.test(normalized)) {
    return "Diseno exterior";
  }
  if (/precio|cop|costo|mercado|colombia|segmento/i.test(normalized)) {
    return "Panorama comercial";
  }
  if (/seguridad|adas|airbag|asistencias/i.test(normalized)) {
    return "Seguridad y asistencias";
  }
  if (/motor|potencia|torque|aceleracion|traccion/i.test(normalized)) {
    return "Desempeno mecanico";
  }

  return editorialFallbackTitles[index % editorialFallbackTitles.length];
}

// Procesar títulos personalizados si están disponibles
const customTitles = (note?.block_titles || "")
  .split("\n")
  .map((t) => t.trim())
  .filter((t) => t.length > 0);

const uniqueContentBlocks = contentParagraphs.map((paragraph, index) => {
  const inlineManual = extractInlineManualTitle(paragraph);
  const customTitle = customTitles[index];
  const normalizedParagraph = inlineManual ? inlineManual.paragraph : paragraph;
  
  const paragraphParts = splitEditorialParagraph(normalizedParagraph);
  const title = inlineManual?.title || customTitle || makeBlockTitle(normalizedParagraph, index);

  return {
    paragraph: normalizedParagraph,
    paragraphs: paragraphParts,
    title,
  };
});

const usedTitles = new Set<string>();
uniqueContentBlocks.forEach((block, index) => {
  if (!usedTitles.has(block.title)) {
    usedTitles.add(block.title);
    return;
  }

  const nextFallback = editorialFallbackTitles.find((candidate) => !usedTitles.has(candidate));
  if (nextFallback) {
    block.title = nextFallback;
    usedTitles.add(block.title);
    return;
  }

  block.title = `${block.title} ${index + 1}`;
  usedTitles.add(block.title);
});

const remainingImages = galleryImages.slice(uniqueContentBlocks.length);

function combineText(...values: Array<string | undefined>) {
  return values
    .map((value) => value?.trim())
    .filter((value): value is string => Boolean(value && value.length > 0))
    .join(" | ");
}

const batteryAutonomy =
  note?.spec_bateria_autonomia ||
  combineText(
    note?.spec_bateria_kwh
      ? `${note.spec_bateria_kwh} kWh`
      : undefined,
    note?.spec_autonomia_km
      ? `Hasta ${note.spec_autonomia_km} km`
      : undefined
  );

const chargingSpec =
  note?.spec_carga ||
  combineText(
    note?.spec_carga_ac_kw
      ? `AC ${note.spec_carga_ac_kw} kW`
      : undefined,
    note?.spec_carga_dc_kw
      ? `DC ${note.spec_carga_dc_kw} kW`
      : undefined
  );

const priceSpec =
  note?.spec_precio_estimado ||
  note?.spec_precio_cop ||
  undefined;

const technicalSpecCards = [
  { label: "Precio estimado", icon: "fa-solid fa-tags", value: priceSpec },
  { label: "Versiones", icon: "fa-solid fa-car-side", value: note?.spec_versiones },
  { label: "Motor", icon: "fa-solid fa-gears", value: note?.spec_motorizacion },
  { label: "Potencia", icon: "fa-solid fa-gauge-high", value: note?.spec_potencia_hp },
  { label: "Torque", icon: "fa-solid fa-bolt", value: note?.spec_torque_nm },
  {
    label: "Batería y autonomía",
    icon: "fa-solid fa-battery-full",
    value: batteryAutonomy,
  },
  {
    label: "Aceleración",
    icon: "fa-regular fa-clock",
    value: note?.spec_aceleracion_0_100,
  },
  { label: "Carga", icon: "fa-solid fa-charging-station", value: chargingSpec },
  { label: "Seguridad", icon: "fa-solid fa-shield-halved", value: note?.spec_seguridad },
  {
    label: "Equipamiento",
    icon: "fa-solid fa-mobile-screen-button",
    value: note?.spec_equipamiento,
  },
  { label: "Pros", icon: "fa-solid fa-circle-check", value: note?.spec_pros },
  { label: "Contras", icon: "fa-solid fa-circle-xmark", value: note?.spec_contras },
  {
    label: "Competidores directos",
    icon: "fa-solid fa-flag-checkered",
    value: note?.spec_competidores,
    className: "competidores",
  },
].filter((item) => Boolean(item.value && item.value.trim()));

function sourceScopeLabel(scope?: string) {
  return scope?.toLowerCase() === "internacional" ? "Internacional" : "Nacional";
}

function sectionLabel(category?: string) {
  const normalized = (category || "").toLowerCase();
  switch (normalized) {
    case "electricos":
    case "eléctricos":
      return "Eléctricos";
    case "hibridos":
    case "híbridos":
      return "Híbridos";
    case "lanzamientos":
      return "Lanzamientos";
    case "deportes":
      return "Deportes";
    case "pruebas":
      return "Pruebas";
    case "noticias":
      return "Noticias";
    default:
      return "Actualidad";
  }
}

function categoryClassName(category?: string) {
  const normalized = (category || "")
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "");

  switch (normalized) {
    case "electricos":
    case "hibridos":
    case "lanzamientos":
    case "deportes":
    case "pruebas":
    case "noticias":
    case "automatch":
      return normalized;
    default:
      return "general";
  }
}

const categoryClass = categoryClassName(note?.category);
const normalizedTitle = (note?.title || "")
  .toLowerCase()
  .normalize("NFD")
  .replace(/[\u0300-\u036f]/g, "");
const displayTitle = note?.title?.trim() || "";
const displayLead = note?.subtitle?.trim() || "";
const useSmartImageFrame =
  normalizedTitle.includes("smart #5") || normalizedTitle.includes("smart 5");

const siteUrl = Astro.site?.href ?? "https://autotechdigital.com";
const noteDescription =
  note?.subtitle?.trim() ||
  getNewsTitleHook(note?.title || "") ||
  note?.title ||
  "";
const publishDate = note ? getNotePublishDate(note) : null;
const publishedIso = publishDate?.toISOString();
const modifiedIso =
  (note?.scheduled_at ? new Date(note.scheduled_at).toISOString() : undefined) ||
  (note?.created_at ? new Date(note.created_at).toISOString() : undefined) ||
  publishedIso;
const articleJsonLd = note
  ? buildNewsArticleJsonLd({
      note,
      siteUrl,
      description: noteDescription,
      coverImage,
      headline: note.title,
    })
  : undefined;
const noteCanonical = note ? `${siteUrl}/notas/${note.id}` : undefined;
---

<Layout
  title={note?.title || "Página no encontrada | Auto-Tech-Digital"}
  description={
    isNoteMissing
      ? "La nota que buscas no existe o ya no está disponible."
      : noteDescription || undefined
  }
  ogImage={coverImage || undefined}
  ogType={note ? "article" : "website"}
  canonical={noteCanonical}
  articlePublishedTime={publishedIso}
  articleModifiedTime={modifiedIso}
  articleAuthor={note?.editor?.trim() || "Jhon Aparicio"}
  articleSection={note?.category ? sectionLabel(note.category) : undefined}
  jsonLd={articleJsonLd}
  robots={isNoteMissing ? "noindex, nofollow" : "index, follow"}
  trackAnalytics={!isNoteMissing}
  bodyClass={`nota-page nota-${categoryClass} ${categoryClass}`}
>
  {
    note?.title ? (
      <section class={`articulo-container ${categoryClass}`}>
        <article class={`noticia-detalle${useSmartImageFrame ? " smart-note-frame" : ""}`}>
          {
            <>
              <p class="nota-eyebrow">
                {sectionLabel(note.category)} · {sourceScopeLabel(note.source_scope)}
              </p>

              <h1>{displayTitle}</h1>
              <div class="nota-meta-line">
                <span class="nota-meta-item">
                  <i class="fa-regular fa-user" aria-hidden="true"></i>
                  <span>{note.editor?.trim() || "Jhon Aparicio"}</span>
                </span>
                {
                  formatNotePublishDateLong(note) && (
                    <span class="nota-meta-item">
                      <i class="fa-regular fa-calendar" aria-hidden="true"></i>
                      <span>{formatNotePublishDateLong(note)}</span>
                    </span>
                  )
                }
              </div>

              {
                displayLead && (
                  <p class="noticia-descripcion">{displayLead}</p>
                )
              }

              {
                coverImage && (
                  <img
                    class="noticia-portada noticia-portada--main"
                    src={coverImage}
                    alt={note.title}
                    loading="lazy"
                    decoding="async"
                  />
                )
              }
            </>
          }

          {
            uniqueContentBlocks.length > 0 ? (
              uniqueContentBlocks.map((block, index) => {
                const blockImage = galleryImages[index];
                return (
                  <section class={`noticia-bloque${index % 2 === 1 ? " imagen-izquierda" : ""}`}>
                    <div class="noticia-texto">
                      <h2 class="noticia-titulo">{block.title}</h2>
                      {
                        block.paragraphs.map((paragraphText, paragraphIndex) => (
                          <p
                            class:list={[
                              "noticia-parrafo",
                              index === 0 &&
                                paragraphIndex === 0 &&
                                "noticia-parrafo--lead",
                            ]}
                          >
                            {paragraphText}
                          </p>
                        ))
                      }
                    </div>
                    {
                      blockImage && (
                        useSmartImageFrame ? (
                          <div class="noticia-media-frame">
                            <img
                              src={blockImage}
                              alt={`${note.title} imagen ${index + 2}`}
                              loading="lazy"
                              decoding="async"
                            />
                          </div>
                        ) : (
                          <img
                            src={blockImage}
                            alt={`${note.title} imagen ${index + 2}`}
                            loading="lazy"
                            decoding="async"
                          />
                        )
                      )
                    }
                  </section>
                );
              })
            ) : (
              <section class="noticia-bloque">
                <div class="noticia-texto">
                  <p class="noticia-parrafo">Sin contenido disponible.</p>
                </div>
              </section>
            )
          }

          {
            technicalSpecCards.length > 0 && (
              <section class="ficha-tecnica-profesional">
                <h2>Ficha Técnica Completa — {getNewsCardTitle(note.title)}</h2>
                <div class="ficha-grid">
                  {technicalSpecCards.map((item) => (
                    <div class={`ficha-item ${item.className || ""}`.trim()}>
                      <strong>
                        {item.icon && <i class={item.icon} aria-hidden="true" />}
                        <span>{item.label}</span>
                      </strong>
                      <p>{item.value}</p>
                    </div>
                  ))}
                </div>
              </section>
            )
          }

          {
            remainingImages.length > 0 &&
              remainingImages.map((imgSrc, index) => (
                <section class={`noticia-bloque${(uniqueContentBlocks.length + index) % 2 === 1 ? " imagen-izquierda" : ""}`}>
                  <div class="noticia-texto">
                    <h2 class="noticia-titulo">Más imágenes de {displayTitle}</h2>
                    <p class="noticia-parrafo">Galería visual complementaria de la nota.</p>
                  </div>
                  {useSmartImageFrame ? (
                    <div class="noticia-media-frame">
                      <img
                        src={imgSrc}
                        alt={`${note.title} imagen adicional ${index + 1}`}
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  ) : (
                    <img
                      src={imgSrc}
                      alt={`${note.title} imagen adicional ${index + 1}`}
                      loading="lazy"
                      decoding="async"
                    />
                  )}
                </section>
              ))
          }

          {
            galleryVideos.length > 0 && (
              <section class="noticia-bloque noticia-bloque-full">
                <div class="noticia-texto">
                  <h2 class="noticia-titulo">Videos</h2>
                  <div class="noticia-parrafo">
                    {galleryVideos.map((videoSrc, index) => (
                      <div style="margin-bottom: 18px;">
                        {isDirectVideoFile(videoSrc) ? (
                          <video
                            controls
                            preload="metadata"
                            style="width: 100%; border-radius: 12px; background: #000;"
                          >
                            <source src={videoSrc} />
                            Tu navegador no soporta la reproducción de video.
                          </video>
                        ) : (
                          <p>
                            <a href={videoSrc} target="_blank" rel="noreferrer">
                              Ver video {index + 1}
                            </a>
                          </p>
                        )}
                      </div>
                    ))}
                  </div>
                </div>
              </section>
            )
          }
        </article>

        {
          noteCta === "test-drive" ? (
            <TestDriveCTA
              autoNombre={note.title}
              noteId={note.id}
              autoId={String(note.id)}
              dealerId={dealerInfo?.dealerId}
              dealerNombre={dealerInfo?.dealerNombre}
            />
          ) : (
            <AutoMatchCTA
              autoNombre={note.title}
              reason={automatchReason}
            />
          )
        }

        <!-- Notas relacionadas -->
        {note?.category && (
          <RelatedNotes currentId={note.id} category={note.category} />
        )}
<!--
        <section class="resumen">
          <h2>Resumen Técnico</h2>
          <div class="grid">
            <div class="item">
              <strong>Categoría:</strong> {note.category}
            </div>
            <div class="item">
              <strong>Fecha:</strong>{" "}
              {formatNotePublishDateLong(note) || "Fecha no disponible"}
            </div>
          </div>
        </section>
        -->
      </section>
    ) : (
      <section class="nota-not-found" aria-labelledby="nota-not-found-title">
        <p class="nota-not-found__eyebrow">Error 404</p>
        <h1 id="nota-not-found-title">Esta nota no está disponible</h1>
        <p class="nota-not-found__lead">
          El enlace puede estar desactualizado, la nota fue retirada o el número de
          identificación no existe. Tus demás notas publicadas siguen en orden.
        </p>
        <div class="nota-not-found__actions">
          <a class="nota-not-found__btn nota-not-found__btn--primary" href="/noticias">
            Ver noticias
          </a>
          <a class="nota-not-found__btn" href="/">
            Ir al inicio
          </a>
        </div>
      </section>
    )
  }
</Layout>

<style>
  /* Estilos de nota: ver /css/nota-article.css */

  .nota-not-found {
    width: min(100%, 720px);
    margin: 3rem auto 4rem;
    padding: 2rem 1.5rem;
    text-align: center;
    border-radius: 1rem;
    background: #fff;
    border: 1px solid #e2ece6;
    box-shadow: 0 12px 32px rgba(8, 52, 31, 0.08);
  }

  .nota-not-found__eyebrow {
    margin: 0 0 0.5rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #e6b410;
  }

  .nota-not-found h1 {
    margin: 0 0 0.85rem;
    color: #08341f;
    font-size: clamp(1.6rem, 4vw, 2.2rem);
  }

  .nota-not-found__lead {
    margin: 0 auto 1.5rem;
    max-width: 52ch;
    color: #5a5a5a;
    line-height: 1.6;
  }

  .nota-not-found__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .nota-not-found__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 10rem;
    padding: 0.7rem 1.1rem;
    border-radius: 999px;
    border: 1px solid #08341f;
    color: #08341f;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .nota-not-found__btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 18px rgba(8, 52, 31, 0.12);
  }

  .nota-not-found__btn--primary {
    background: #08341f;
    color: #fff;
    border-color: #08341f;
  }
</style>

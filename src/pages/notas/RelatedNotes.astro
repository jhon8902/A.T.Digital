---
import { getApiUrl, fetchWithTimeout } from "../../lib/api";
import {
  formatNotePublishDate,
  formatNotePublishedLabel,
  getNotePublishTimestamp,
} from "../../lib/note-scheduling";
const { currentId, category } = Astro.props;

let relatedNotes = [];
try {
  const apiUrl = getApiUrl("get-notes");
  const data = await fetchWithTimeout(apiUrl);
  if (data && Array.isArray(data)) {
    relatedNotes = data
      .filter(
        (note) =>
          note.category?.toLowerCase() === category.toLowerCase() &&
          note.id !== currentId,
      )
      .sort(
        (a, b) => getNotePublishTimestamp(b) - getNotePublishTimestamp(a),
      )
      .slice(0, 4);
  }
} catch (err) {
  relatedNotes = [];
}
---

{
  relatedNotes.length > 0 && (
    <section class="notas-relacionadas">
      <h2>Notas relacionadas</h2>
      <div class="notas-relacionadas-grid">
        {relatedNotes.map((note) => (
          <a href={`/notas/${note.id}`} class="nota-relacionada-card">
            <img
              src={note.image1 || "/img/default.jpg"}
              alt={note.title}
              loading="lazy"
            />
            <div class="nota-relacionada-info">
              <span class="nota-relacionada-fecha">
                {formatNotePublishDate(note)
                  ? formatNotePublishDate(note)
                  : ""}
              </span>
              <span class="nota-relacionada-autor">
                {note.editor || "AutoTechDigital"}
              </span>
              <h3>{note.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>
  )
}

<style>
  .notas-relacionadas {
    margin: 48px 0 0 0;
    padding: 0 32px 32px 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .notas-relacionadas h2 {
    color: #08341f;
    font-size: 1.5rem;
    font-weight: 700;
    border-bottom: 3px solid #e1a307;
    padding-bottom: 6px;
    margin-bottom: 24px;
    letter-spacing: 0.01em;
    display: inline-block;
  }
  .notas-relacionadas-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(370px, 1fr));
    gap: 16px 12px;
    justify-items: center;
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
  }
  .nota-relacionada-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 4px 18px rgba(8, 52, 31, 0.09);
    text-decoration: none;
    color: #08341f;
    overflow: hidden;
    transition:
      box-shadow 0.22s,
      transform 0.18s,
      border 0.18s;
    border: 1.5px solid #e1a307;
    min-width: 360px;
    max-width: 400px;
    width: 100%;
  }
  .nota-relacionada-card:hover {
    box-shadow: 0 8px 28px rgba(225, 163, 7, 0.16);
    transform: translateY(-4px) scale(1.02);
    border-color: #08341f;
  }
  .nota-relacionada-card img {
    width: 100%;
    height: 280px;
    object-fit: cover;
    border-bottom: 1px solid #e1a307;
    border-radius: 16px 16px 0 0;
    transition: transform 0.2s;
    background: #f8f8f8;
  }
  .nota-relacionada-card:hover img {
    transform: scale(1.04);
  }
  .nota-relacionada-info {
    padding: 18px 20px 22px 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 120px;
    justify-content: flex-end;
  }
  @media (max-width: 1200px) {
    .notas-relacionadas-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 18px 12px;
    }
  }
  @media (max-width: 900px) {
    .notas-relacionadas {
      padding: 0 10px 24px 10px;
    }
    .notas-relacionadas-grid {
      grid-template-columns: 1fr;
      gap: 16px 8px;
      max-width: 100vw;
    }
    .nota-relacionada-card {
      min-width: 220px;
      max-width: 100%;
    }
    .nota-relacionada-card img {
      height: 160px;
    }
  }
  .nota-relacionada-info h3 {
    font-size: 1.08rem;
    font-weight: 600;
    margin: 0;
    color: #08341f;
    line-height: 1.3;
  }
  @media (max-width: 700px) {
    .notas-relacionadas-grid {
      grid-template-columns: 1fr;
    }
    .nota-relacionada-card img {
      height: 160px;
    }
  }
</style>

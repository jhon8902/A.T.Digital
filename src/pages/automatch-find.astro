---
import Layout from "../layouts/Layout.astro";
---

<link rel="stylesheet" href="/css/automatch-find.css" />

<Layout title="AutoMatch Inteligente 🚗❤️">
  <section class="automatch-page">
    <h1>Encuentra tu Auto Ideal con <span>AutoMatch</span> 🤖</h1>
    <p class="intro">
      Cuéntanos un poco de ti y te mostraremos el vehículo que más se adapta a
      tus necesidades. Tu perfil nos ayudará a mejores recomendaciones.
    </p>

    <!-- Perfil usuario -->
    <div class="user-profile-form">
      <h3>👤 Tu Perfil (Opcional)</h3>
      <p style="color: #666; font-size: 0.9rem; margin-bottom: 1rem;">
        Completa tu perfil para que AutoMatch te entienda mejor y recomiende
        vehículos solo para ti.
      </p>
      <form id="user-profile-form">
        <label>Nombre / Alias</label>
        <input type="text" id="user-name" placeholder="Mi nombre..." />

        <label>Ciudad / País</label>
        <input type="text" id="user-city" placeholder="Ej: Bogotá, Colombia" />

        <label>Edad (opcional)</label>
        <input
          type="number"
          id="user-age"
          placeholder="25"
          min="16"
          max="120"
        />

        <label>Preferencias de vehículos</label>
        <select id="user-preferences">
          <option value="">-- Selecciona una o más --</option>
          <option value="suv">🚙 SUV</option>
          <option value="sedan">🚗 Sedán</option>
          <option value="hatchback">🚕 Hatchback</option>
          <option value="pickup">🚛 Pickup</option>
          <option value="convertible">🏎️ Convertible</option>
        </select>

        <p style="font-size: 0.85rem; color: #888; margin-top: 1rem;">
          💡 Tip: Tu perfil se guarda localmente. Esto nos ayuda a recordarte y
          a hacer mejores recomendaciones.
        </p>
      </form>
    </div>

    <div class="automatch-container">
      <!-- Formulario a la izquierda -->
      <form id="automatch-form" class="form-section">
        <h3 style="color: #1b5e3f; margin-bottom: 1rem;">🔍 Búsqueda</h3>

        <label>Presupuesto (en millones)</label>
        <select id="presupuesto" required>
          <option value="">Seleccionar...</option>
          <option value="20-40">$20 - $40 millones</option>
          <option value="40-60">$40 - $60 millones</option>
          <option value="60-80">$60 - $80 millones</option>
          <option value="80-100">$80 - $100 millones</option>
          <option value="100-150">$100 - $150 millones</option>
          <option value="150-200">$150 - $200 millones</option>
          <option value="200+">Más de $200 millones</option>
        </select>

        <label>Tipo de uso</label>
        <select id="uso" required>
          <option value="">Seleccionar...</option>
          <option value="urbano">Urbano</option>
          <option value="familiar">Familiar</option>
          <option value="trabajo">Trabajo</option>
          <option value="deportivo">Deportivo</option>
        </select>

        <label>Tipo de vehículo</label>
        <select id="tipo" required>
          <option value="">Seleccionar...</option>
          <option value="gasolina">Gasolina</option>
          <option value="híbrido">Híbrido</option>
          <option value="eléctrico">Eléctrico</option>
        </select>

        <label>Condición del vehículo</label>
        <select id="condicion" required>
          <option value="">Seleccionar...</option>
          <option value="nuevo">Nuevo (0 km)</option>
          <option value="seminuevo">Seminuevo (1-3 años)</option>
          <option value="usado">Usado (más de 3 años)</option>
          <option value="ambos">Me interesan ambos</option>
        </select>

        <label>Ciudad</label>
        <input type="text" id="ciudad" placeholder="Ej: Bogotá" required />

        <div class="button-group">
          <button type="submit" class="btn-match">Buscar mi AutoMatch</button>
          <button
            type="button"
            id="btn-nueva-busqueda"
            class="btn-nueva-busqueda"
            style="display: none;"
          >
            ↻ Nueva Búsqueda
          </button>
        </div>
      </form>

      <!-- Indicador de carga -->
      <div id="loading" class="loading-spinner">
        <div class="spinner"></div>
        <p class="loading-text">Buscando tu AutoMatch perfecto...</p>
      </div>

      <!-- Resultados a la derecha -->
      <div id="resultado" class="resultado resultado-section"></div>
    </div>
  </section>

  <!-- ✅ Carga del JS v3 MVP optimizado -->
  <script type="module" src="/js/automatch-v3.js" defer></script>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import AutoMatchBanner from "../components/automatch/AutoMatchBanner.astro";
---

<link rel="stylesheet" href="/css/automatch-find.css" />

<Layout title="AutoMatch | Encuentra tu auto ideal en Colombia">
  <section class="automatch-page">
    <header class="automatch-find-hero">
      <p class="automatch-find-hero__eyebrow">Herramienta inteligente · Colombia</p>
      <h1 class="automatch-find-hero__title">
        Encuentra tu auto ideal con <span>AutoMatch</span>
      </h1>
      <p class="automatch-find-hero__lead">
        Responde unas preguntas sobre presupuesto, uso y ciudad. Te mostramos el
        modelo que mejor encaja y puedes solicitar test drive con un asesor.
      </p>
      <a href="/" class="automatch-find-hero__back">← Volver al inicio</a>
    </header>

    <AutoMatchBanner />

    <details class="user-profile-form">
      <summary>Tu perfil (opcional)</summary>
      <p class="user-profile-form__hint">
        Guardamos estos datos en tu navegador para afinar recomendaciones en
        futuras búsquedas.
      </p>
      <form id="user-profile-form">
        <label for="user-name">Nombre / alias</label>
        <input type="text" id="user-name" placeholder="Tu nombre" />

        <label for="user-city">Ciudad</label>
        <input type="text" id="user-city" placeholder="Ej: Bogotá" />

        <label for="user-age">Edad (opcional)</label>
        <input
          type="number"
          id="user-age"
          placeholder="25"
          min="16"
          max="120"
        />

        <label for="user-preferences">Preferencia de carrocería</label>
        <select id="user-preferences">
          <option value="">Seleccionar...</option>
          <option value="suv">SUV</option>
          <option value="sedan">Sedán</option>
          <option value="hatchback">Hatchback</option>
          <option value="pickup">Pickup</option>
          <option value="convertible">Convertible</option>
        </select>
      </form>
    </details>

    <div class="automatch-container">
      <form id="automatch-form" class="form-section">
        <h2 class="form-section__title">Cuéntanos qué buscas</h2>

        <label for="presupuesto">Presupuesto (millones COP)</label>
        <select id="presupuesto" required>
          <option value="">Seleccionar...</option>
          <option value="70-90">$70 – $90 millones</option>
          <option value="90-120">$90 – $120 millones</option>
          <option value="120-150">$120 – $150 millones</option>
          <option value="150-180">$150 – $180 millones</option>
          <option value="180-220">$180 – $220 millones</option>
          <option value="220-280">$220 – $280 millones</option>
          <option value="280-380">$280 – $380 millones</option>
          <option value="380-500">$380 – $500 millones</option>
          <option value="500+">Más de $500 millones</option>
        </select>

        <label for="uso">Tipo de uso</label>
        <select id="uso" required>
          <option value="">Seleccionar...</option>
          <option value="urbano">Urbano</option>
          <option value="familiar">Familiar</option>
          <option value="trabajo">Trabajo</option>
          <option value="deportivo">Deportivo</option>
        </select>

        <label for="tipo">Tipo de vehículo</label>
        <select id="tipo" required>
          <option value="">Seleccionar...</option>
          <option value="gasolina">Gasolina</option>
          <option value="híbrido">Híbrido</option>
          <option value="eléctrico">Eléctrico</option>
        </select>

        <label for="condicion">Condición</label>
        <select id="condicion" required>
          <option value="">Seleccionar...</option>
          <option value="nuevo">Nuevo (0 km)</option>
          <option value="seminuevo">Seminuevo (1–3 años)</option>
          <option value="usado">Usado (más de 3 años)</option>
          <option value="ambos">Nuevo o usado</option>
        </select>

        <label for="ciudad">Ciudad</label>
        <input type="text" id="ciudad" placeholder="Ej: Bogotá" required />

        <div class="button-group">
          <button type="submit" class="btn-match">Buscar mi AutoMatch</button>
          <button
            type="button"
            id="btn-nueva-busqueda"
            class="btn-nueva-busqueda"
            hidden
          >
            Nueva búsqueda
          </button>
        </div>
      </form>

      <div id="loading" class="loading-spinner" hidden>
        <div class="spinner"></div>
        <p class="loading-text">Buscando tu AutoMatch...</p>
      </div>

      <div id="resultado" class="resultado resultado-section"></div>
    </div>
  </section>

  <script type="module" src="/js/automatch-v3.js" defer></script>
</Layout>

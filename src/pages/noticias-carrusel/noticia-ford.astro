---
// Importar el layout principal
import Layout from "../../layouts/Layout.astro";
---

<Layout title="noticia-ford" bodyClass="otras-page">
  <meta charset="UTF-8" />
  <section class="section-noticias">
    <!-- Título -->
    <div class="header">
      <h1>Explorando la Ford Bronco: innovaciones en diseño y seguridad.</h1>
    </div>
    <div class="container">
      <!-- Tarjeta 1 -->
      <div class="card">
        <div class="card-image">
          <img
            src="/img/ford-bronco/ford-bronco-portada.jpg"
            alt="bronco diseño"
          />
        </div>
        <div class="card-text">
          <h2>Diseño</h2>
          <p>
            La Ford Bronco tiene un diseño robusto y cuadrado que evoca la
            nostalgia de los todo terrenos clásicos.
          </p>
          <p>
            Personalización: permite una amplia personalización, ofreciendo
            diferentes opciones de techo desmontable y puertas extraíbles para
            disfrutar de una experiencia al aire libre completa. Además, está
            disponible en una variedad de colores y acabados que permiten a los
            propietarios expresar su estilo personal.
          </p>
        </div>
      </div>

      <!-- Tarjeta 2 -->
      <div class="card reverse">
        <div class="card-image">
          <img
            src="/img/ford-bronco/ford-bronco-tecnologia.jpg"
            alt="bronco tecnología"
          />
        </div>
        <div class="card-text">
          <h2>Tecnología</h2>
          <p>
            Equipada con la última tecnología, la Ford Bronco ofrece un sistema
            de infoentretenimiento de vanguardia con puntos de acceso Wi-Fi 4G
            LTE,.
          </p>
          <p>
            <strong>Seguridad:</strong> En cuanto a seguridad, la Ford Bronco cuenta
            con un sistema de cámaras de 360 grados, control de crucero adaptativo
            y asistente de mantenimiento de carril. También incluye frenado automático
            de emergencia, lo que ayuda a evitar colisiones potenciales al detectar
            obstáculos en el camino y activar los frenos automáticamente si el conductor
            no reacciona a tiempo.
          </p>
        </div>
      </div>

      <!-- Tarjeta 3 -->
      <div class="card">
        <div class="card-image">
          <img
            src="/img/ford-bronco/ford-bronco-motor.jpg"
            alt="bronco motor"
          />
        </div>
        <div class="card-text">
          <h2>Motor</h2>
          <p>
            Equipada con motores potentes, incluyendo el EcoBoost de 2.3 litros,
            ideal para aventuras extremas. Este motor turboalimentado
            proporciona una excelente combinación de potencia y eficiencia, para
            terrenos difíciles. Además, la Bronco ofrece la opción de un motor
            V6 EcoBoost de 2.7 litros, que proporciona aún más fuerza y
            rendimiento para los entusiastas del todoterreno.
          </p>
        </div>
      </div>
      <!-- Tarjeta 4 -->
      <div class="card reverse">
        <div class="card-image">
          <img
            src="/img/ford-bronco/ford-bronco-interior.jpg"
            alt="bronco interior"
          />
        </div>
        <div class="card-text">
          <h2>Interior</h2>
          <p>
            El interior combina comodidad y funcionalidad con asientos de cuero
            opcionales y materiales duraderos.
          </p>
          <p>
            Además, el diseño del interior está pensado para proporcionar el
            máximo confort y conveniencia, con características como
            almacenamiento inteligente y superficies fáciles de limpiar
          </p>
        </div>
      </div>
      <!-- Tarjeta 5 -->
      <div class="card">
        <div class="card-image">
          <img
            src="/img/ford-bronco/ford-bronco-suspension.jpg"
            alt="bronco suspensión"
          />
        </div>
        <div class="card-text">
          <h2>Suspensión</h2>
          <p>
            La suspensión avanzada con amortiguadores Bilstein asegura una
            conducción estable para el conductor y pasajeros sin importar el
            terreno.
          </p>
          <p>
            los amortiguadores Bilstein, conocidos por su durabilidad y
            rendimiento, garantizan una absorción de impactos eficiente y una
            estabilidad óptima, permitiendo que la Bronco mantenga su capacidad
            todoterreno sin comprometer el confort.
          </p>
        </div>
      </div>

      <!-- Ficha Técnica Profesional -->
      <section class="ficha-tecnica-profesional">
        <h2
          style="font-size: 36px; font-weight: bold; color: #08341f; text-align: center; margin-bottom: 30px; font-family: 'Poppins', sans-serif;"
        >
          📋 Ficha Técnica Profesional - Ford Bronco
        </h2>
        <div class="ficha-grid">
          <div class="ficha-item">
            <div class="ficha-label">💰 Precio Estimado</div>
            <div class="ficha-value">
              Desde USD $38,000 / $170 millones COP (aprox.)
            </div>
          </div>
          <div class="ficha-item">
            <div class="ficha-label">🚗 Versiones</div>
            <div class="ficha-value">
              Bronco Base, Big Bend, Black Diamond, Outer Banks, Badlands,
              Wildtrak, Everglades, Raptor
            </div>
          </div>
          <div class="ficha-item">
            <div class="ficha-label">⚙️ Motor</div>
            <div class="ficha-value">
              2.3L EcoBoost Turbo 4 cilindros / 2.7L EcoBoost V6 Twin-Turbo /
              Bronco Raptor: 3.0L V6 Twin-Turbo
            </div>
          </div>
          <div class="ficha-item">
            <div class="ficha-label">💪 Potencia</div>
            <div class="ficha-value">
              2.3L: 300 hp / 2.7L: 330 hp / Raptor: 418 hp
            </div>
          </div>
          <div class="ficha-item">
            <div class="ficha-label">🔩 Torque</div>
            <div class="ficha-value">
              2.3L: 420 Nm / 2.7L: 542 Nm / Raptor: 583 Nm
            </div>
          </div>
          <div class="ficha-item">
            <div class="ficha-label">⛽ Consumo</div>
            <div class="ficha-value">
              2.3L: 11-13 L/100km / 2.7L V6: 13-15 L/100km (mixto)
            </div>
          </div>
          <div class="ficha-item">
            <div class="ficha-label">⚡ Aceleración</div>
            <div class="ficha-value">
              0-100 km/h: 2.3L ~8s / 2.7L ~6.5s / Raptor ~5.8s
            </div>
          </div>
          <div class="ficha-item">
            <div class="ficha-label">🔧 Transmisión y Tracción</div>
            <div class="ficha-value">
              Automática 10 velocidades / 4x4 con sistema G.O.A.T. Modes (7
              modos de terreno) / Bloqueos diferenciales / Desconectables
              estabilizadoras
            </div>
          </div>
          <div class="ficha-item">
            <div class="ficha-label">🛡️ Seguridad</div>
            <div class="ficha-value">
              Ford Co-Pilot360™, control de crucero adaptativo, frenado
              autónomo, cámara 360° con lavado, asistente de pendientes, control
              de descenso
            </div>
          </div>
          <div class="ficha-item">
            <div class="ficha-label">🎯 Equipamiento Destacado</div>
            <div class="ficha-value">
              Pantalla SYNC 4 de 12", techo y puertas removibles, suspensión
              Bilstein, amortiguadores FOX (Raptor), protección inferior,
              snorkel opcional, winch eléctrico
            </div>
          </div>
          <div class="ficha-item pros">
            <div class="ficha-label">✅ Puntos Fuertes</div>
            <div class="ficha-value">
              • Capacidad off-road excepcional<br />• Sistema G.O.A.T. con 7
              modos de terreno<br />• Techo y puertas removibles<br />• Motor
              2.7L V6 potente y confiable<br />• Bronco Raptor versión extrema
              418 hp
            </div>
          </div>
          <div class="ficha-item contras">
            <div class="ficha-label">❌ Áreas de Mejora</div>
            <div class="ficha-value">
              • Consumo elevado especialmente V6<br />• Confort en ciudad
              limitado (suspensión dura)<br />• Espacio interior menor vs SUVs
              convencionales<br />• Manejo en carretera menos refinado
            </div>
          </div>
          <div class="ficha-item competencia">
            <div class="ficha-label">🏁 Competencia Directa</div>
            <div class="ficha-value">
              Jeep Wrangler, Land Rover Defender, Toyota 4Runner, Mercedes-Benz
              Clase G, Suzuki Jimny
            </div>
          </div>
        </div>
      </section>
    </div>
  </section>
</Layout>

<style>
  /* === ESTILOS FICHA TÉCNICA PROFESIONAL === */
  .ficha-tecnica-profesional {
    max-width: 1400px;
    margin: 40px auto;
    padding: 30px;
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .ficha-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-top: 30px;
  }

  .ficha-item {
    background: white;
    padding: 20px;
    border-radius: 12px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
    transition: all 0.3s ease;
    border-left: 4px solid #08341f;
  }

  .ficha-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 15px rgba(0, 0, 0, 0.15);
    border-left-color: #e6b410;
  }

  .ficha-item.pros {
    border-left-color: #28a745;
    background: linear-gradient(135deg, #ffffff 0%, #f0fff4 100%);
  }

  .ficha-item.contras {
    border-left-color: #dc3545;
    background: linear-gradient(135deg, #ffffff 0%, #fff5f5 100%);
  }

  .ficha-item.competencia {
    border-left-color: #007bff;
    background: linear-gradient(135deg, #ffffff 0%, #f0f8ff 100%);
  }

  .ficha-label {
    font-weight: 700;
    color: #08341f;
    margin-bottom: 8px;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-family: "Poppins", sans-serif;
  }

  .ficha-value {
    color: #2c3e50;
    font-size: 15px;
    line-height: 1.6;
    font-family: "Georgia", serif;
  }

  @media (max-width: 768px) {
    .ficha-tecnica-profesional {
      padding: 20px 15px;
      margin: 20px 10px;
    }

    .ficha-grid {
      grid-template-columns: 1fr;
      gap: 15px;
    }

    .ficha-tecnica-profesional h2 {
      font-size: 24px !important;
    }
  }
  /* === FIN ESTILOS FICHA TÉCNICA PROFESIONAL === */

  body {
    margin: 0;
    padding: 0;
    font-family: "Georgia", serif;
  }

  .section-noticias {
    padding: 20px 10px;
    text-align: center;
    max-width: 100%;
    margin: auto;
  }

  /* header */
  .header h1 {
    text-align: center;
    padding: 10px;
    font-size: 48px;
    font-weight: bolder;
    color: black;
    margin-bottom: 60px;
    background: white;
  }

  .header h1,
  .card-text h2 {
    font-family: "Georgia", serif;
  }

  .container {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .card {
    display: flex;
    flex-direction: row;
    align-items: center;
    border-radius: 15px;
    overflow: hidden;

    transition:
      transform 0.3s ease-in-out,
      box-shadow 0.3s ease-in-out;
  }

  .card:hover {
    transform: translateY(-8px);
  }

  .card.reverse {
    flex-direction: row-reverse;
  }

  .card-image {
    width: 50%;
    height: 100%;
  }

  .card-image,
  .card-text {
    width: 100%;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-text {
    width: 50%;
    padding: 70px;
    text-align: start;
  }

  .card-text h2 {
    font-size: 46px;
    color: black;
    margin-bottom: 15px;
    text-align: start;
    /*border-bottom: 2px solid black;
    display: inline-block;  Esto hace que el ancho de la línea sea igual al del texto */

    font-weight: bolder;
  }

  .card-text p {
    font-size: 25px;
    line-height: 30px;
    color: #121212;
    text-align: start;
    font-family: "Georgia", serif;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .card {
      flex-direction: column;
    }
    .header h1 {
      font-size: 26px;
      text-align: start;
      padding: 0 10px;
      margin-bottom: 20px;
    }

    .card.reverse {
      flex-direction: column;
    }

    .card-image,
    .card-text {
      width: 100%;
    }

    .card-text {
      text-align: center;
      padding: 10px;
    }

    .card-text h2 {
      font-size: 24px;
      border-bottom: none;
      text-align: start;
      padding: 0;
      margin: 0;
    }

    .card-text p {
      font-size: 18px;
      padding-top: 10px;
    }
  }
</style>

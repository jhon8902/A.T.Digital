---
import Layout from "../layouts/Layout.astro";
import SectionInfo from "../components/Section-Info/Section-Info.astro";
import Hibridos from "../components/hibridos/hibridos.astro";
import Noticias from "../components/section-noticias/noticias.astro";
import Electricos from "../components/electricos/Electricos.astro";
import Deportes from "../components/deportes/deportes.astro";
import Pruebas from "../components/pruebas/pruebas.astro";
import AutoMatch from "../components/automatch/automatch.astro";
import AutoMatchPromo from "../components/automatch/AutoMatchPromo.astro";
import AdBanner from "../components/advertising/AdBanner.astro";
import { getApiUrl, fetchWithTimeout } from "../lib/api";
import {
  buildAutomatchCarousel,
  type AutomatchDbNote,
} from "../lib/automatch-catalog";

let autos: ReturnType<typeof buildAutomatchCarousel> = [];

try {
  const apiUrl = getApiUrl("get-notes");
  const data = await fetchWithTimeout(apiUrl);

  if (data && Array.isArray(data)) {
    const automatchNotes: AutomatchDbNote[] = data
      .filter((note: any) => note.category?.toLowerCase() === "automatch")
      .map((note: any) => ({
        id: note.id,
        title: note.title,
        subtitle: note.subtitle,
        content: note.content || "",
        created_at: note.created_at,
        image1: note.image1,
        image2: note.image2,
        image3: note.image3,
        image4: note.image4,
        image5: note.image5,
        image6: note.image6,
      }));

    autos = buildAutomatchCarousel(automatchNotes, { skipEditorialCover: true });
  }
} catch (err) {
  console.error("Error cargando autos:", err);
  autos = buildAutomatchCarousel([], { skipEditorialCover: true });
}
---

<Layout
  title="Auto-Tech-Digital | Autos Eléctricos, Híbridos y Noticias Automotrices en Colombia"
  description="Descubre los mejores autos eléctricos, híbridos y lanzamientos en Colombia. Pruebas de manejo, fichas técnicas y noticias del mundo automotriz."
  class="home-page"
>
  <!-- ✅ SECCIONES VISIBLES -->
  <div class="extra-sections" id="extra-sections">
    <section id="automatch" class="automatch-destacado">
      <AutoMatch autos={autos} />
    </section>

    <SectionInfo />

    <Electricos />
    <AutoMatchPromo
      title="Compara eléctricos con AutoMatch"
      description="Filtra por autonomía, precio y uso. Encuentra el modelo ideal y solicita test drive."
    />
    <Hibridos />
    <Noticias />

    <Pruebas />
    <AutoMatchPromo
      variant="compact"
      title="¿Listo para probarlo en la vida real?"
      description="AutoMatch te ayuda a elegir y conectarte con un asesor para test drive."
    />

    <section class="home-secondary-content" aria-label="Más contenido editorial">
      <Deportes compact />
    </section>

    <AdBanner />
  </div>
</Layout>

<style>
  /* Animación suave de entrada para secciones */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .automatch-destacado {
    margin: 0;
    padding: 0;
    animation: fadeInUp 0.7s ease-out;
    overflow: hidden;
  }

  .automatch-destacado :global(.automatch-home) {
    margin: 0;
  }

  .home-secondary-content {
    opacity: 0.98;
  }

  /* Secciones siempre visibles con transiciones suaves */
  .extra-sections {
    opacity: 1;
    transform: translateY(0);
    max-height: none;
    overflow: visible;
    background: white;
  }

  .extra-sections > * {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
  }

  .extra-sections > *:nth-child(1) {
    animation-delay: 0.15s;
  }

  .extra-sections > *:nth-child(2) {
    animation-delay: 0.3s;
  }

  .extra-sections > *:nth-child(3) {
    animation-delay: 0.45s;
  }

  .extra-sections > *:nth-child(4) {
    animation-delay: 0.6s;
  }

  .extra-sections > *:nth-child(5) {
    animation-delay: 0.75s;
  }

  .extra-sections > *:nth-child(6) {
    animation-delay: 0.9s;
  }

  .extra-sections > *:nth-child(7) {
    animation-delay: 1.05s;
  }

  .extra-sections > *:nth-child(8) {
    animation-delay: 1.2s;
  }

  .extra-sections > *:nth-child(9) {
    animation-delay: 1.35s;
  }
</style>

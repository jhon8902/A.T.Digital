---
import { resolveSiteNotes } from "../lib/api";
import Layout from "../layouts/Layout.astro";
import SectionInfo from "../components/Section-Info/Section-Info.astro";
import Hibridos from "../components/hibridos/hibridos.astro";
import Noticias from "../components/section-noticias/noticias.astro";
import Electricos from "../components/electricos/Electricos.astro";
import Deportes from "../components/deportes/deportes.astro";
import Pruebas from "../components/pruebas/pruebas.astro";
// import AdBanner from "../components/advertising/AdBanner.astro";

let homeNotes = await resolveSiteNotes();
---

<Layout
  title="Auto-Tech-Digital | Autos Eléctricos, Híbridos y Noticias Automotrices en Colombia"
  description="Descubre los mejores autos eléctricos, híbridos y lanzamientos en Colombia. Pruebas de manejo, fichas técnicas y noticias del mundo automotriz."
  class="home-page"
>
  <div class="extra-sections" id="extra-sections">
    <!-- AutoMatch — oculto hasta tener la herramienta lista
    <section id="automatch" class="automatch-destacado">
      <AutoMatch autos={autos} />
    </section>
    -->

    <SectionInfo notes={homeNotes} />

    <Electricos notes={homeNotes} />
    <!--
    <AutoMatchPromo
      title="Compara eléctricos con AutoMatch"
      description="Filtra por autonomía, precio y uso. Encuentra el modelo ideal para ti."
    />
    -->
    <Hibridos notes={homeNotes} />
    <Noticias notes={homeNotes} />

    <!-- Banner marca — oculto temporalmente
    <AdBanner variant="autotech" />
    -->

    <Pruebas notes={homeNotes} />
    <!--
    <AutoMatchPromo
      variant="compact"
      title="¿Listo para encontrar tu próximo auto?"
      description="Usa AutoMatch para comparar modelos y ver fichas destacadas."
    />
    -->

    <section
      class="home-secondary-content"
      aria-label="Más contenido editorial"
    >
      <Deportes compact notes={homeNotes} />
    </section>
  </div>

  <link rel="stylesheet" href="/css/home-typography.css?v=8" />
</Layout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* .automatch-destacado {
    margin-bottom: 1rem;
    animation: fadeInUp 0.7s ease-out;
  } */

  .home-secondary-content {
    opacity: 0.98;
  }

  .extra-sections {
    opacity: 1;
    transform: translateY(0);
    max-height: none;
    overflow: visible;
    background: white;
  }

  .extra-sections > * {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
  }

  /* Noticias al tope: sin slide-up para evitar salto brusco del título */
  .extra-sections > #noticias {
    animation: none;
    opacity: 1;
    transform: none;
  }

  .extra-sections > *:nth-child(1) {
    animation-delay: 0.15s;
  }

  .extra-sections > *:nth-child(2) {
    animation-delay: 0.3s;
  }

  .extra-sections > *:nth-child(3) {
    animation-delay: 0.45s;
  }

  .extra-sections > *:nth-child(4) {
    animation-delay: 0.6s;
  }

  .extra-sections > *:nth-child(5) {
    animation-delay: 0.75s;
  }

  .extra-sections > *:nth-child(6) {
    animation-delay: 0.9s;
  }

  .extra-sections > *:nth-child(7) {
    animation-delay: 1.05s;
  }

  .extra-sections > *:nth-child(8) {
    animation-delay: 1.2s;
  }

  .extra-sections > *:nth-child(9) {
    animation-delay: 1.35s;
  }

  .extra-sections > *:nth-child(10) {
    animation-delay: 1.5s;
  }
</style>

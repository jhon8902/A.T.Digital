---
import Layout from "../layouts/Layout.astro";
import {
  sectorRadarActive,
  sectorRadarArchive,
  sectorRadarHero,
  sectorRadarSource,
  sectorRadarTrends,
} from "../lib/sector-radar";

const trends = sectorRadarTrends;
---

<Layout title="Tendencias del sector" bodyClass="tendencias-page">
  <section class="tendencias-hero">
    <div class="hero-inner">
      <span class="hero-kicker">Radar del sector</span>
      <p class="hero-edition">
        Edición actual — {sectorRadarActive.label} · {sectorRadarActive.period}
      </p>
      <h1>Tendencias clave del mercado automotor en Colombia</h1>
      <p>
        {sectorRadarHero.description}
      </p>
      <div class="hero-actions">
        <a class="cta-primary" href="/#noticias">Ver noticias</a>
        <a class="cta-secondary" href="#tendencias-grid">Explorar tendencias</a>
      </div>
      <div class="hero-stats">
        {
          sectorRadarHero.stats.map((stat) => (
            <div class="stat">
              <span class="stat-value">{stat.value}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section id="tendencias-grid" class="tendencias-grid">
    {
      trends.map((trend) => (
        <article class="trend-card">
          <div class="trend-card-top">
            <span class="trend-tag">{trend.tag}</span>
            <span class="trend-date">{trend.date}</span>
          </div>
          <p class="trend-metric" aria-label="Dato clave">
            {trend.metric}
          </p>
          <h2>{trend.title}</h2>
          <p class="trend-summary">{trend.summary}</p>
        </article>
      ))
    }
    <p class="tendencias-source">
      <strong>{sectorRadarSource.label}:</strong> {sectorRadarSource.text}
    </p>
  </section>

  {
    sectorRadarArchive.length > 0 && (
      <section id="tendencias-archivo" class="tendencias-archivo">
        <div class="tendencias-archivo-inner">
          <h2>Ediciones anteriores</h2>
          <p class="tendencias-archivo-lead">
            Cada actualización queda registrada con su fecha y fuente para que
            puedas contrastar cómo evolucionan las señales del mercado.
          </p>
          {sectorRadarArchive.map((edition) => (
            <details class="tendencias-archive-item">
              <summary>
                <span class="tendencias-archive-title">{edition.label}</span>
                <span class="tendencias-archive-period">{edition.period}</span>
              </summary>
              <div class="tendencias-archive-body">
                <p class="tendencias-source tendencias-source--archive">
                  <strong>{edition.source.label}:</strong> {edition.source.text}
                </p>
                <div class="tendencias-grid tendencias-grid--archive">
                  {edition.trends.map((trend) => (
                    <article class="trend-card trend-card--archive">
                      <div class="trend-card-top">
                        <span class="trend-tag">{trend.tag}</span>
                        <span class="trend-date">{trend.date}</span>
                      </div>
                      <p class="trend-metric" aria-label="Dato clave">
                        {trend.metric}
                      </p>
                      <h3>{trend.title}</h3>
                      <p class="trend-summary">{trend.summary}</p>
                    </article>
                  ))}
                </div>
              </div>
            </details>
          ))}
        </div>
      </section>
    )
  }

  <section class="tendencias-cta">
    <div class="cta-content">
      <h3>Quieres más contexto en tiempo real</h3>
      <p>
        Revisa las últimas notas y el balance del primer semestre para entender
        cómo se materializan estas tendencias en el mercado local.
      </p>
      <a class="cta-primary" href="/#noticias">Ir a noticias</a>
    </div>
  </section>
</Layout>

<style>
  .tendencias-hero {
    background:
      radial-gradient(
        circle at 15% 20%,
        rgba(248, 202, 38, 0.2),
        transparent 55%
      ),
      linear-gradient(150deg, #10161f 0%, #18212d 58%, #1f2b3a 100%);
    color: #f8fafc;
    padding: 80px 24px 60px;
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 13px;
    font-weight: 700;
    color: #f8ca26;
  }

  .hero-edition {
    margin: -8px 0 0;
    font-size: 0.95rem;
    color: rgba(248, 250, 252, 0.72);
    font-family: "Poppins", sans-serif;
    letter-spacing: 0.02em;
  }

  .tendencias-hero h1 {
    font-size: clamp(2.35rem, 3.3vw, 3.7rem);
    font-family: "Georgia", serif;
    margin: 0;
    line-height: 1.1;
    color: #f8fafc !important;
  }

  .tendencias-hero p {
    font-size: 1.2rem;
    max-width: 720px;
    line-height: 1.7;
    color: rgba(248, 250, 252, 0.85);
    font-family: "Poppins", sans-serif;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .cta-primary,
  .cta-secondary {
    text-decoration: none;
    font-weight: 700;
    padding: 12px 26px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .cta-primary {
    background: #f8ca26;
    color: #1a1a1a;
    box-shadow: 0 12px 24px rgba(248, 202, 38, 0.25);
  }

  .cta-secondary {
    border: 1px solid rgba(248, 202, 38, 0.6);
    color: #f8ca26;
  }

  .cta-primary:hover,
  .cta-secondary:hover {
    transform: translateY(-2px);
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 16px;
  }

  .stat {
    background: rgba(16, 22, 31, 0.62);
    border: 1px solid rgba(248, 202, 38, 0.25);
    border-radius: 16px;
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 700;
    color: #f8ca26;
  }

  .stat-label {
    font-size: 0.98rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: whitesmoke;
  }

  .tendencias-grid {
    max-width: 1080px;
    margin: 0 auto;
    padding: clamp(48px, 6vw, 72px) clamp(20px, 4vw, 32px);
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
    background: #f8f7f4;
  }

  @media (min-width: 720px) {
    .tendencias-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 32px 28px;
    }
  }

  .trend-card {
    border: 1px solid rgba(8, 52, 31, 0.08);
    border-radius: 20px;
    padding: clamp(26px, 3vw, 34px) clamp(24px, 3vw, 32px);
    color: #1a1a1a;
    background: #fff;
    box-shadow: 0 8px 24px rgba(17, 24, 39, 0.06);
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
    overflow: hidden;
    min-height: 0;
  }

  .trend-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at top right,
      rgba(248, 202, 38, 0.1),
      transparent 58%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .trend-card:hover::after {
    opacity: 1;
  }

  .trend-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    font-size: 0.8125rem;
    color: rgba(26, 26, 26, 0.85) !important;
    position: relative;
    z-index: 1;
  }

  .trend-tag {
    background: #f8ca26;
    color: #1a1a1a;
    padding: 5px 12px;
    border-radius: 999px;
    font-weight: 700;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  .trend-date {
    color: rgba(26, 26, 26, 0.65) !important;
    font-weight: 500;
    white-space: nowrap;
  }

  .trend-metric {
    margin: 4px 0 2px;
    padding: 12px 16px;
    background: linear-gradient(
      135deg,
      rgba(248, 202, 38, 0.14) 0%,
      rgba(248, 202, 38, 0.06) 100%
    );
    border-left: 4px solid #d4a742;
    border-radius: 10px;
    font-weight: 800;
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    line-height: 1.2;
    color: #08341f;
    letter-spacing: -0.01em;
    position: relative;
    z-index: 1;
  }

  .trend-card h2 {
    margin: 0;
    font-size: clamp(1.2rem, 1.6vw, 1.38rem);
    font-family: "Georgia", serif;
    color: #1a1a1a !important;
    line-height: 1.32;
    font-weight: 700;
    position: relative;
    z-index: 1;
  }

  .trend-summary {
    margin: 0;
    line-height: 1.72;
    font-size: 1.02rem;
    color: rgba(26, 26, 26, 0.82) !important;
    font-family: "Poppins", sans-serif;
    max-width: 48ch;
    position: relative;
    z-index: 1;
  }

  .tendencias-source {
    grid-column: 1 / -1;
    margin: 8px 0 0;
    padding: 18px 20px;
    border-radius: 12px;
    background: rgba(8, 52, 31, 0.05);
    border: 1px solid rgba(8, 52, 31, 0.08);
    font-size: 0.92rem;
    line-height: 1.65;
    color: rgba(26, 26, 26, 0.75);
    font-family: "Poppins", sans-serif;
  }

  .tendencias-source strong {
    color: #08341f;
    font-weight: 700;
  }

  .tendencias-archivo {
    padding: 0 clamp(20px, 4vw, 32px) clamp(48px, 6vw, 64px);
    background: #f8f7f4;
  }

  .tendencias-archivo-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .tendencias-archivo h2 {
    margin: 0;
    font-family: "Georgia", serif;
    font-size: clamp(1.65rem, 2.5vw, 2rem);
    color: #08341f;
  }

  .tendencias-archivo-lead {
    margin: 0;
    max-width: 62ch;
    font-family: "Poppins", sans-serif;
    font-size: 1rem;
    line-height: 1.65;
    color: rgba(26, 26, 26, 0.72);
  }

  .tendencias-archive-item {
    border: 1px solid rgba(8, 52, 31, 0.1);
    border-radius: 16px;
    background: #fff;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(17, 24, 39, 0.04);
  }

  .tendencias-archive-item summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 10px 16px;
    padding: 18px 22px;
    font-family: "Poppins", sans-serif;
  }

  .tendencias-archive-item summary::-webkit-details-marker {
    display: none;
  }

  .tendencias-archive-item summary::after {
    content: "+";
    font-size: 1.35rem;
    font-weight: 700;
    color: #d4a742;
    line-height: 1;
  }

  .tendencias-archive-item[open] summary::after {
    content: "−";
  }

  .tendencias-archive-title {
    font-weight: 700;
    color: #08341f;
    font-size: 1.05rem;
  }

  .tendencias-archive-period {
    color: rgba(26, 26, 26, 0.62);
    font-size: 0.92rem;
  }

  .tendencias-archive-body {
    padding: 0 22px 22px;
    border-top: 1px solid rgba(8, 52, 31, 0.08);
  }

  .tendencias-source--archive {
    margin: 18px 0 20px;
  }

  .tendencias-grid--archive {
    padding: 0;
    background: transparent;
    gap: 20px;
  }

  .trend-card--archive h3 {
    margin: 0;
    font-size: clamp(1.15rem, 1.5vw, 1.3rem);
    font-family: "Georgia", serif;
    color: #1a1a1a !important;
    line-height: 1.32;
    font-weight: 700;
  }

  .trend-card--archive {
    box-shadow: none;
    border-color: rgba(8, 52, 31, 0.06);
    background: #faf9f7;
  }

  .tendencias-cta {
    padding: 60px 24px 80px;
    background: #f8f7f4;
  }

  .cta-content {
    max-width: 900px;
    margin: 0 auto;
    background: linear-gradient(160deg, #10161f 0%, #18212d 60%, #1f2b3a 100%);
    border: 1px solid rgba(248, 202, 38, 0.3);
    box-shadow: 0 16px 34px rgba(0, 0, 0, 0.22);
    border-radius: 20px;
    padding: 40px;
    color: #f8fafc;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cta-content h3 {
    margin: 0;
    font-size: 2.15rem;
    font-family: "Georgia", serif;
    color: #f8fafc !important;
  }

  .cta-content p {
    margin: 0;
    color: rgba(248, 250, 252, 0.88);
    font-family: "Poppins", sans-serif;
    font-size: 1.05rem;
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .tendencias-hero {
      padding: 60px 20px 40px;
    }

    .hero-inner {
      width: calc(100% - 20px);
      margin-left: auto;
      margin-right: auto;
    }

    .tendencias-grid {
      padding: 40px 18px 48px;
      gap: 22px;
    }

    .trend-card {
      padding: 24px 20px;
      gap: 12px;
    }

    .trend-metric {
      padding: 10px 14px;
      font-size: 1.12rem;
    }

    .cta-content {
      padding: 32px 24px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
    }

    .tendencias-hero h1 {
      font-size: 2.55rem;
      line-height: 1.12;
    }

    .tendencias-hero p {
      font-size: 1.08rem;
      line-height: 1.65;
    }

    .trend-card h2 {
      font-size: 1.22rem;
      line-height: 1.34;
    }

    .trend-summary {
      font-size: 0.98rem;
      line-height: 1.68;
      max-width: none;
    }
  }
</style>

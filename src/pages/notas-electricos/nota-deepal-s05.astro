---
import Layout from "../../layouts/Layout.astro";
import RelatedNotes from "../notas/RelatedNotes.astro";
---

<Layout
  title="Deepal S05 Eléctrico | Ficha AutoMatch"
  description="SUV eléctrico Deepal S05: diseño contemporáneo, tecnología de cabina y autonomía competitiva en Colombia."
  bodyClass="otras-page"
>
  <section class="ficha-electrica">
    <header class="ficha-electrica__header">
      <h1>Deepal S05 Eléctrico</h1>
      <p>
        SUV eléctrico moderno con enfoque en autonomía, tecnología de cabina y
        diseño contemporáneo. Versión E-Max 100% eléctrica en Colombia.
      </p>
    </header>

    <img
      class="ficha-electrica__hero"
      src="/img/Deepal-S05/Deepal%20S05.webp"
      alt="Deepal S05 Eléctrico"
      loading="eager"
    />

    <div class="ficha-electrica__grid">
      <article>
        <h2>Motorización</h2>
        <p>100% eléctrico. Aproximadamente 258 hp.</p>
      </article>
      <article>
        <h2>Autonomía</h2>
        <p>Hasta 458 km en ciclo WLTP (versión E-Max).</p>
      </article>
      <article>
        <h2>Equipamiento</h2>
        <ul>
          <li>Cabina digital</li>
          <li>Carga rápida</li>
          <li>ADAS</li>
          <li>Techo panorámico</li>
        </ul>
      </article>
      <article>
        <h2>Precio referencia CO</h2>
        <p>Desde $142.990.000 COP (versión E-Max).</p>
      </article>
    </div>
  </section>

  <RelatedNotes currentId={"deepal-s05"} category={"electricos"} />
</Layout>

<style>
  .ficha-electrica {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }

  .ficha-electrica__header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .ficha-electrica__header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 0.75rem;
  }

  .ficha-electrica__hero {
    width: 100%;
    max-height: 520px;
    object-fit: cover;
    border-radius: 1rem;
    margin-bottom: 2rem;
  }

  .ficha-electrica__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .ficha-electrica__grid article {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 0.75rem;
    padding: 1rem 1.1rem;
  }

  .ficha-electrica__grid h2 {
    font-size: 1rem;
    color: #08341f;
    margin-bottom: 0.5rem;
  }

  .ficha-electrica__grid ul {
    margin: 0;
    padding-left: 1.1rem;
  }
</style>

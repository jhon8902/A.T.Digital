---
import Layout from "../../layouts/Layout.astro";
import RelatedNotes from "../notas/RelatedNotes.astro";
---

<Layout
  title="Smart #5 Eléctrico | Ficha AutoMatch"
  description="SUV eléctrico compacto-premium Smart #5: diseño audaz, tecnología conectada y enfoque urbano en Colombia."
  bodyClass="otras-page"
>
  <section class="ficha-electrica">
    <header class="ficha-electrica__header">
      <h1>Smart #5 Eléctrico</h1>
      <p>
        SUV eléctrico compacto-premium con diseño audaz y enfoque urbano
        conectado. Disponible en versiones Pro+ y Brabus en Colombia.
      </p>
    </header>

    <img
      class="ficha-electrica__hero"
      src="/img/smart-5-electrico/smart-5-portada.webp"
      alt="Smart #5 Eléctrico"
      loading="eager"
    />

    <div class="ficha-electrica__grid">
      <article>
        <h2>Motorización</h2>
        <p>100% eléctrico. Hasta 340 hp en configuraciones AWD.</p>
      </article>
      <article>
        <h2>Autonomía</h2>
        <p>Largo alcance para uso urbano y periurbano.</p>
      </article>
      <article>
        <h2>Equipamiento</h2>
        <ul>
          <li>Pantalla OLED</li>
          <li>ADAS</li>
          <li>Carga rápida</li>
          <li>Conectividad 5G</li>
        </ul>
      </article>
      <article>
        <h2>Precio referencia CO</h2>
        <p>Desde $209.900.000 COP (versión Pro+).</p>
      </article>
    </div>
  </section>

  <RelatedNotes currentId={"smart-5"} category={"electricos"} />
</Layout>

<style>
  .ficha-electrica {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }

  .ficha-electrica__header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .ficha-electrica__header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 0.75rem;
  }

  .ficha-electrica__hero {
    width: 100%;
    max-height: 520px;
    object-fit: cover;
    border-radius: 1rem;
    margin-bottom: 2rem;
  }

  .ficha-electrica__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .ficha-electrica__grid article {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 0.75rem;
    padding: 1rem 1.1rem;
  }

  .ficha-electrica__grid h2 {
    font-size: 1rem;
    color: #08341f;
    margin-bottom: 0.5rem;
  }

  .ficha-electrica__grid ul {
    margin: 0;
    padding-left: 1.1rem;
  }
</style>

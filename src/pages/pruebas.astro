---
import Layout from "../layouts/Layout.astro";
import { getApiUrl, fetchWithTimeout } from "../lib/api";

type PruebaItem = {
  title: string;
  subtitle: string;
  editor?: string;
  video?: string;
  image?: string;
  href?: string;
  fecha?: string;
  source_scope?: string;
  sortDate: number;
};

function normalizeSourceScope(scope?: string) {
  return scope?.toLowerCase() === "internacional"
    ? "internacional"
    : "nacional";
}

function sourceScopeLabel(scope?: string) {
  return normalizeSourceScope(scope) === "internacional"
    ? "Internacional"
    : "Nacional";
}

function sourceScopeClass(scope?: string) {
  return normalizeSourceScope(scope) === "internacional"
    ? "archivo-scope archivo-scope--internacional"
    : "archivo-scope archivo-scope--nacional";
}

function cleanPublishedDate(value?: string) {
  const cleaned = (value || "").replace(/^Publicado:\s*/i, "").trim();
  if (!cleaned) return "";
  if (/\d{4}/.test(cleaned)) return cleaned;
  if (/^\d{1,2}-[a-záéíóúüñ]+$/i.test(cleaned)) return `${cleaned}-2025`;
  return cleaned;
}

const staticPruebas: PruebaItem[] = [
  {
    title: "Ford F-150",
    subtitle:
      "En nuestra prueba destacada tenemos a la Ford F-150, una pick-up que te brinda todo lo que necesitas para esos viajes fuera de la ciudad.",
    video: "/img/videos-pruebas/ford f-150.mp4",
    fecha: "Publicado: 10/08/2025",
    source_scope: "nacional",
    sortDate: new Date("2025-08-10").getTime(),
  },
  {
    title: "Xiaomi YU7",
    subtitle:
      "Diseño y tecnología en armonía, el carro de Xiaomi rompiendo récord como el más vendido en poco tiempo.",
    video: "/img/videos-pruebas/xiaomi YU7.mp4",
    fecha: "Publicado: 09/08/2025",
    source_scope: "internacional",
    sortDate: new Date("2025-08-09").getTime(),
  },
  {
    title: "Nissan Qashqai",
    subtitle:
      "Con nueva parrilla, la Nissan Qashqai nos sorprende con sus cambios en tecnología y seguridad.",
    video: "/img/videos-pruebas/nissan qashqai.mp4",
    fecha: "Publicado: 08/08/2025",
    source_scope: "internacional",
    sortDate: new Date("2025-08-08").getTime(),
  },
  {
    title: "Mazda Iconic",
    subtitle:
      "El diseño de este Mazda Iconic es muy moderno y elegante, destaca por sus líneas deportivas y detalles innovadores.",
    video: "/img/videos-pruebas/prueba-mazda.mp4",
    fecha: "Publicado: 07/08/2025",
    source_scope: "internacional",
    sortDate: new Date("2025-08-07").getTime(),
  },
  {
    title: "DFSK E5",
    subtitle:
      "La SUV eléctrica para 7 pasajeros, confortable y espaciosa, nos sorprendió mucho y seguro que a ustedes también les gustará.",
    video: "/img/videos-pruebas/video-dfsk.mp4",
    fecha: "Publicado: 06/08/2025",
    source_scope: "nacional",
    sortDate: new Date("2025-08-06").getTime(),
  },
  {
    title: "Kia K4 X-Line",
    subtitle:
      "La marca no quiere dejar los automóviles, por eso nos presenta el K4 Xline: deportivo, seguro y muy confortable.",
    video: "/img/videos-pruebas/video-kia-k4.mp4",
    fecha: "Publicado: 05/08/2025",
    source_scope: "nacional",
    sortDate: new Date("2025-08-05").getTime(),
  },
  {
    title: "Zeekr 007 GT",
    subtitle:
      "El ZEEKR 007 GT fue lanzado en China en abril del 2025 y a Europa llegará como 007 GT.",
    video: "/img/videos-pruebas/video-zeekr.mp4",
    fecha: "Publicado: 04/08/2025",
    source_scope: "internacional",
    sortDate: new Date("2025-08-04").getTime(),
  },
];

let dynamicPruebas: PruebaItem[] = [];

try {
  const apiUrl = getApiUrl("get-notes");
  const data = await fetchWithTimeout(apiUrl);

  if (data && Array.isArray(data)) {
    dynamicPruebas = data
      .filter((note: any) => note.category?.toLowerCase() === "pruebas")
      .map((note: any) => ({
        title: note.title || "Sin título",
        subtitle: note.subtitle || "",
        editor: note.editor || "Jhon Aparicio",
        video: note.video1?.trim() || undefined,
        image: note.image1?.trim() || undefined,
        href: `/notas/${note.id}`,
        fecha: note.created_at
          ? `Publicado: ${new Date(note.created_at).toLocaleDateString("es-CO")}`
          : "",
        source_scope: normalizeSourceScope(note.source_scope),
        sortDate: note.created_at ? new Date(note.created_at).getTime() : 0,
      }));
  }
} catch (err) {
  console.error("Error cargando pruebas dinámicas:", err);
}

const HOME_VISIBLE_COUNT = staticPruebas.length;
const ITEMS_PER_PAGE = 8;

const allPruebas = [...dynamicPruebas, ...staticPruebas].sort(
  (a, b) => b.sortDate - a.sortDate,
);

const archivePruebas = allPruebas.slice(HOME_VISIBLE_COUNT);

const totalPages = Math.max(
  1,
  Math.ceil(archivePruebas.length / ITEMS_PER_PAGE),
);
const requestedPage = Number(Astro.url.searchParams.get("page") || "1");
const currentPage =
  Number.isFinite(requestedPage) && requestedPage > 0
    ? Math.min(requestedPage, totalPages)
    : 1;

const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
const paginatedPruebas = archivePruebas.slice(
  startIndex,
  startIndex + ITEMS_PER_PAGE,
);

function pageHref(page: number) {
  return page <= 1 ? "?" : `?page=${page}`;
}
---

<Layout
  title="Videos de Pruebas de Manejo | Auto-Tech-Digital"
  description="Mira los mejores videos de pruebas de manejo de autos eléctricos, híbridos y de alto rendimiento en Colombia. Opiniones honestas y análisis en detalle."
>
  <link rel="stylesheet" href="/css/pruebas.css" />

  <div class="pruebas-archivo-page">
  <section
    class="pruebas-archivo"
    data-pruebas-channel
    aria-labelledby="archivo-pruebas-title"
  >
    <header class="pruebas-head">
      <p class="pruebas-eyebrow">Archivo</p>
      <h1 id="archivo-pruebas-title" class="pruebas-title">Más videos de pruebas</h1>
      <p class="pruebas-lead">
        Test drives y análisis en video que ya salieron de la portada principal.
      </p>
    </header>

    {
      archivePruebas.length === 0 && allPruebas.length > 0 && (
        <p class="archivo-empty">
          Los videos más recientes están en la página principal. Aquí verás los
          anteriores a medida que publiques nuevos.
        </p>
      )
    }

    {
      allPruebas.length === 0 && (
        <p class="archivo-empty">Aún no hay videos de pruebas disponibles.</p>
      )
    }

    {
      paginatedPruebas.length > 0 && (
        <div class="pruebas-rail-wrap pruebas-rail-wrap--archivo">
          <div class="pruebas-rail-toolbar">
            <h2 class="pruebas-rail-title">Episodios del archivo</h2>
            <div class="pruebas-rail-controls">
              <span class="pruebas-rail-counter" data-rail-counter aria-live="polite">
                1 / {paginatedPruebas.length}
              </span>
              <div class="pruebas-rail-nav" aria-label="Navegación del carril">
                <button
                  type="button"
                  class="pruebas-rail-btn prev"
                  aria-label="Episodio anterior"
                >
                  <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
                </button>
                <button
                  type="button"
                  class="pruebas-rail-btn next"
                  aria-label="Siguiente episodio"
                >
                  <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
                </button>
              </div>
            </div>
          </div>

          <div class="pruebas-rail-viewport">
            <div class="pruebas-rail" data-pruebas-rail tabindex="0" aria-label="Archivo de videos">
              {paginatedPruebas.map((item, index) => (
                <article class="prueba-rail-card">
                  <div class="prueba-rail-card__media" data-video-card>
                    {item.video ? (
                      <>
                        <video playsinline preload="metadata">
                          <source src={item.video} type="video/mp4" />
                          Tu navegador no soporta videos HTML5.
                        </video>
                        <button
                          type="button"
                          class="prueba-play"
                          aria-label={`Reproducir video de ${item.title}`}
                        />
                      </>
                    ) : item.image ? (
                      <img
                        src={item.image}
                        alt={item.title}
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="archivo-placeholder">Sin media</div>
                    )}
                  </div>
                  <div class="prueba-rail-card__body">
                    <span class={sourceScopeClass(item.source_scope)}>
                      {sourceScopeLabel(item.source_scope)}
                    </span>
                    <h4>{item.title}</h4>
                    <p class="archivo-meta">
                      <i class="fa-regular fa-user" aria-hidden="true" />
                      <span>{item.editor || "Jhon Aparicio"}</span>
                      <span class="meta-sep">•</span>
                      <i class="fa-regular fa-calendar" aria-hidden="true" />
                      <span>{cleanPublishedDate(item.fecha)}</span>
                    </p>
                    {item.subtitle && (
                      <p class="prueba-rail-desc">{item.subtitle}</p>
                    )}
                    <div class="prueba-rail-actions">
                      {item.href && (
                        <a href={item.href} class="archivo-link">
                          Ver nota
                        </a>
                      )}
                      <a href="/automatch-find" class="prueba-rail-automatch">
                        Comparar en AutoMatch
                      </a>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      )
    }

    {
      totalPages > 1 && (
        <div class="archivo-pagination">
          <a
            href={pageHref(currentPage - 1)}
            class={`archivo-page-btn ${currentPage === 1 ? "is-disabled" : ""}`}
            aria-disabled={currentPage === 1}
          >
            ← Anterior
          </a>

          <span class="archivo-page-indicator">
            Página {currentPage} de {totalPages}
          </span>

          <a
            href={pageHref(currentPage + 1)}
            class={`archivo-page-btn ${currentPage === totalPages ? "is-disabled" : ""}`}
            aria-disabled={currentPage === totalPages}
          >
            Siguiente →
          </a>
        </div>
      )
    }
  </section>
  </div>

  <script type="module" src="/js/pruebas-channel.js"></script>
</Layout>

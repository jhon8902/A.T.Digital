---
import { resolveSiteNotes, type SiteNote } from "../../lib/api";
import {
  formatNotePublishedLabel,
  getNotePublishTimestamp,
} from "../../lib/note-scheduling";

type DeporteItem = {
  href: string;
  img: string;
  alt: string;
  title: string;
  description: string;
  fecha?: string;
  editor?: string;
  source_scope?: string;
  chips?: string[];
  sortDate: number;
};

interface Props {
  compact?: boolean;
  notes?: SiteNote[];
}

const { compact = false, notes: prefetchedNotes } = Astro.props as Props;
const HOME_VISIBLE_COUNT = compact ? 2 : 3;

function normalizeSourceScope(scope?: string) {
  return scope?.toLowerCase() === "internacional"
    ? "internacional"
    : "nacional";
}

function sourceScopeLabel(scope?: string) {
  return normalizeSourceScope(scope) === "internacional"
    ? "Internacional"
    : "Nacional";
}

function cleanPublishedDate(value?: string) {
  const cleaned = (value || "").replace(/^Publicado:\s*/i, "").trim();
  if (!cleaned) return "";
  if (/\d{4}/.test(cleaned)) return cleaned;
  if (/^\d{1,2}-[a-záéíóúüñ]+$/i.test(cleaned)) return `${cleaned}-2025`;
  return cleaned;
}

const MESES_ES: Record<string, string> = {
  ene: "01",
  enero: "01",
  feb: "02",
  febrero: "02",
  mar: "03",
  marzo: "03",
  abr: "04",
  abril: "04",
  may: "05",
  mayo: "05",
  jun: "06",
  junio: "06",
  jul: "07",
  julio: "07",
  ago: "08",
  agosto: "08",
  sep: "09",
  sept: "09",
  septiembre: "09",
  oct: "10",
  octubre: "10",
  nov: "11",
  noviembre: "11",
  dic: "12",
  diciembre: "12",
};

function parseDateValue(value?: string) {
  const cleaned = (value || "").replace(/^Publicado:\s*/i, "").trim();
  if (!cleaned) return 0;

  const direct = new Date(cleaned);
  if (!isNaN(direct.getTime())) return direct.getTime();

  const ddmmyyyy = cleaned.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (ddmmyyyy) {
    const [, dd, mm, yyyy] = ddmmyyyy;
    return new Date(`${yyyy}-${mm}-${dd}`).getTime();
  }

  const ddMonth = cleaned.match(/^(\d{1,2})-([a-záéíóúüñ]+)$/i);
  if (ddMonth) {
    const [, dd, monthStr] = ddMonth;
    const mm = MESES_ES[monthStr.toLowerCase()];
    if (mm) return new Date(`2025-${mm}-${dd.padStart(2, "0")}`).getTime();
  }

  return 0;
}

function extractFirstImage(html: string | undefined) {
  if (!html) return null;
  const match = html.match(/<img[^>]+src=["']([^"']+)["'][^>]*>/i);
  return match ? match[1] : null;
}

function buildChips(item: { description?: string; chips?: string[] }) {
  if (item.chips?.length) return item.chips.slice(0, 3);

  const chips: string[] = [];
  const text = (item.description || "").toLowerCase();

  if (/f1|fórmula|formula/i.test(text)) chips.push("F1");
  if (/moto/i.test(text)) chips.push("Motociclismo");
  if (/automovilismo|pista|carrera/i.test(text)) chips.push("Automovilismo");
  if (/alto rendimiento|competición|competicion/i.test(text))
    chips.push("Alto rendimiento");
  if (/tecnolog/i.test(text)) chips.push("Tecnología");

  if (chips.length === 0) chips.push("Deportes motor");
  return chips.slice(0, 3);
}

const staticDeportes: DeporteItem[] = [
  {
    href: "/notas-deportes/nota-deportes-motos",
    img: "/img/img-deportes/deportes-motos-portada1.jpg",
    alt: "Deportes motorizados",
    title: "Adrenalina sobre ruedas",
    description:
      "Cobertura de motociclismo y automovilismo de alto nivel en pista y calle.",
    fecha: "Publicado: 12-mar",
    editor: "Jhon Aparicio",
    source_scope: "nacional",
    chips: ["Motociclismo", "Automovilismo", "Pista"],
    sortDate: parseDateValue("Publicado: 12-mar"),
  },
  {
    href: "/notas-deportes/nota-deportes1",
    img: "/img/img-deportes/subportada-deporte.webp",
    alt: "Máquinas de alto rendimiento",
    title: "Máquinas de alto rendimiento",
    description:
      "Ingeniería extrema aplicada a la velocidad, la pista y la competición.",
    fecha: "Publicado: 13-mar",
    editor: "Jhon Aparicio",
    source_scope: "nacional",
    chips: ["Alto rendimiento", "Pista", "Ingeniería"],
    sortDate: parseDateValue("Publicado: 13-mar"),
  },
  {
    href: "/notas-deportes/nota-deportes2",
    img: "/img/img-deportes/deporte-2.webp",
    alt: "Tecnología en deportes",
    title: "Tecnología de última generación",
    description:
      "Materiales, telemetría y evolución técnica en el automovilismo moderno.",
    fecha: "Publicado: 15-mar",
    editor: "Jhon Aparicio",
    source_scope: "nacional",
    chips: ["Tecnología", "Telemetría", "Competición"],
    sortDate: parseDateValue("Publicado: 15-mar"),
  },
];

let dynamicDeportes: DeporteItem[] = [];

try {
  const data = await resolveSiteNotes(prefetchedNotes);

  if (data.length > 0) {
    dynamicDeportes = data
      .filter((note: any) => note.category?.toLowerCase() === "deportes")
      .map((note: any) => ({
        href: `/notas/${note.id}`,
        img:
          note.image1?.trim() ||
          extractFirstImage(note.content) ||
          "/img/default.jpg",
        alt: note.title || "Deportes",
        title: note.title || "Sin título",
        description: note.subtitle || "",
        fecha: formatNotePublishedLabel(note),
        editor: note.editor || "Jhon Aparicio",
        source_scope: normalizeSourceScope(note.source_scope),
        sortDate: getNotePublishTimestamp(note),
      }));
  }
} catch (err) {
  console.error("Error cargando deportes dinámicos:", err);
}

function slugTitle(t?: string) {
  return (t || "")
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]/g, "");
}

const dynamicDeportesTitles = new Set(
  dynamicDeportes.map((n) => slugTitle(n.title)),
);

const deduplicatedStaticDeportes = staticDeportes.filter(
  (n) => !dynamicDeportesTitles.has(slugTitle(n.title)),
);

const allDeportes = [...dynamicDeportes, ...deduplicatedStaticDeportes]
  .sort((a, b) => b.sortDate - a.sortDate)
  .slice(0, HOME_VISIBLE_COUNT);
---

<link rel="stylesheet" href="/css/deportes-section.css" />

<section
  id="deportes"
  class="deportes-section"
  aria-labelledby="deportes-heading"
>
  <div class="deportes-inner">
    <header class="deportes-head">
      <p class="deportes-eyebrow">
        {compact ? "Más del portal" : "Alto rendimiento"}
      </p>
      <h2 id="deportes-heading" class="deportes-title">
        {compact ? "Deportes motor" : "Adrenalina sobre ruedas"}
      </h2>
      <p class="deportes-lead">
        Automovilismo, motociclismo y competición: lo más reciente del mundo
        deportivo sobre ruedas.
      </p>
    </header>

    {
      allDeportes.length > 0 && (
        <div
          class:list={[
            "deportes-grid",
            !compact && allDeportes.length >= 3 && "deportes-grid--solo",
          ]}
        >
          {allDeportes.map((nota) => {
            const chips = buildChips(nota);
            const scope = normalizeSourceScope(nota.source_scope);
            const fecha = cleanPublishedDate(nota.fecha);

            return (
              <article class="deporte-card">
                <a href={nota.href} class="deporte-card__media">
                  <img
                    src={nota.img}
                    alt={nota.alt}
                    loading="lazy"
                    decoding="async"
                  />
                </a>
                <div class="deporte-card__body">
                  <div class="deporte-card__meta">
                    <span class={`deporte-scope deporte-scope--${scope}`}>
                      {sourceScopeLabel(nota.source_scope)}
                    </span>
                    {fecha && (
                      <span class="deporte-card__date">{fecha}</span>
                    )}
                  </div>
                  <h3>
                    <a href={nota.href}>{nota.title}</a>
                  </h3>
                  <div class="deporte-chips">
                    {chips.map((chip) => (
                      <span class="deporte-chip">{chip}</span>
                    ))}
                  </div>
                  <p class="deporte-desc">{nota.description}</p>
                  <div class="deporte-card__actions">
                    <a href={nota.href} class="deporte-card__cta">
                      Ver nota
                    </a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      )
    }

    <footer class="deportes-footer">
      <a href="/deportes" class="deportes-more">
        Ver más deportes
        <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
      </a>
    </footer>
  </div>
</section>

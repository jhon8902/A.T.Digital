---
import { getApiUrl, fetchWithTimeout } from "../../lib/api";

type DeporteItem = {
  href: string;
  img: string;
  alt: string;
  title: string;
  description: string;
  fecha?: string;
  editor?: string;
  source_scope?: string;
  sortDate: number;
};

const HOME_VISIBLE_COUNT = 3;

function normalizeSourceScope(scope?: string) {
  return scope?.toLowerCase() === "internacional"
    ? "internacional"
    : "nacional";
}

function sourceScopeLabel(scope?: string) {
  return normalizeSourceScope(scope) === "internacional"
    ? "Internacional"
    : "Nacional";
}

function cleanPublishedDate(value?: string) {
  const cleaned = (value || "").replace(/^Publicado:\s*/i, "").trim();
  if (!cleaned) return "";
  if (/\d{4}/.test(cleaned)) return cleaned;
  if (/^\d{1,2}-[a-záéíóúüñ]+$/i.test(cleaned)) return `${cleaned}-2025`;
  return cleaned;
}

const MESES_ES: Record<string, string> = {
  ene: "01",
  enero: "01",
  feb: "02",
  febrero: "02",
  mar: "03",
  marzo: "03",
  abr: "04",
  abril: "04",
  may: "05",
  mayo: "05",
  jun: "06",
  junio: "06",
  jul: "07",
  julio: "07",
  ago: "08",
  agosto: "08",
  sep: "09",
  sept: "09",
  septiembre: "09",
  oct: "10",
  octubre: "10",
  nov: "11",
  noviembre: "11",
  dic: "12",
  diciembre: "12",
};

function parseDateValue(value?: string) {
  const cleaned = (value || "").replace(/^Publicado:\s*/i, "").trim();

  if (!cleaned) return 0;

  const direct = new Date(cleaned);
  if (!isNaN(direct.getTime())) return direct.getTime();

  const ddmmyyyy = cleaned.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (ddmmyyyy) {
    const [, dd, mm, yyyy] = ddmmyyyy;
    return new Date(`${yyyy}-${mm}-${dd}`).getTime();
  }

  const ddMonth = cleaned.match(/^(\d{1,2})-([a-záéíóúüñ]+)$/i);
  if (ddMonth) {
    const [, dd, monthStr] = ddMonth;
    const mm = MESES_ES[monthStr.toLowerCase()];
    if (mm) {
      return new Date(`2025-${mm}-${dd.padStart(2, "0")}`).getTime();
    }
  }

  return 0;
}

function extractFirstImage(html: string | undefined) {
  if (!html) return null;
  const match = html.match(/<img[^>]+src=["']([^"']+)["'][^>]*>/i);
  return match ? match[1] : null;
}

const staticDeportes: DeporteItem[] = [
  {
    href: "/notas-deportes/nota-deportes-motos",
    img: "/img/img-deportes/deportes-motos-portada1.jpg",
    alt: "Deportes motorizados",
    title: "Adrenalina sobre ruedas",
    description: "Cobertura de motociclismo y automovilismo de alto nivel.",
    fecha: "Publicado: 12-mar",
    editor: "Jhon Aparicio",
    source_scope: "nacional",
    sortDate: parseDateValue("Publicado: 12-mar"),
  },
  {
    href: "/notas-deportes/nota-deportes1",
    img: "/img/img-deportes/subportada-deporte.webp",
    alt: "Máquinas de alto rendimiento",
    title: "Máquinas de alto rendimiento",
    description: "Ingeniería extrema aplicada a la velocidad y la pista.",
    fecha: "Publicado: 13-mar",
    editor: "Jhon Aparicio",
    source_scope: "nacional",
    sortDate: parseDateValue("Publicado: 13-mar"),
  },
  {
    href: "/notas-deportes/nota-deportes2",
    img: "/img/img-deportes/deporte-2.webp",
    alt: "Tecnología en deportes",
    title: "Tecnología de última generación",
    description: "Materiales, telemetría y evolución técnica en competencia.",
    fecha: "Publicado: 15-mar",
    editor: "Jhon Aparicio",
    source_scope: "nacional",
    sortDate: parseDateValue("Publicado: 15-mar"),
  },
];

let dynamicDeportes: DeporteItem[] = [];

try {
  const apiUrl = getApiUrl("get-notes");
  const data = await fetchWithTimeout(apiUrl);

  if (data && Array.isArray(data)) {
    dynamicDeportes = data
      .filter((note: any) => note.category?.toLowerCase() === "deportes")
      .map((note: any) => ({
        href: `/notas/${note.id}`,
        img:
          note.image1?.trim() ||
          extractFirstImage(note.content) ||
          "/img/default.jpg",
        alt: note.title || "Deportes",
        title: note.title || "Sin título",
        description: note.subtitle || "",
        fecha: note.created_at
          ? `Publicado: ${new Date(note.created_at).toLocaleDateString("es-CO")}`
          : "",
        editor: note.editor || "Jhon Aparicio",
        source_scope: normalizeSourceScope(note.source_scope),
        sortDate: note.created_at ? new Date(note.created_at).getTime() : 0,
      }));
  }
} catch (err) {
  console.error("Error cargando deportes dinámicos:", err);
}

function slugTitle(t?: string) {
  return (t || "")
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]/g, "");
}
const dynamicDeportesTitles = new Set(
  dynamicDeportes.map((n) => slugTitle(n.title)),
);
const deduplicatedStaticDeportes = staticDeportes.filter(
  (n) => !dynamicDeportesTitles.has(slugTitle(n.title)),
);
const allDeportes = [...dynamicDeportes, ...deduplicatedStaticDeportes]
  .sort((a, b) => b.sortDate - a.sortDate)
  .slice(0, HOME_VISIBLE_COUNT);

const destacada = allDeportes[0];
const restoDeportes = allDeportes.slice(1);
---

<section id="deportes" class="nota-container">
  <div class="nota-header">
    <div class="icono-titulo">
      <i class="fa-sharp-duotone fa-solid fa-trophy"></i>
    </div>
    <h1>Adrenalina Sobre Ruedas</h1>
    <p class="subtitulo">
      Descubre lo mejor del automovilismo y motociclismo mundial
    </p>
  </div>

  <section class="highlight-wrapper">
    <!-- IZQUIERDA -->
    <section class="highlight-banner">
      <a href={destacada?.href || "/deportes"} class="highlight-note-link">
        <img
          src={destacada?.img ||
            "/img/img-deportes/deportes-motos-portada1.jpg"}
          alt={destacada?.alt || "Competencia de autos y motos"}
          loading="lazy"
          decoding="async"
        />
        <div class="highlight-text">
          <div class="texto-fecha texto-fecha--highlight">
            <p>
              <i class="fa-regular fa-user" aria-hidden="true"></i>
              <span class="meta-author"
                >{destacada?.editor || "Jhon Aparicio"}</span
              >
              <span class="meta-sep">•</span>
              <i class="fa-regular fa-calendar" aria-hidden="true"></i>
              <span class="meta-date"
                >{cleanPublishedDate(destacada?.fecha)}</span
              >
            </p>
          </div>
          <span
            class={`ambito-deporte ambito-deporte--${normalizeSourceScope(destacada?.source_scope)} ambito-deporte--highlight`}
          >
            {sourceScopeLabel(destacada?.source_scope)}
          </span>
          <p>
            {
              destacada?.description ||
                "Descubre lo mejor del automovilismo y motociclismo mundial."
            }
          </p>
        </div>
      </a>
    </section>

    <!-- DERECHA -->
    <aside class="curiosidades">
      <h3 class="curiosidades-title">Datos curiosos</h3>
      <div class="curiosidad-item">
        <span class="icon">🏁</span>
        <p>
          Un auto de F1 puede acelerar de 0 a 100 km/h en menos de 2 segundos.
        </p>
      </div>

      <div class="curiosidad-item">
        <span class="icon">🔥</span>
        <p>
          Los frenos de competición alcanzan temperaturas superiores a 1.000 °C.
        </p>
      </div>

      <div class="curiosidad-item">
        <span class="icon">⚙️</span>
        <p>Un motor de alto rendimiento puede girar más de 15.000 RPM.</p>
      </div>
    </aside>
  </section>

  <section class="info-grid">
    {
      restoDeportes.map((nota) => (
        <div class="info-item">
          <a href={nota.href}>
            <img
              src={nota.img}
              alt={nota.alt}
              loading="lazy"
              decoding="async"
            />
            <div class="texto-fecha">
              <p>
                <i class="fa-regular fa-user" aria-hidden="true" />
                <span class="meta-author">
                  {nota.editor || "Jhon Aparicio"}
                </span>
                <span class="meta-sep">•</span>
                <i class="fa-regular fa-calendar" aria-hidden="true" />
                <span class="meta-date">{cleanPublishedDate(nota.fecha)}</span>
              </p>
            </div>
            <span
              class={`ambito-deporte ambito-deporte--${normalizeSourceScope(nota.source_scope)}`}
            >
              {sourceScopeLabel(nota.source_scope)}
            </span>
            <h3>{nota.title}</h3>
            <p>{nota.description}</p>
          </a>
        </div>
      ))
    }
    <div class="ver-mas-container">
      <a href="/deportes" class="ver-mas-boton">Ver mas </a>
    </div>
  </section>
</section>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .nota-container {
    width: 100%;
    overflow: hidden;

    background: rgb(248, 242, 219);
  }

  .nota-header {
    height: 280px;
    text-align: center;

    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .nota-header h1 {
    width: 100%;
    font-size: 34px;
    font-weight: 900;
    text-transform: uppercase;
    color: black;
    padding: 15px 30px;
    font-family: "Georgia", serif;
    letter-spacing: 1px;

    display: flex; /* 👈 clave */
    align-items: center;
    justify-content: center;
    gap: 30px;
  }

  /* Líneas */
  .nota-header h1::before,
  .nota-header h1::after {
    content: "";
    flex: 1;
    height: 2px;
    background-color: #e1a307;
    max-width: 650px;
  }

  /* Línea derecha */
  .nota-header h1::after {
    /* nada extra, solo existe para simetría */
  }

  .icono-titulo {
    color: #ebc460;
    font-size: 50px;
    background: #090808;
    padding: 10px 10px;
    border-radius: 50px;
  }

  .nota-header .subtitulo {
    font-size: 23px;
    padding-top: 0;
    font-weight: 500;
    color: black;
    font-family: "Roboto", Arial, sans-serif;
  }

  .highlight-wrapper {
    display: flex;
    align-items: stretch; /* 🔥 clave */
    width: 100%;
    background: #f7f2dc; /* mismo fondo que el resto */
  }

  .highlight-banner {
    width: 50%;
    display: flex;
    flex-direction: column;
  }

  .highlight-note-link {
    display: flex;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
    height: 100%;
  }

  .highlight-banner img {
    width: 100%;
    height: 600px;
    object-fit: cover;
    display: block;
  }

  .highlight-banner a {
    display: block;
    width: 100%;
    position: relative;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .highlight-banner a:hover img {
    transform: scale(1.02);
  }

  .highlight-text {
    width: 100%;
    padding: 28px 24px 34px;
    color: rgb(27, 27, 27);
    text-align: left;
    font-size: 30px;
    font-weight: 500;
    font-family: "Georgia", serif;
    background: linear-gradient(180deg, #fbf2cf 0%, #f7edd0 100%);
  }

  .highlight-text .texto-fecha--highlight {
    padding: 0;
    margin: 6px 0 14px;
  }

  .highlight-text .ambito-deporte--highlight {
    margin: 0 0 16px;
    align-self: flex-start;
  }

  .highlight-text p {
    font-size: 1.55rem;
    line-height: 1.55;
    color: #2c2c2c;
    margin: 0;
  }

  .curiosidades {
    width: 50%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 40px;
    padding: 80px;
    background: #ebc460;
  }
  .curiosidades-title {
    font-size: 30px;
    font-weight: 700;
    color: #222;
    margin-bottom: 20px;
    text-transform: uppercase;
    font-family: "Georgia", serif;
  }

  .curiosidad-item {
    display: flex;
    align-items: flex-start;
    gap: 20px;
  }

  .curiosidad-item .icon {
    font-size: 40px;
    line-height: 1;
  }

  .curiosidad-item p {
    font-size: 24px;
    color: #222;
    line-height: 1.4;
  }

  /* Grid de info */
  .info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    padding: 40px 20px;
    width: 100%;
    margin: 0;
  }

  .info-item {
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.08),
      rgba(255, 255, 255, 0.02)
    );
    padding: 0;
    text-align: start;
    font-family: "Georgia", serif;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .info-item:hover {
    transform: translateY(-8px);
    border-color: rgba(255, 255, 255, 0.6);
    box-shadow: 0 15px 40px rgba(134, 51, 51, 0.3);
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.12),
      rgba(255, 255, 255, 0.05)
    );
  }

  .info-item a {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .info-item img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: flex;
    margin-bottom: 14px;
  }

  .info-item h3 {
    margin-top: 0;
    font-size: 1.6rem;
    color: #000000;
    font-weight: 900;
    padding: 24px 20px 8px 20px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .info-item p {
    font-size: 1.5rem;
    padding: 0 20px 20px 20px;
    font-family: "Roboto", Arial, sans-serif;
    color: #393939;
    line-height: 1.6;
  }

  .info-item .texto-fecha {
    padding: 0 20px;
    background: transparent;
    font-weight: 500;
    margin: 6px 0 12px 0;
    display: block;
    border-radius: 0;
    text-transform: none;
    letter-spacing: 0;
    text-align: start;
    width: 100%;
  }

  .info-item .texto-fecha p {
    margin: 0;
    padding: 0;
    color: rgb(32, 32, 32);
    font-size: 0.9rem;
  }

  .ambito-deporte {
    display: inline-flex;
    width: fit-content;
    margin: 0 0 16px 20px;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    color: #ffffff;
  }

  .ambito-deporte--nacional {
    background: #1f6f43;
  }

  .ver-mas-container {
    width: 100%;
    display: flex;
    justify-content: flex-end;
    padding: 30px 48px 30px 20px;
    box-sizing: border-box;
  }

  .ver-mas-boton {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: #222;
    font-size: 15px;
    font-weight: 700;
    font-family: "Georgia", serif;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 0 0 3px;
    background: none;
    border: none;
    cursor: pointer;
    background-image: linear-gradient(currentColor, currentColor);
    background-repeat: no-repeat;
    background-size: 0% 1.5px;
    background-position: left bottom;
    transition: background-size 0.35s ease;
  }
  .ver-mas-boton::before {
    display: none;
  }
  .ver-mas-boton::after {
    content: " →";
    display: inline-block;
    margin-left: 8px;
    font-size: 14px;
    letter-spacing: 0;
    transition: transform 0.25s ease;
  }
  .ver-mas-boton:hover {
    background-size: 100% 1.5px;
  }
  .ver-mas-boton:hover::before {
    width: 56px;
  }
  .ver-mas-boton:hover::after {
    transform: translateX(6px);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .nota-header h1 {
      font-size: 48px;
    }

    .nota-header .subtitulo {
      font-size: 18px;
    }

    .highlight-text {
      font-size: 24px;
      padding: 24px 18px 28px;
    }

    .highlight-banner img {
      height: 500px;
    }
  }

  @media (max-width: 768px) {
    .nota-header {
      height: auto;
      padding: 30px 15px;
    }

    .nota-header h1 {
      font-size: 36px;
      padding: 10px 15px;
      margin-bottom: 10px;
    }

    .nota-header .subtitulo {
      font-size: 16px;
      padding: 8px 15px;
    }

    .highlight-wrapper {
      flex-direction: column;
    }

    .highlight-banner,
    .curiosidades {
      width: 100%;
    }

    .highlight-banner img {
      height: 400px;
    }

    .highlight-text {
      font-size: 20px;
      padding: 22px 15px 24px;
    }

    .highlight-text p {
      font-size: 1rem;
    }

    .curiosidades {
      padding: 40px 20px;
    }

    .curiosidades-title {
      font-size: 26px;
      text-align: center;
    }

    .curiosidad-item {
      gap: 15px;
    }

    .curiosidad-item p {
      font-size: 16px;
    }

    .info-grid {
      grid-template-columns: 1fr;
      padding: 30px 15px;
      gap: 15px;
    }

    .info-item h3 {
      font-size: 1.3rem;
      padding: 15px 15px 8px 15px;
    }

    .info-item p {
      font-size: 0.9rem;
      padding: 0 15px 15px 15px;
    }

    .info-item .texto-fecha {
      padding: 0 15px;
      margin: 6px 0 10px;
    }

    .ambito-deporte {
      margin-left: 15px;
      margin-bottom: 12px;
    }
  }

  @media (max-width: 480px) {
    .nota-header {
      padding: 25px 10px;
    }

    .nota-header h1 {
      font-size: 28px;
      padding: 10px;
      margin-bottom: 10px;
    }

    .nota-header .subtitulo {
      font-size: 14px;
      padding: 8px 10px;
    }

    .highlight-banner img {
      height: 300px;
    }

    .highlight-text {
      font-size: 18px;
      padding: 18px 12px 22px;
    }

    .highlight-text p {
      font-size: 0.95rem;
    }

    .curiosidades {
      padding: 30px 15px;
    }

    .curiosidades-title {
      font-size: 22px;
    }

    .curiosidad-item i {
      font-size: 22px;
    }

    .curiosidad-item p {
      font-size: 15px;
    }

    .info-grid {
      grid-template-columns: 1fr;
      padding: 20px 10px;
      gap: 12px;
    }

    .info-item h3 {
      font-size: 1.1rem;
      padding: 12px 12px 6px 12px;
    }

    .info-item p {
      font-size: 0.85rem;
      padding: 0 12px 12px 12px;
    }

    .info-item .texto-fecha {
      font-size: 0.75rem;
      margin: 6px 0 8px;
      padding: 0 12px;
    }

    .ambito-deporte {
      margin-left: 12px;
      margin-bottom: 10px;
    }

    .ver-mas-container {
      padding: 20px 16px;
      margin: 0;
      justify-content: center;
    }

    .ver-mas-boton {
      font-size: 12px;
    }
  }
</style>

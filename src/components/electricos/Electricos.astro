    }

    .imagenes-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .texto-destacado {
      text-align: left;
      padding: 10px 10px;
    }

    .texto-destacado h2 {
      font-size: 22px;
      border-bottom: 2px solid #6c9b61;
      padding-bottom: 10px;
      margin-bottom: 10px;
    }

    .texto-destacado p {

---
import { resolveSiteNotes, type SiteNote } from "../../lib/api";
import { normalizeNoteCategory } from "../../lib/notes-query";
import {
  formatNotePublishedLabel,
  getNotePublishTimestamp,
} from "../../lib/note-scheduling";
import { getNewsCardDeck, getNewsCardTitle } from "../../lib/editorial";
import { HOME_ELECTRICOS_CAROUSEL_LIMIT } from "../../lib/home-news-config";

interface Props {
  notes?: SiteNote[];
}

const { notes: prefetchedNotes } = Astro.props;

type ElectricoItem = {
  href: string;
  img: string;
  alt: string;
  title: string;
  description: string;
  fecha?: string;
  editor?: string;
  source_scope?: string;
  chips?: string[];
  sortDate: number;
};

let dynamicElectricos: ElectricoItem[] = [];

function normalizeSourceScope(scope?: string) {
  return scope?.toLowerCase() === "internacional"
    ? "internacional"
    : "nacional";
}

function sourceScopeLabel(scope?: string) {
  return normalizeSourceScope(scope) === "internacional"
    ? "Internacional"
    : "Nacional";
}

function cleanPublishedDate(value?: string) {
  const cleaned = (value || "").replace(/^Publicado:\s*/i, "").trim();
  if (!cleaned) return "";
  if (/\d{4}/.test(cleaned)) return cleaned;
  if (/^\d{1,2}-[a-záéíóúüñ]+$/i.test(cleaned)) return `${cleaned}-2025`;
  return cleaned;
}

const MESES_ES: Record<string, string> = {
  ene: "01",
  enero: "01",
  feb: "02",
  febrero: "02",
  mar: "03",
  marzo: "03",
  abr: "04",
  abril: "04",
  may: "05",
  mayo: "05",
  jun: "06",
  junio: "06",
  jul: "07",
  julio: "07",
  ago: "08",
  agosto: "08",
  sep: "09",
  sept: "09",
  septiembre: "09",
  oct: "10",
  octubre: "10",
  nov: "11",
  noviembre: "11",
  dic: "12",
  diciembre: "12",
};

function parseDateValue(value?: string) {
  const cleaned = (value || "").replace(/^Publicado:\s*/i, "").trim();
  if (!cleaned) return 0;

  const direct = new Date(cleaned);
  if (!isNaN(direct.getTime())) return direct.getTime();

  const ddmmyyyy = cleaned.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (ddmmyyyy) {
    const [, dd, mm, yyyy] = ddmmyyyy;
    return new Date(`${yyyy}-${mm}-${dd}`).getTime();
  }

  const ddMonth = cleaned.match(/^(\d{1,2})-([a-záéíóúüñ]+)$/i);
  if (ddMonth) {
    const [, dd, monthStr] = ddMonth;
    const mm = MESES_ES[monthStr.toLowerCase()];
    if (mm) return new Date(`2025-${mm}-${dd.padStart(2, "0")}`).getTime();
  }

  return 0;
}

function extractFirstImage(html?: string) {
  if (!html) return null;
  const match = html.match(/<img[^>]+src=["']([^"']+)["'][^>]*>/i);
  return match ? match[1] : null;
}

function normalizeImg(src: string) {
  return src
    .replace(/^\.\.\//, "/")
    .replace(/^img\//, "/img/")
    .replace(/^\/\//, "/");
}

function buildChips(item: { description?: string; chips?: string[] }) {
  if (item.chips?.length) return item.chips.slice(0, 3);

  const chips: string[] = [];
  const text = (item.description || "").toLowerCase();

  const km = text.match(/(\d{2,4})\s*km/);
  if (km) chips.push(`${km[1]} km autonomía`);

  if (/suv/i.test(text)) chips.push("SUV");
  if (/compacto/i.test(text)) chips.push("Compacto");
  if (/urbano|ciudad/i.test(text)) chips.push("Uso urbano");
  if (/premium|lujo/i.test(text)) chips.push("Premium");
  if (/deportivo/i.test(text)) chips.push("Deportivo");
  if (/carga/i.test(text)) chips.push("Carga rápida");

  if (chips.length === 0) chips.push("100% eléctrico");
  return chips.slice(0, 3);
}

try {
  const data = await resolveSiteNotes(prefetchedNotes);

  if (data.length > 0) {
    dynamicElectricos = data
      .filter((note) => normalizeNoteCategory(note.category) === "electricos")
      .map((note) => {
        const portada =
          note.image1?.trim() ||
          extractFirstImage(note.content) ||
          "/img/default.jpg";

        return {
          href: `/notas/${note.id}`,
          img: normalizeImg(portada),
          alt: note.title,
          title: note.title,
          description: getNewsCardDeck(note.title, note.subtitle),
          fecha: formatNotePublishedLabel(note),
          editor: note.editor || "Jhon Aparicio",
          source_scope: normalizeSourceScope(note.source_scope),
          sortDate: getNotePublishTimestamp(note),
        };
      });
  }
} catch (err) {
  console.error("Error cargando eléctricos dinámicos:", err);
}

const staticElectricos: Omit<ElectricoItem, "sortDate">[] = [
  {
    href: "/notas-electricos/nota-volvo-ex90",
    img: "/img/volvo-ex90-electrico/volvo-ex90-portada.webp",
    alt: "Volvo EX90",
    title: "Volvo EX90",
    description:
      "SUV eléctrico premium con autonomía de hasta 500 km, diseño vanguardista y uno de los más cotizados en Colombia.",
    fecha: "Publicado: 10-feb",
    source_scope: "nacional",
    chips: ["500 km", "SUV", "Premium"],
  },
  {
    href: "/notas-electricos/nota-mini-cooper",
    img: "/img/mini-cooper-electrico/mini-cooper-portada.webp",
    alt: "Mini Cooper",
    title: "Mini Cooper",
    description:
      "Compacto eléctrico con enfoque urbano: lujo, tecnología y confort en un tamaño ideal para la ciudad.",
    fecha: "Publicado: 13-mar",
    source_scope: "nacional",
    chips: ["Compacto", "Uso urbano", "Premium"],
  },
  {
    href: "/notas-electricos/nota-byd-sealion7",
    img: "/img/byd-sealion-7/byd-sealion7-principal.webp",
    alt: "BYD Sealion 7",
    title: "BYD Sealion 7",
    description:
      "SUV deportivo y sostenible que combina diseño, potencia y propuesta tecnológica para el mercado actual.",
    fecha: "Publicado: 13-mar",
    source_scope: "nacional",
    chips: ["SUV", "Deportivo", "AWD"],
  },
  {
    href: "/notas-electricos/nota-peugeot-e3008",
    img: "/img/peugeot-3008-electrica/carga-peugeot.webp",
    alt: "Peugeot E-3008",
    title: "Peugeot E-3008",
    description:
      "SUV eléctrico con diseño llamativo, buen rendimiento y carga rápida para uso diario y viajes.",
    fecha: "Publicado: 24-mar",
    source_scope: "nacional",
    chips: ["SUV", "Carga rápida", "Diseño"],
  },
  {
    href: "/notas-electricos/nota-renault-megane",
    img: "/img/renault-megane-e-tech/renault-megane-principal.webp",
    alt: "Renault Megane",
    title: "Renault Megane E-Tech",
    description:
      "Compacto eficiente para movilidad urbana con estética futurista y buen equilibrio entre autonomía y confort.",
    fecha: "Publicado: 20-abril",
    source_scope: "nacional",
    chips: ["Compacto", "E-Tech", "Uso urbano"],
  },
];

function slugTitle(t?: string) {
  return (t || "")
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]/g, "");
}

const staticElectricosWithDate: ElectricoItem[] = staticElectricos.map(
  (note) => ({
    ...note,
    img: normalizeImg(note.img),
    sortDate: parseDateValue(note.fecha),
  }),
);

const dynamicElectricosTitles = new Set(
  dynamicElectricos.map((n) => slugTitle(n.title)),
);

const deduplicatedStaticElectricos = staticElectricosWithDate.filter(
  (n) => !dynamicElectricosTitles.has(slugTitle(n.title)),
);

const allElectricos = [...dynamicElectricos, ...deduplicatedStaticElectricos]
  .sort((a, b) => b.sortDate - a.sortDate)
  .slice(0, HOME_ELECTRICOS_CAROUSEL_LIMIT);
---

<link rel="stylesheet" href="/css/electricos-section.css" />
<link rel="stylesheet" href="/css/news-interactive.css" />

<section
  id="electricos"
  class="electricos-section"
  aria-labelledby="electricos-heading"
>
  <div class="electricos-inner">
    <header class="electricos-head">
      <p class="electricos-eyebrow">Movilidad eléctrica</p>
      <h2 id="electricos-heading" class="electricos-title">Carros eléctricos</h2>
      <p class="electricos-lead">
        Modelos 100% eléctricos en Colombia: autonomía, carga y fichas para
        comparar con AutoMatch.
      </p>
    </header>

    {
      allElectricos.length > 0 && (
        <div class="news-carousel-wrap electricos-carousel" data-carousel-root>
          <div class="news-carousel-header">
            <h3 class="news-carousel-heading">Modelos destacados</h3>
            <div class="news-carousel-nav">
              <button
                type="button"
                class="news-carousel-btn news-carousel-btn--prev"
                aria-label="Modelo anterior"
              >
                <i class="fa-solid fa-chevron-left" aria-hidden="true" />
              </button>
              <button
                type="button"
                class="news-carousel-btn news-carousel-btn--next"
                aria-label="Modelo siguiente"
              >
                <i class="fa-solid fa-chevron-right" aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="news-carousel">
            {allElectricos.map((nota) => {
              const chips = buildChips(nota);
              const scope = normalizeSourceScope(nota.source_scope);
              const fecha = cleanPublishedDate(nota.fecha);

              return (
                <article class="news-carousel-card">
                  <a href={nota.href} class="news-carousel-card__link">
                    <div class="news-carousel-card__image">
                      <img
                        src={nota.img}
                        alt={nota.alt}
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                    <div class="news-carousel-card__body">
                      <div class="news-meta-tags">
                        <span class="news-tag">Eléctricos</span>
                        <span
                          class={
                            "scope-tag" +
                            (scope === "internacional"
                              ? " scope-tag--international"
                              : " scope-tag--national")
                          }
                        >
                          {sourceScopeLabel(nota.source_scope)}
                        </span>
                      </div>
                      <h4 class="news-carousel-card__title">
                        {getNewsCardTitle(nota.title)}
                      </h4>
                      {nota.description && (
                        <p class="news-carousel-card__deck">{nota.description}</p>
                      )}
                      <div class="electrico-chips electrico-chips--carousel">
                        {chips.map((chip) => (
                          <span class="electrico-chip">{chip}</span>
                        ))}
                      </div>
                      {fecha && (
                        <p class="news-date">
                          <i class="fa-regular fa-calendar" aria-hidden="true" />
                          <span>{fecha}</span>
                        </p>
                      )}
                    </div>
                  </a>
                </article>
              );
            })}
          </div>
        </div>
      )
    }

    <footer class="electricos-footer">
      <a href="/electricos" class="electricos-more">
        Ver más modelos
        <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
      </a>
    </footer>
  </div>
</section>

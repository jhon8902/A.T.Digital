    .imagen-destacada-img,
    .imagen-card-img-wrapper {
      width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
    }

    .titulo-electricos {
      font-size: 24px;
      padding: 5px;
    }

    .descripcion-electricos {
      width: 100%;
      padding: 0 15px; /* espacio lateral */
      margin: 5px 0; /* espacio arriba y abajo */
      font-size: 16px;

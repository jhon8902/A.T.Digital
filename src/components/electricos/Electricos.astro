  }

  .texto-destacado .texto-f {
    font-size: 14px;
    margin-top: 12px;
    margin-bottom: 15px;
    color: #666;
    border-bottom: none;
    width: auto;
    display: inline-flex;
    justify-content: flex-start;
    align-items: center;
    padding: 0;
    font-weight: 400;
    font-family: "Georgia", serif;
  }

  .scope-badge {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 10px;
    padding: 0;
    border-radius: 0;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.35px;
    color: #4b5563;
    background: transparent;
    border: none;
  }

  .scope-badge--nacional {
    color: #4b5563;
  }

  .scope-badge--internacional {
    color: #4b5563;
  }

  .imagen-destacada-img {
    flex: 1;
    min-width: 300px;
    max-height: 100%;
    overflow: hidden;
  }

  .imagen-destacada-img img,
  .imagen-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .nueva-destacada:hover .imagen-destacada-img img,
  .imagen-card:hover .imagen-card-img-wrapper img {
    transform: scale(1.1);
  }

  .imagenes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 10px;
    width: 100%;
    max-width: none;
    margin-top: 40px;

    padding: 20px; /* Elimina el padding lateral */
  }

  .imagen-card {

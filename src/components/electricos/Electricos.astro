    background-position: left bottom;
    transition: background-size 0.35s ease;
  }
  .ver-mas-modelos-btn::before {
    display: none;
  }
  .ver-mas-modelos-btn::after {
    content: " →";
    display: inline-block;
    margin-left: 8px;
    font-size: 14px;
    letter-spacing: 0;
    transition: transform 0.25s ease;
  }
  .ver-mas-modelos-btn:hover {
    background-size: 100% 1.5px;
  }
  .ver-mas-modelos-btn:hover::before {
    width: 56px;
  }
  .ver-mas-modelos-btn:hover::after {
    transform: translateX(6px);

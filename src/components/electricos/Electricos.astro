  .ver-mas-modelos-container {
    width: 100%;
    display: flex;
    justify-content: flex-end;
    padding: 30px 48px 30px 20px;
    box-sizing: border-box;
  }

  .ver-mas-modelos-btn {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: #6c9b61;
    font-size: 15px;
    font-weight: 700;
    font-family: "Georgia", serif;
    text-transform: uppercase;
    letter-spacing: 2px;

    }

    .imagen-card img {
      width: 100%;
      height: 250px;
    }

    .imagen-card h2,
    .imagen-card p,
    .imagen-card .texto-f,
    .imagen-card .scope-badge,
    .texto-destacado {
      padding-left: 16px;
      padding-right: 16px;
      box-sizing: border-box;
    }

    .imagen-card .scope-badge {
      margin-left: 16px;
      margin-right: 16px;
    }

    .imagen-card h2 {
      font-size: 18px;
      padding: 10px;
      padding-top: 10px;
      padding-bottom: 10px;
      font-weight: 600;
      border-bottom: 2px solid #6c9b61;
    }

    .imagen-card p {
      font-size: 16px;
      font-weight: 500;
      color: black;
      padding: 10px;
    }

    .imagen-card .texto-f {
      font-size: 12px;
      color: #666;
      padding: 0 10px;
      margin-top: 10px;
      margin-bottom: 10px;
      display: flex;
      justify-content: flex-start;
      text-align: left;
    }

    .imagen-card .scope-badge {
      display: flex;
      justify-content: flex-start;
      margin: 0 10px 10px;
    }

    .ver-mas-modelos-container {
      padding: 20px 16px;
      margin: 0;
      justify-content: center;
    }

    .ver-mas-modelos-btn {
      font-size: 12px;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const tituloElectricos = document.querySelector(
      ".electrico-container .central-content h2",
    ) as HTMLElement;

    if (!tituloElectricos) return;

    const observerElectricos = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            tituloElectricos.classList.add("animate-title");
            tituloElectricos.style.opacity = "1";
          } else {
            tituloElectricos.classList.remove("animate-title");
            tituloElectricos.style.opacity = "0";
          }
        });
      },
      { threshold: 0.5 },
    );

    observerElectricos.observe(tituloElectricos);
  });
</script>

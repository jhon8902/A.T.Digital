    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .imagen-card h2 {
    font-size: 22px;
    font-weight: 600;
    color: black;
    border-bottom: 2px solid #6c9b61;
    padding: 20px;
    padding-bottom: 10px;
    text-align: start;
    position: relative;
    display: block;

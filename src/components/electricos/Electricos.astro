---
import { getApiUrl, fetchWithTimeout } from "../../lib/api";

let dynamicElectricos: any[] = [];
const HOME_VISIBLE_COUNT = 5;

function normalizeSourceScope(scope?: string) {
  return scope?.toLowerCase() === "internacional"
    ? "internacional"
    : "nacional";
}

function sourceScopeLabel(scope?: string) {
  return normalizeSourceScope(scope) === "internacional"
    ? "Internacional"
    : "Nacional";
}

function cleanPublishedDate(value?: string) {
  const cleaned = (value || "").replace(/^Publicado:\s*/i, "").trim();
  if (!cleaned) return "";
  if (/\d{4}/.test(cleaned)) return cleaned;
  if (/^\d{1,2}-[a-záéíóúüñ]+$/i.test(cleaned)) return `${cleaned}-2025`;
  return cleaned;
}

const MESES_ES: Record<string, string> = {
  ene: "01",
  enero: "01",
  feb: "02",
  febrero: "02",
  mar: "03",
  marzo: "03",
  abr: "04",
  abril: "04",
  may: "05",
  mayo: "05",
  jun: "06",
  junio: "06",
  jul: "07",
  julio: "07",
  ago: "08",
  agosto: "08",
  sep: "09",
  sept: "09",
  septiembre: "09",
  oct: "10",
  octubre: "10",
  nov: "11",
  noviembre: "11",
  dic: "12",
  diciembre: "12",
};

function parseDateValue(value?: string) {
  const cleaned = (value || "").replace(/^Publicado:\s*/i, "").trim();

  if (!cleaned) return 0;

  const direct = new Date(cleaned);
  if (!isNaN(direct.getTime())) return direct.getTime();

  const ddmmyyyy = cleaned.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (ddmmyyyy) {
    const [, dd, mm, yyyy] = ddmmyyyy;
    return new Date(`${yyyy}-${mm}-${dd}`).getTime();
  }

  const ddMonth = cleaned.match(/^(\d{1,2})-([a-záéíóúüñ]+)$/i);
  if (ddMonth) {
    const [, dd, monthStr] = ddMonth;
    const mm = MESES_ES[monthStr.toLowerCase()];
    if (mm) {
      return new Date(`2025-${mm}-${dd.padStart(2, "0")}`).getTime();
    }
  }

  return 0;
}

// ✅ Función para extraer la primera imagen del HTML (para portada si no hay image1)
function extractFirstImage(html?: string) {
  if (!html) return null;
  const match = html.match(/<img[^>]+src=["']([^"']+)["'][^>]*>/i);
  return match ? match[1] : null;
}

try {
  const apiUrl = getApiUrl("get-notes");
  const data = await fetchWithTimeout(apiUrl);

  if (data && Array.isArray(data)) {
    // ✅ Filtramos solo categoría "electricos"
    dynamicElectricos = data
      .filter((note) => note.category?.toLowerCase() === "electricos")
      .map((note) => {
        // 🔹 Si tiene image1, usamos esa
        // 🔹 Si no, usamos la primera imagen del contenido HTML
        // 🔹 Si no hay ninguna, ponemos una por defecto
        const portada =
          note.image1?.trim() ||
          extractFirstImage(note.content) ||
          "/img/default.jpg";

        return {
          href: `/notas/${note.id}`,
          img: portada,
          alt: note.title,
          title: note.title,
          description: note.subtitle || "",
          fecha: note.created_at
            ? `Publicado: ${new Date(note.created_at).toLocaleDateString("es-CO")}`
            : "",
          editor: note.editor || "Jhon Aparicio",
          source_scope: normalizeSourceScope(note.source_scope),
          sortDate: note.created_at ? new Date(note.created_at).getTime() : 0,
        };
      });
  }
} catch (err) {
  console.error("Error cargando eléctricos dinámicos:", err);
}

// ✅ Notas estáticas (puedes dejar tus objetos como estaban)
const staticElectricos = [
  {
    href: "/notas-electricos/nota-volvo-ex90",
    img: "../img/volvo-ex90-electrico/volvo-ex90-portada.webp",
    alt: "Volvo EX90",
    title: "Volvo EX90",
    description:
      "No solo ofrece una autonomía de 500km sino que además llega con nuevo diseño vanguardista, es una de las más cotizadas en Colombia.",
    fecha: "Publicado: 10-feb",
    source_scope: "nacional",
  },
  {
    href: "/notas-electricos/nota-mini-cooper",
    img: "../img/mini-cooper-electrico/mini-cooper-portada.webp",
    alt: "Mini Cooper",
    title: "Mini Cooper",
    description:
      "Lujo y tecnología en un compacto eléctrico capaz de satisfacer todas tus necesidades básicas y de confort.",
    fecha: "Publicado: 13-mar",
    source_scope: "nacional",
  },
  {
    href: "/notas-electricos/nota-byd-sealion7",
    img: "/img/byd-sealion-7/byd-sealion7-principal.webp",
    alt: "BYD Sealion 7",
    title: "BYD Sealion 7",
    description:
      "Deportivo y sostenible sin perder su esencia, el diseño y lujo se combinan para ofrecer lo mejor.",
    fecha: "Publicado: 13-mar",
    source_scope: "nacional",
  },
  {
    href: "/notas-electricos/nota-peugeot-e3008",
    img: "/img/peugeot-3008-electrica/carga-peugeot.webp",
    alt: "Peugeot E-3008",
    title: "Peugeot E-3008",
    description:
      "Eléctrico y potente para la nueva era: si lo que quieres es que te vean, con este SUV lo logras.",
    fecha: "Publicado: 24-mar",
    source_scope: "nacional",
  },
  {
    href: "/notas-electricos/nota-renault-megane",
    img: "/img/renault-megane-e-tech/renault-megane-principal.webp",
    alt: "Renault Megane",
    title: "Renault Megane",
    description:
      "Compacto y eficiente para la movilidad urbana, además de futurista que compensa cualquier pero.",
    fecha: "Publicado: 20-abril",
    source_scope: "nacional",
  },
];

// ✅ Juntamos dinámicas + estáticas (las 5 primeras)
const staticElectricosWithDate = staticElectricos.map((note) => ({
  ...note,
  sortDate: parseDateValue(note.fecha),
}));

function slugTitle(t?: string) {
  return (t || "")
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]/g, "");
}
const dynamicElectricosTitles = new Set(
  dynamicElectricos.map((n) => slugTitle(n.title)),
);
const deduplicatedStaticElectricos = staticElectricosWithDate.filter(
  (n) => !dynamicElectricosTitles.has(slugTitle(n.title)),
);
const allElectricos = [...dynamicElectricos, ...deduplicatedStaticElectricos]
  .sort((a, b) => b.sortDate - a.sortDate)
  .slice(0, HOME_VISIBLE_COUNT);
---

<div id="electricos" class="electrico-container">
  <div class="central-content">
    <span class="icono-electricos">
      <i class="fas fa-car-battery"></i>
    </span>

    <h2>Carros Eléctricos</h2>
  </div>
  <p class="descripcion-electricos">
    Modelos 100% eléctricos disponibles en el mercado nacional: autonomía,
    tiempos de carga, conectividad y más.
  </p>
</div>

<div class="grid-container">
  {
    allElectricos.length > 0 && (
      <div class="imagen-destacada nueva-destacada">
        <a href={allElectricos[0].href} class="destacada-link">
          <div class="imagen-destacada-img">
            <img
              src={allElectricos[0].img}
              alt={allElectricos[0].alt}
              class="electrico-imagen"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="texto-destacado">
            <h2>{allElectricos[0].title}</h2>
            <p class="texto-f">
              <i class="fa-regular fa-user" aria-hidden="true" />
              <span class="meta-author">
                {allElectricos[0].editor || "Jhon Aparicio"}
              </span>
              <span class="meta-sep">•</span>
              <i class="fa-regular fa-calendar" aria-hidden="true" />
              <span class="meta-date">
                {cleanPublishedDate(allElectricos[0].fecha)}
              </span>
            </p>
            <span
              class={
                "scope-badge " +
                (normalizeSourceScope(allElectricos[0].source_scope) ===
                "internacional"
                  ? "scope-badge--internacional"
                  : "scope-badge--nacional")
              }
            >
              {sourceScopeLabel(allElectricos[0].source_scope)}
            </span>
            <p>{allElectricos[0].description}</p>
          </div>
        </a>
      </div>
    )
  }
</div>

<div class="imagenes-grid">
  {
    allElectricos.slice(1).map((nota) => (
      <div class="imagen-card">
        <a href={nota.href}>
          <div class="imagen-card-img-wrapper">
            <img
              src={nota.img}
              alt={nota.alt}
              loading="lazy"
              decoding="async"
            />
          </div>
          <h2>{nota.title}</h2>
          <p class="texto-f">
            <i class="fa-regular fa-user" aria-hidden="true" />
            <span class="meta-author">{nota.editor || "Jhon Aparicio"}</span>
            <span class="meta-sep">•</span>
            <i class="fa-regular fa-calendar" aria-hidden="true" />
            <span class="meta-date">{cleanPublishedDate(nota.fecha)}</span>
          </p>
          <span
            class={
              "scope-badge " +
              (normalizeSourceScope(nota.source_scope) === "internacional"
                ? "scope-badge--internacional"
                : "scope-badge--nacional")
            }
          >
            {sourceScopeLabel(nota.source_scope)}
          </span>
          <p>{nota.description}</p>
        </a>
      </div>
    ))
  }
</div>

<div class="ver-mas-modelos-container">
  <a href="/electricos" class="ver-mas-modelos-btn">Ver más modelos</a>
</div>

<style>
  /* Contenedor principal */
  .electrico-container {
    display: flex;
    flex-direction: column;
    align-items: center;

    border-bottom: 20px solid rgb(250, 250, 250);

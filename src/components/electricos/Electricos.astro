  .imagen-card p {
    font-size: 20px;
    padding: 20px;
    padding-top: 10px;
    font-weight: 500;
    color: black;
    text-align: start;
    text-transform: none;
  }

  .imagen-card .texto-f {
    font-size: 14px;
    color: #666;
    position: static;
    top: auto;
    left: auto;
    padding: 0 20px;
    margin-top: 12px;
    margin-bottom: 10px;
    z-index: auto;
    text-align: left;
    text-transform: none;
    border-bottom: none;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    font-weight: 400;
    font-family: "Georgia", serif;
  }

  .imagen-card .scope-badge {
    display: flex;
    justify-content: flex-start;

    text-align: center;
    width: 100%;
    font-family: "Georgia", serif;
  }

  /* 🔥 ESTE ES EL CONTENEDOR QUE LIMITA TODO */
  .central-content {
    width: 100%;
    max-width: 1400px; /* ⬅️ AJUSTA AQUÍ EL ANCHO TOTAL */
    margin: 0 auto;
    padding: 20px 0 0 0;
  }

  /* Animaciones */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(0);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .central-content h2 {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    width: 100%;
    box-sizing: border-box;
    position: relative;

    font-size: clamp(40px, 5vw, 40px);
    font-weight: bolder;
    color: black;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-shadow: 2px 2px 6px rgba(16, 16, 16, 0.2);

    margin-top: 10px;

    opacity: 0;
    transform: translateY(0);
    transition: opacity 0.3s;
  }

  .central-content h2.animate-title {
    animation: fadeInUp 1s ease-out;
  }

  .central-content h2 {
    font-size: 32px;
  }

  /* 🔥 LÍNEAS (SIN LÍMITES) */

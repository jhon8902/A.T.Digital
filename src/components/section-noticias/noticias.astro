---
import { getApiUrl, fetchWithTimeout } from "../../lib/api";

let dynamicLanzamientos: any[] = [];
const HOME_VISIBLE_COUNT = 5;

function normalizeSourceScope(scope?: string) {
  return scope?.toLowerCase() === "internacional"
    ? "internacional"
    : "nacional";
}

function sourceScopeLabel(scope?: string) {
  return normalizeSourceScope(scope) === "internacional"
    ? "Internacional"
    : "Nacional";
}

function cleanPublishedDate(value?: string) {
  const cleaned = (value || "")
    .replace(/^Publicado:\s*/i, "")
    .replace(/^Nota:\s*/i, "")
    .trim();

  if (!cleaned) return "";
  if (/\d{4}/.test(cleaned)) return cleaned;
  if (/^\d{1,2}-[a-záéíóúüñ]+$/i.test(cleaned)) return `${cleaned}-2025`;
  return cleaned;
}

function parseDateValue(value?: string) {
  if (!value) return 0;

  const cleaned = value
    .replace(/^Publicado:\s*/i, "")
    .replace(/^Nota:\s*/i, "")
    .trim();

  const monthMap: Record<string, number> = {
    ene: 0,
    enero: 0,
    feb: 1,
    febrero: 1,
    mar: 2,
    marzo: 2,
    abr: 3,
    abril: 3,
    may: 4,
    mayo: 4,
    jun: 5,
    junio: 5,
    jul: 6,
    julio: 6,
    ago: 7,
    agosto: 7,
    sep: 8,
    septiembre: 8,
    oct: 9,
    octubre: 9,
    nov: 10,
    noviembre: 10,
    dic: 11,
    diciembre: 11,
  };

  const dayMonthMatch = cleaned.match(
    /^(\d{1,2})-([a-záéíóúüñ]+)(?:-(\d{4}))?$/i,
  );
  if (dayMonthMatch) {
    const [, dayRaw, monthRaw, yearRaw] = dayMonthMatch;
    const normalizedMonth = monthRaw
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "");
    const monthIndex = monthMap[normalizedMonth];
    if (Number.isInteger(monthIndex)) {
      const year = yearRaw ? Number(yearRaw) : 2025;
      return new Date(year, monthIndex, Number(dayRaw)).getTime();
    }
  }

  const direct = new Date(cleaned);
  if (!isNaN(direct.getTime())) return direct.getTime();

  const ddmmyyyy = cleaned.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (ddmmyyyy) {
    const [, dd, mm, yyyy] = ddmmyyyy;
    return new Date(`${yyyy}-${mm}-${dd}`).getTime();
  }

  return 0;
}

// Traemos notas dinámicas desde Netlify
try {
  const apiUrl = getApiUrl("get-notes");
  const data = await fetchWithTimeout(apiUrl);

  if (data && Array.isArray(data)) {
    // Filtramos solo las de categoría "lanzamientos"
    dynamicLanzamientos = data
      .filter((note: any) => note.category?.toLowerCase() === "lanzamientos")
      .map((note: any) => ({
        href: `/notas/${note.id}`,
        img: note.image1 || "/img/default.jpg",
        alt: note.title,
        title: note.title,
        description: note.subtitle || "",
        fecha: note.created_at
          ? `Publicado: ${new Date(note.created_at).toLocaleDateString("es-CO")}`
          : "",
        editor: note.editor || "Jhon Aparicio",
        source_scope: normalizeSourceScope(note.source_scope),
        sortDate: note.created_at ? new Date(note.created_at).getTime() : 0,
      }));
  }
} catch (err) {
  console.error("Error cargando lanzamientos dinámicos:", err);
}

// Notas estáticas originales
const staticLanzamientos = [
  {
    href: "./noticias-nacionales/noticia-jeep-avenger",
    img: "/img/jeep-avenger/jeep-avenger-portada.webp",
    alt: "JEEP AVENGER",
    title: "JEEP AVENGER",
    description:
      "¿Sabías que el Jeep Avenger fue el primer modelo 100% eléctrico de la marca lanzado en Europa, ganando el premio 'Car of the Year 2023'?",
    fecha: "Publicado: 2025-08-05",
    destacada: true,
    source_scope: "nacional",
  },
  {
    href: "./noticias-nacionales/noticia-kia-ev9",
    img: "/img/kia-ev9/kia-ev9-portada.webp",
    alt: "KIA EV-9",
    title: "KIA EV-9",
    description:
      "El KIA EV9 es uno de los primeros SUV eléctricos en el mundo que puede recibir actualizaciones de software a distancia.",
    fecha: "Publicado: 2025-08-01",
    source_scope: "nacional",
  },
  {
    href: "./noticias-nacionales/noticia-mazda-ez6",
    img: "/img/mazda-ez6/mazda-ez6-portada.webp",
    alt: "MAZDA EZ-6",
    title: "MAZDA EZ-6",
    description:
      "‘Skyactiv’ Tecnología que optimiza el rendimiento y la eficiencia del motor híbrido, Mazda fue pionera en el uso del motor rotativo.",
    fecha: "Publicado: 2025-08-02",
    source_scope: "nacional",
  },
  {
    href: "./noticias-nacionales/noticia-toyota-prado",
    img: "/img/toyota-prado/toyota-prado-copia.webp",
    alt: "TOYOTA PRADO",
    title: "TOYOTA PRADO",
    description:
      "La Toyota Prado es famosa por su durabilidad en algunos países, es el vehículo preferido para condiciones extremas.",
    fecha: "Publicado: 2025-08-03",
    source_scope: "nacional",
  },
  {
    href: "./noticias-nacionales/noticia-ford-f150",
    img: "/img/ford-f150/ford-f150-2.webp",
    alt: "FORD F-150",
    title: "FORD F-150",
    description:
      "La Ford F-150 Lightning puede alimentar una casa entera durante un corte de energía gracias a su batería de alta capacidad.",
    fecha: "Publicado: 2025-08-04",
    source_scope: "nacional",
  },
];

const staticLanzamientosWithDate = staticLanzamientos.map((note) => ({
  ...note,
  sortDate: parseDateValue(note.fecha),
}));

// Mezclamos dinámicas y estáticas y ordenamos por fecha descendente
const mezcladas = [...dynamicLanzamientos, ...staticLanzamientosWithDate].sort(
  (a, b) => b.sortDate - a.sortDate,
);

// Nota destacada y el resto
const destacada = mezcladas[0];
const resto = mezcladas.slice(1, HOME_VISIBLE_COUNT);
---

<section id="lanzamientos" class="noticias-container">
  <div class="noticias-header">
    <div class="noticias-icono">
      <i class="fa-brands fa-galactic-republic"></i>
    </div>
    <h1 class="noticias-titulo">LANZAMIENTOS</h1>
    <p class="descripcion-lanzamientos">
      Descubre los nuevos modelos que llegan al país: fichas técnicas, imágenes
      y versiones.
    </p>
  </div>

  {
    destacada && (
      <a href={destacada.href} class="noticia-avenger-container">
        <div class="noticia-avenger-texto">
          <h3 class="noticia-texto-titulo">{destacada.title}</h3>
          <p class="noticia-descripcion noticia-descripcion--destacada">
            {destacada.description}
          </p>
          <span class="noticia-fecha noticia-fecha--destacada">
            <i class="fa-regular fa-user" aria-hidden="true" />
            <span class="meta-author">
              {destacada.editor || "Jhon Aparicio"}
            </span>
            <span class="meta-sep">•</span>
            <i class="fa-regular fa-calendar" aria-hidden="true" />
            <span class="meta-date">{cleanPublishedDate(destacada.fecha)}</span>
          </span>
          <span
            class={
              "noticia-ambito " +
              (normalizeSourceScope(destacada.source_scope) === "internacional"
                ? "noticia-ambito--internacional"
                : "noticia-ambito--nacional")
            }
          >
            {sourceScopeLabel(destacada.source_scope)}
          </span>
        </div>
        <img
          src={destacada.img}
          alt={destacada.alt}
          class="noticia-avenger-imagen"
          loading="lazy"
          decoding="async"
        />
      </a>
    )
  }

  {
    resto.map((nota) => (
      <a href={nota.href} class="noticia-container">
        <div class="noticia-imagen-wrapper">
          <img
            src={nota.img}
            alt={nota.alt}
            class="noticia-imagen"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="noticia-texto">
          <h3 class="noticia-texto-titulo">{nota.title}</h3>
          <span class="noticia-fecha">
            <i class="fa-regular fa-user" aria-hidden="true" />
            <span class="meta-author">{nota.editor || "Jhon Aparicio"}</span>
            <span class="meta-sep">•</span>
            <i class="fa-regular fa-calendar" aria-hidden="true" />
            <span class="meta-date">{cleanPublishedDate(nota.fecha)}</span>
          </span>
          <span
            class={
              "noticia-ambito " +
              (normalizeSourceScope(nota.source_scope) === "internacional"
                ? "noticia-ambito--internacional"
                : "noticia-ambito--nacional")
            }
          >
            {sourceScopeLabel(nota.source_scope)}
          </span>
          <p class="noticia-descripcion">{nota.description}</p>
        </div>
      </a>
    ))
  }

  <div class="ver-mas-noticias-container">
    <a href="/lanzamientos" class="ver-mas-noticias-btn">Ver más lanzamientos</a
    >
  </div>
</section>


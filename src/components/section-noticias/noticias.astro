---
import { getApiUrl, fetchWithTimeout } from "../../lib/api";

type LanzamientoItem = {
  href: string;
  img: string;
  alt: string;
  title: string;
  description: string;
  fecha?: string;
  editor?: string;
  source_scope?: string;
  sortDate: number;
};

let dynamicLanzamientos: LanzamientoItem[] = [];
const HOME_VISIBLE_COUNT = 5;

function normalizeSourceScope(scope?: string) {
  return scope?.toLowerCase() === "internacional"
    ? "internacional"
    : "nacional";
}

function sourceScopeLabel(scope?: string) {
  return normalizeSourceScope(scope) === "internacional"
    ? "Internacional"
    : "Nacional";
}

function cleanPublishedDate(value?: string) {
  const cleaned = (value || "")
    .replace(/^Publicado:\s*/i, "")
    .replace(/^Nota:\s*/i, "")
    .trim();

  if (!cleaned) return "";
  if (/\d{4}/.test(cleaned)) return cleaned;
  if (/^\d{1,2}-[a-záéíóúüñ]+$/i.test(cleaned)) return `${cleaned}-2025`;
  return cleaned;
}

function parseDateValue(value?: string) {
  if (!value) return 0;

  const cleaned = value
    .replace(/^Publicado:\s*/i, "")
    .replace(/^Nota:\s*/i, "")
    .trim();

  const monthMap: Record<string, number> = {
    ene: 0,
    enero: 0,
    feb: 1,
    febrero: 1,
    mar: 2,
    marzo: 2,
    abr: 3,
    abril: 3,
    may: 4,
    mayo: 4,
    jun: 5,
    junio: 5,
    jul: 6,
    julio: 6,
    ago: 7,
    agosto: 7,
    sep: 8,
    septiembre: 8,
    oct: 9,
    octubre: 9,
    nov: 10,
    noviembre: 10,
    dic: 11,
    diciembre: 11,
  };

  const dayMonthMatch = cleaned.match(
    /^(\d{1,2})-([a-záéíóúüñ]+)(?:-(\d{4}))?$/i,
  );
  if (dayMonthMatch) {
    const [, dayRaw, monthRaw, yearRaw] = dayMonthMatch;
    const normalizedMonth = monthRaw
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "");
    const monthIndex = monthMap[normalizedMonth];
    if (Number.isInteger(monthIndex)) {
      const year = yearRaw ? Number(yearRaw) : 2025;
      return new Date(year, monthIndex, Number(dayRaw)).getTime();
    }
  }

  const direct = new Date(cleaned);
  if (!isNaN(direct.getTime())) return direct.getTime();

  const ddmmyyyy = cleaned.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (ddmmyyyy) {
    const [, dd, mm, yyyy] = ddmmyyyy;
    return new Date(`${yyyy}-${mm}-${dd}`).getTime();
  }

  return 0;
}

function normalizeImg(src: string) {
  return src
    .replace(/^\.\//, "/")
    .replace(/^\.\.\//, "/")
    .replace(/^img\//, "/img/");
}

function normalizeHref(href: string) {
  return href.replace(/^\.\//, "/");
}

try {
  const apiUrl = getApiUrl("get-notes");
  const data = await fetchWithTimeout(apiUrl);

  if (data && Array.isArray(data)) {
    dynamicLanzamientos = data
      .filter((note: any) => note.category?.toLowerCase() === "lanzamientos")
      .map((note: any) => ({
        href: `/notas/${note.id}`,
        img: normalizeImg(note.image1 || "/img/default.jpg"),
        alt: note.title,
        title: note.title,
        description: note.subtitle || "",
        fecha: note.created_at
          ? `Publicado: ${new Date(note.created_at).toLocaleDateString("es-CO")}`
          : "",
        editor: note.editor || "Jhon Aparicio",
        source_scope: normalizeSourceScope(note.source_scope),
        sortDate: note.created_at ? new Date(note.created_at).getTime() : 0,
      }));
  }
} catch (err) {
  console.error("Error cargando lanzamientos dinámicos:", err);
}

const staticLanzamientos: Omit<LanzamientoItem, "sortDate">[] = [
  {
    href: "/noticias-nacionales/noticia-jeep-avenger",
    img: "/img/jeep-avenger/jeep-avenger-portada.webp",
    alt: "Jeep Avenger",
    title: "Jeep Avenger",
    description:
      "El primer Jeep 100% eléctrico de la marca en Europa, ganador del Car of the Year 2023.",
    fecha: "Publicado: 2025-08-05",
    source_scope: "nacional",
  },
  {
    href: "/noticias-nacionales/noticia-kia-ev9",
    img: "/img/kia-ev9/kia-ev9-portada.webp",
    alt: "KIA EV9",
    title: "KIA EV9",
    description:
      "Uno de los primeros SUV eléctricos con actualizaciones de software a distancia (OTA).",
    fecha: "Publicado: 2025-08-01",
    source_scope: "nacional",
  },
  {
    href: "/noticias-nacionales/noticia-mazda-ez6",
    img: "/img/mazda-ez6/mazda-ez6-portada.webp",
    alt: "Mazda EZ-6",
    title: "Mazda EZ-6",
    description:
      "Tecnología Skyactiv aplicada a la electrificación con enfoque en eficiencia y rendimiento.",
    fecha: "Publicado: 2025-08-02",
    source_scope: "nacional",
  },
  {
    href: "/noticias-nacionales/noticia-toyota-prado",
    img: "/img/toyota-prado/toyota-prado-copia.webp",
    alt: "Toyota Prado",
    title: "Toyota Prado",
    description:
      "La nueva generación del SUV icónico, reconocido por su durabilidad en condiciones exigentes.",
    fecha: "Publicado: 2025-08-03",
    source_scope: "nacional",
  },
  {
    href: "/noticias-nacionales/noticia-ford-f150",
    img: "/img/ford-f150/ford-f150-2.webp",
    alt: "Ford F-150 Lightning",
    title: "Ford F-150 Lightning",
    description:
      "Pick-up eléctrica que puede alimentar una vivienda durante un corte de energía.",
    fecha: "Publicado: 2025-08-04",
    source_scope: "nacional",
  },
];

function slugTitle(t?: string) {
  return (t || "")
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]/g, "");
}

const staticLanzamientosWithDate: LanzamientoItem[] = staticLanzamientos.map(
  (note) => ({
    ...note,
    href: normalizeHref(note.href),
    img: normalizeImg(note.img),
    sortDate: parseDateValue(note.fecha),
  }),
);

const dynamicLanzamientosTitles = new Set(
  dynamicLanzamientos.map((n) => slugTitle(n.title)),
);

const deduplicatedStaticLanzamientos = staticLanzamientosWithDate.filter(
  (n) => !dynamicLanzamientosTitles.has(slugTitle(n.title)),
);

const homeLanzamientos = [
  ...dynamicLanzamientos,
  ...deduplicatedStaticLanzamientos,
]
  .sort((a, b) => b.sortDate - a.sortDate)
  .slice(0, HOME_VISIBLE_COUNT);
---

<link rel="stylesheet" href="/css/lanzamientos-section.css" />

<section
  id="lanzamientos"
  class="lanzamientos-section"
  aria-labelledby="lanzamientos-heading"
>
  <div class="lanzamientos-inner">
    <header class="lanzamientos-head">
      <p class="lanzamientos-eyebrow">Novedades del mercado</p>
      <h2 id="lanzamientos-heading" class="lanzamientos-title">Lanzamientos</h2>
      <p class="lanzamientos-lead">
        Los modelos que acaban de llegar o se presentan en Colombia: fichas,
        versiones e imágenes.
      </p>
    </header>

    {
      homeLanzamientos.length > 0 && (
        <div class="lanzamientos-feed">
          {homeLanzamientos.map((nota, index) => {
            const scope = normalizeSourceScope(nota.source_scope);
            const fecha = cleanPublishedDate(nota.fecha);

            return (
              <article
                class:list={[
                  "lanzamiento-item",
                  index === 0 && "is-latest",
                ]}
              >
                <a href={nota.href} class="lanzamiento-item__media">
                  <img
                    src={nota.img}
                    alt={nota.alt}
                    loading="lazy"
                    decoding="async"
                  />
                </a>
                <div class="lanzamiento-item__body">
                  {index === 0 && (
                    <span class="lanzamiento-badge-new">Recién llegado</span>
                  )}
                  <div class="lanzamiento-item__meta">
                    <span class={`lanzamiento-scope lanzamiento-scope--${scope}`}>
                      {sourceScopeLabel(nota.source_scope)}
                    </span>
                    {fecha && (
                      <span class="lanzamiento-item__date">{fecha}</span>
                    )}
                  </div>
                  <h3>
                    <a href={nota.href}>{nota.title}</a>
                  </h3>
                  <p class="lanzamiento-desc">{nota.description}</p>
                  <div class="lanzamiento-item__actions">
                    <a href={nota.href} class="lanzamiento-item__cta">
                      Ver lanzamiento →
                    </a>
                    <a
                      href="/automatch-find"
                      class="lanzamiento-item__automatch"
                    >
                      Comparar en AutoMatch
                    </a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      )
    }

    <footer class="lanzamientos-footer">
      <a href="/lanzamientos" class="lanzamientos-more">
        Ver más lanzamientos
        <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
      </a>
    </footer>
  </div>
</section>

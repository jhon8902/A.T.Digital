</style>

<script>
  document.addEventListener("DOMContentLoaded", async function () {
    const tituloLanzamientos = document.querySelector(
      "#lanzamientos .noticias-titulo",
    ) as HTMLElement;

    if (!tituloLanzamientos) return;

    // Animación con IntersectionObserver - MISMO PATRÓN QUE HÍBRIDOS
    const observerLanzamientos = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            tituloLanzamientos.classList.add("visible");
            tituloLanzamientos.style.opacity = "1";
          } else {
            tituloLanzamientos.classList.remove("visible");
            tituloLanzamientos.style.opacity = "0";
          }
        });
      },
      { threshold: 0.5 },
    );
    observerLanzamientos.observe(tituloLanzamientos);
  });
</script>

---
import { getApiUrl, fetchWithTimeout } from "../../lib/api";
import { getNewsCardDeck, getNewsCardTitle } from "../../lib/editorial";
import {
  formatNotePublishedLabel,
  getNotePublishTimestamp,
} from "../../lib/note-scheduling";

interface NoteItem {
  href: string;
  img: string;
  alt: string;
  title: string;
  description?: string;
  fecha?: string;
  editor?: string;
  source_scope?: string;
}

interface Props {
  category: string;
  categories?: string[];
  title: string;
  description: string;
  staticNotes?: NoteItem[];
  itemsPerPage?: number;
  skipFirst?: number;
}

const {
  category,
  categories,
  title,
  description,
  staticNotes = [],
  itemsPerPage = 12,
  skipFirst = 0,
} = Astro.props as Props;

function normalizeCategory(value: string) {
  return value
    ?.toString()
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "");
}

function extractFirstImage(html: string | undefined) {
  if (!html) return null;
  const match = html.match(/<img[^>]+src=["']([^"']+)["'][^>]*>/i);
  return match ? match[1] : null;
}

const MESES_ES: Record<string, string> = {
  ene: "01",
  enero: "01",
  feb: "02",
  febrero: "02",
  mar: "03",
  marzo: "03",
  abr: "04",
  abril: "04",
  may: "05",
  mayo: "05",
  jun: "06",
  junio: "06",
  jul: "07",
  julio: "07",
  ago: "08",
  agosto: "08",
  sep: "09",
  sept: "09",
  septiembre: "09",
  oct: "10",
  octubre: "10",
  nov: "11",
  noviembre: "11",
  dic: "12",
  diciembre: "12",
};

function parseDateValue(value?: string) {
  if (!value) return 0;

  const cleaned = value
    .replace(/^Publicado:\s*/i, "")
    .replace(/^Nota:\s*/i, "")
    .trim();

  const monthMap: Record<string, number> = {
    ene: 0,
    enero: 0,
    feb: 1,
    febrero: 1,
    mar: 2,
    marzo: 2,
    abr: 3,
    abril: 3,
    may: 4,
    mayo: 4,
    jun: 5,
    junio: 5,
    jul: 6,
    julio: 6,
    ago: 7,
    agosto: 7,
    sep: 8,
    septiembre: 8,
    oct: 9,
    octubre: 9,
    nov: 10,
    noviembre: 10,
    dic: 11,
    diciembre: 11,
  };

  const dayMonthMatch = cleaned.match(
    /^(\d{1,2})-([a-záéíóúüñ]+)(?:-(\d{4}))?$/i,
  );
  if (dayMonthMatch) {
    const [, dayRaw, monthRaw, yearRaw] = dayMonthMatch;
    const normalizedMonth = monthRaw
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "");
    const monthIndex = monthMap[normalizedMonth];
    if (Number.isInteger(monthIndex)) {
      const year = yearRaw ? Number(yearRaw) : 2025;
      return new Date(year, monthIndex, Number(dayRaw)).getTime();
    }
  }

  const direct = new Date(cleaned);
  if (!isNaN(direct.getTime())) return direct.getTime();

  const ddmmyyyy = cleaned.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (ddmmyyyy) {
    const [, dd, mm, yyyy] = ddmmyyyy;
    return new Date(`${yyyy}-${mm}-${dd}`).getTime();
  }

  return 0;
}

function sourceScopeLabel(scope?: string) {
  return scope?.toLowerCase() === "internacional"
    ? "Internacional"
    : "Nacional";
}

function sourceScopeClass(scope?: string) {
  return scope?.toLowerCase() === "internacional"
    ? "archivo-scope archivo-scope--internacional"
    : "archivo-scope archivo-scope--nacional";
}

function cleanPublishedDate(value?: string) {
  const cleaned = (value || "")
    .replace(/^Publicado:\s*/i, "")
    .replace(/^Nota:\s*/i, "")
    .trim();

  if (!cleaned) return "";
  if (/\d{4}/.test(cleaned)) return cleaned;
  if (/^\d{1,2}-[a-záéíóúüñ]+$/i.test(cleaned)) return `${cleaned}-2025`;
  return cleaned;
}

let dynamicNotes: Array<NoteItem & { sortDate: number }> = [];

try {
  const apiUrl = getApiUrl("get-notes");
  const data = await fetchWithTimeout(apiUrl);

  if (data && Array.isArray(data)) {
    const categorySet = categories
      ? new Set(categories.map((c) => normalizeCategory(c)))
      : null;

    dynamicNotes = data
      .filter((note: any) =>
        categorySet
          ? categorySet.has(normalizeCategory(note.category))
          : normalizeCategory(note.category) === normalizeCategory(category),
      )
      .map((note: any) => ({
        href: `/notas/${note.id}`,
        img:
          note.image1?.trim() ||
          extractFirstImage(note.content) ||
          "/img/default.jpg",
        alt: note.title || "nota",
        title: note.title || "Sin título",
        description: getNewsCardDeck(note.title, note.subtitle),
        editor: note.editor || "Jhon Aparicio",
        source_scope: note.source_scope || "nacional",
        fecha: formatNotePublishedLabel(note),
        sortDate: getNotePublishTimestamp(note),
      }));
  }
} catch (err) {
  console.error(`Error cargando notas de ${category}:`, err);
}

const normalizedStatic = staticNotes.map((note) => ({
  ...note,
  sortDate: parseDateValue(note.fecha),
}));

function slugTitle(t?: string) {
  return (t || "")
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]/g, "");
}
const dynamicTitles = new Set(dynamicNotes.map((n) => slugTitle(n.title)));
const deduplicatedStatic = normalizedStatic.filter(
  (n) => !dynamicTitles.has(slugTitle(n.title)),
);
const allNotes = [...dynamicNotes, ...deduplicatedStatic].sort(
  (a, b) => b.sortDate - a.sortDate,
);

// Omitir las primeras N notas que ya están visibles en la página principal
const archiveNotes = skipFirst > 0 ? allNotes.slice(skipFirst) : allNotes;

const totalPages = Math.max(1, Math.ceil(archiveNotes.length / itemsPerPage));
const requestedPage = Number(Astro.url.searchParams.get("page") || "1");
const currentPage =
  Number.isFinite(requestedPage) && requestedPage > 0
    ? Math.min(requestedPage, totalPages)
    : 1;
const startIndex = (currentPage - 1) * itemsPerPage;
const paginatedNotes = archiveNotes.slice(
  startIndex,
  startIndex + itemsPerPage,
);

const isNoticiasArchive = normalizeCategory(category) === "noticias";

function pageHref(page: number) {
  return page <= 1 ? "?" : `?page=${page}`;
}
---

<section
  class={`archivo-notas ${isNoticiasArchive ? "archivo-notas--noticias" : ""}`}
>
  <div class="archivo-header">
    <h1>{title}</h1>
    <p>{description}</p>
  </div>

  <div class="archivo-grid">
    {
      paginatedNotes.map((note) => (
        <article class="archivo-card">
          <a href={note.href} class="archivo-link">
            <div class="archivo-image">
              <img
                src={note.img}
                alt={note.alt}
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="archivo-content">
              <span class={sourceScopeClass(note.source_scope)}>
                {sourceScopeLabel(note.source_scope)}
              </span>
              <h2>{getNewsCardTitle(note.title)}</h2>
              <p class="archivo-date">
                <i class="fa-regular fa-user" aria-hidden="true" />
                <span class="meta-author">
                  {note.editor || "Jhon Aparicio"}
                </span>
                <span class="meta-sep">•</span>
                <i class="fa-regular fa-calendar" aria-hidden="true" />
                <span class="meta-date">{cleanPublishedDate(note.fecha)}</span>
              </p>
              {note.description && (
                <p class="archivo-desc">{note.description}</p>
              )}
            </div>
          </a>
        </article>
      ))
    }
  </div>

  {
    allNotes.length === 0 && (
      <p class="archivo-empty">Aún no hay notas disponibles en esta sección.</p>
    )
  }

  {
    allNotes.length > 0 && archiveNotes.length === 0 && (
      <p class="archivo-empty">
        Las notas más recientes de esta sección están en la página principal.
        ¡Pronto habrá más contenido aquí!
      </p>
    )
  }

  {
    totalPages > 1 && (
      <div class="archivo-pagination">
        <a
          href={pageHref(currentPage - 1)}
          class={`archivo-page-btn ${currentPage === 1 ? "is-disabled" : ""}`}
          aria-disabled={currentPage === 1}
          title="Página anterior"
        >
          &#8592;
        </a>

        <span class="archivo-page-indicator">
          {currentPage}
          <span class="archivo-page-total"> / {totalPages}</span>
        </span>

        <a
          href={pageHref(currentPage + 1)}
          class={`archivo-page-btn ${currentPage === totalPages ? "is-disabled" : ""}`}
          aria-disabled={currentPage === totalPages}
          title="Página siguiente"
        >
          &#8594;
        </a>
      </div>
    )
  }
</section>

<style>
  .archivo-notas {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 20px 60px;
    font-family: "Georgia", serif;
  }

  .archivo-header {
    text-align: center;
    margin-bottom: 30px;
  }

  .archivo-header h1 {
    font-size: clamp(28px, 4vw, 42px);
    margin-bottom: 10px;
    font-weight: 700;
  }

  .archivo-header p {
    font-size: 18px;
    color: #2c2c2c;
  }

  .archivo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 22px;
  }

  .archivo-card {
    border-radius: 14px;
    overflow: hidden;
    background: #fff;

    transition: transform 0.2s ease;
  }

  .archivo-card:hover {
    transform: translateY(-4px);
  }

  .archivo-link {
    display: block;
    color: inherit;
    text-decoration: none;
    height: 100%;
  }

  .archivo-image {
    height: 220px;
    overflow: hidden;
  }

  .archivo-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .archivo-content {
    padding: 18px;
  }

  .archivo-content h2 {
    font-size: 22px;
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .archivo-scope {
    display: inline-flex;
    align-items: center;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    padding: 0;
    border-radius: 0;
    margin-bottom: 8px;
    color: #4b5563;
    background: transparent;
    border: none;
  }

  .archivo-scope--nacional {
    color: #4b5563;
  }

  .archivo-scope--internacional {
    color: #4b5563;
  }

  .archivo-date {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 8px;
    color: #444;
  }

  .archivo-desc {
    font-size: 16px;
    line-height: 1.5;
    color: #1f1f1f;
  }

  .archivo-empty {
    margin-top: 24px;
    text-align: center;
    font-size: 18px;
    color: #333;
  }

  .archivo-pagination {
    margin-top: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    background: none;
    border-radius: 0;
    box-shadow: none;
    padding: 0;
    min-width: 0;
    border: none;
  }

  .archivo-page-btn {
    text-decoration: none;
    color: #08341f;
    border: 1.2px solid #e1a307;
    padding: 7px 18px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    background: #fff;
    box-shadow: none;
    transition:
      border 0.18s,
      color 0.18s,
      background 0.18s;
    cursor: pointer;
    outline: none;
    position: relative;
    min-width: 90px;
    text-align: center;
  }

  .archivo-page-btn:hover:not(.is-disabled),
  .archivo-page-btn:focus-visible:not(.is-disabled) {
    background: #e1a307;
    color: #fff;
    border-color: #08341f;
    box-shadow: none;
    transform: none;
  }

  .archivo-page-btn.is-disabled {
    pointer-events: none;
    opacity: 0.45;
    background: #f3f3f3;
    color: #aaa;
    border-color: #e0d9ce;
    box-shadow: none;
    transform: none;
  }

  .archivo-page-indicator {
    font-size: 17px;
    font-weight: 700;
    color: #08341f;
    letter-spacing: 0.01em;
    padding: 0 4px;
    background: transparent;
    border-radius: 0;
    min-width: 32px;
    text-align: center;
    transition: color 0.18s;
    display: inline-block;
  }
  .archivo-page-total {
    font-size: 14px;
    font-weight: 400;
    color: #b6a98b;
    margin-left: 2px;
  }

  .archivo-notas--noticias {
    width: min(90%, 1700px);
    max-width: 1700px;
  }

  .archivo-notas--noticias .archivo-header h1,
  .archivo-notas--noticias .archivo-header p,
  .archivo-notas--noticias .archivo-content h2,
  .archivo-notas--noticias .archivo-date,
  .archivo-notas--noticias .archivo-desc,
  .archivo-notas--noticias .archivo-page-btn,
  .archivo-notas--noticias .archivo-page-indicator,
  .archivo-notas--noticias .archivo-empty {
    font-family: "Georgia", serif;
  }

  @media (min-width: 1024px) {
    .archivo-notas--noticias .archivo-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 28px;
    }
  }

  @media (max-width: 768px) {
    .archivo-notas {
      padding: 30px 15px 50px;
    }

    .archivo-image {
      height: 190px;
    }

    .archivo-content h2 {
      font-size: 20px;
    }
  }
</style>

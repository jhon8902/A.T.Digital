      border-bottom: 0 !important;
      box-shadow: none !important;
      border-bottom: 2px solid rgba(59, 43, 1, 0.16) !important;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    // ---------------------------
    // Menú hamburguesa
    // ---------------------------
    const botonHamburguesa = document.getElementById("boton-hamburguesa");
    const menu = document.getElementById("menu-hamburguesa");
    const closeMenu = document.getElementById("close-menu");
    const overlay = document.getElementById("menu-overlay");
    const brandIdentity = document.querySelector(
      ".brand-identity",
    ) as HTMLElement | null;
    const topBar = document.getElementById("site-top-bar") as HTMLElement | null;
    const topBarAnchor = document.getElementById(
      "top-bar-anchor",
    ) as HTMLElement | null;
    const botonInicio = document.getElementById(
      "boton-inicio",
    ) as HTMLAnchorElement | null;
    const botonSubir = document.getElementById(
      "boton-subir",
    ) as HTMLButtonElement | null;
    const SCROLL_TOP_THRESHOLD = 280;

    function getHeaderOffset() {
      const topBarHeight = topBar?.getBoundingClientRect().height || 0;
      const brandBottom = brandIdentity?.getBoundingClientRect().bottom ?? 0;
      const isPinned =
        topBar?.classList.contains("is-fixed") || brandBottom <= 0;
      return Math.round((isPinned ? topBarHeight : 0) + 16);
    }

    function syncAnchorOffset() {
      document.documentElement.style.setProperty(
        "--header-anchor-offset",
        `${getHeaderOffset()}px`,
      );
    }

    function updatePinnedNav() {
      if (!brandIdentity || !topBar || !topBarAnchor) return;

      const shouldFix = brandIdentity.getBoundingClientRect().bottom <= 0;

      if (shouldFix) {
        topBar.classList.add("is-fixed");
        topBarAnchor.style.height = `${topBar.offsetHeight}px`;
      } else {
        topBar.classList.remove("is-fixed");
        topBarAnchor.style.height = "";
      }

      syncAnchorOffset();
    }

    function setupHomeButton() {
      const onHome = isHomePath(window.location.pathname);
      document.body.classList.toggle("has-home-btn", !onHome);

      if (!botonInicio) return;

      if (onHome) {
        botonInicio.classList.remove("is-visible");
      } else {
        botonInicio.classList.add("is-visible");
        botonInicio.setAttribute("href", "/");
        botonInicio.setAttribute("title", "Volver al inicio");
        botonInicio.setAttribute("aria-label", "Volver al inicio");
      }
    }

    function updateScrollTopButton() {
      if (!botonSubir) return;
      const show = window.scrollY > SCROLL_TOP_THRESHOLD;
      botonSubir.classList.toggle("is-visible", show);
    }

    function isHomePath(pathname: string) {
      return pathname === "/" || pathname === "/index.html";
    }

    function scrollToHash(hash: string, behavior: ScrollBehavior = "smooth") {
      const targetId = hash.replace(/^#/, "");
      if (!targetId) return false;

      const target = document.getElementById(targetId);
      if (!target) return false;

      const targetPosition =
        target.getBoundingClientRect().top + window.scrollY - getHeaderOffset();

      window.scrollTo({
        top: Math.max(0, targetPosition),
        behavior,
      });

      return true;
    }

    setupHomeButton();
    updatePinnedNav();
    updateScrollTopButton();

    botonSubir?.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    window.addEventListener(
      "scroll",
      () => {
        updatePinnedNav();
        updateScrollTopButton();
      },
      { passive: true },
    );

    window.addEventListener("resize", () => {
      updatePinnedNav();
      updateScrollTopButton();
    });

    const navDropdown = document.querySelector(".nav-dropdown");
    const navDropdownToggle = document.querySelector(".nav-dropdown-toggle");

    if (navDropdown && navDropdownToggle) {
      navDropdownToggle.addEventListener("click", () => {
        const isOpen = navDropdown.classList.toggle("is-open");
        navDropdownToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
      });

      document.addEventListener("click", (event) => {
        if (!navDropdown.contains(event.target as Node)) {
          navDropdown.classList.remove("is-open");
          navDropdownToggle.setAttribute("aria-expanded", "false");
        }
      });
    }

    const hashLinks = document.querySelectorAll('a[href^="/#"], a[href^="#"]');

    hashLinks.forEach((link) => {
      link.addEventListener("click", (event) => {
        const href = link.getAttribute("href") || "";
        const hashIndex = href.indexOf("#");
        if (hashIndex < 0) return;

        const hash = href.slice(hashIndex);
        if (!hash || hash === "#") return;

        const targetId = hash.slice(1);
        if (!targetId) return;

        const shouldNavigateToHome =
          href.startsWith("/#") && !isHomePath(window.location.pathname);

        if (shouldNavigateToHome) {
          return;
        }

        if (!document.getElementById(targetId)) {
          return;
        }

        event.preventDefault();
        history.pushState(null, "", `${window.location.pathname}${hash}`);
        scrollToHash(hash, "smooth");
      });
    });

    if (isHomePath(window.location.pathname) && window.location.hash) {
      requestAnimationFrame(() => {
        scrollToHash(window.location.hash, "auto");
      });
    }

    if (botonHamburguesa && menu) {
      botonHamburguesa.addEventListener("click", function () {
        menu.classList.add("active");
        document.body.style.overflow = "hidden";
      });
    }
    if (closeMenu && menu) {
      closeMenu.addEventListener("click", function () {
        menu.classList.remove("active");
        document.body.style.overflow = "";
      });
    }
    if (overlay && menu) {
      overlay.addEventListener("click", function () {
        menu.classList.remove("active");
        document.body.style.overflow = "";
      });
    }
    document.addEventListener("keydown", function (e) {
      if (menu && e.key === "Escape" && menu.classList.contains("active")) {
        menu.classList.remove("active");
        document.body.style.overflow = "";
      }
    });

    // ---------------------------
    // Botón de búsqueda y input
    // ---------------------------
    const searchButton = document.getElementById("search-button");
    const searchInput = document.getElementById(
      "search-input",
    ) as HTMLInputElement | null;
    const searchDataScript = document.getElementById("header-search-data");

    type HeaderSearchEntry = {
      title: string;
      description: string;
      href: string;
      category: string;
      type: "seccion" | "pagina" | "nota";
      keywords?: string[];
    };

    const encodedSearchData =
      searchDataScript?.getAttribute("data-search") || "";
    const staticSearchEntries: HeaderSearchEntry[] = encodedSearchData
      ? JSON.parse(decodeURIComponent(encodedSearchData))
      : [];
    let dynamicSearchEntries: HeaderSearchEntry[] = [];
    let dynamicSearchPromise: Promise<HeaderSearchEntry[]> | null = null;

    function normalizeSearchText(value: string) {
      return value
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/[^a-z0-9\s/-]/g, " ")
        .replace(/\s+/g, " ")
        .trim();
    }

    function stripHtml(value: string) {
      return value
        .replace(/<br\s*\/?\s*>/gi, " ")
        .replace(/<[^>]+>/g, " ")
        .replace(/\s+/g, " ")
        .trim();
    }

    function buildHaystack(entry: HeaderSearchEntry) {
      return normalizeSearchText(
        [
          entry.title,
          entry.description,
          entry.category,
          ...(entry.keywords || []),
        ].join(" "),
      );
    }

    function scoreEntry(query: string, entry: HeaderSearchEntry) {
      const normalizedQuery = normalizeSearchText(query);
      if (!normalizedQuery) return 0;

      const title = normalizeSearchText(entry.title);
      const description = normalizeSearchText(entry.description);
      const category = normalizeSearchText(entry.category);
      const haystack = buildHaystack(entry);
      const tokens = normalizedQuery.split(" ").filter(Boolean);

      let score = 0;

      if (title === normalizedQuery) score += 140;
      if (title.startsWith(normalizedQuery)) score += 100;
      if (title.includes(normalizedQuery)) score += 70;
      if (description.includes(normalizedQuery)) score += 35;
      if (category.includes(normalizedQuery)) score += 20;
      if (haystack.includes(normalizedQuery)) score += 15;

      tokens.forEach((token) => {
        if (title.startsWith(token)) score += 18;
        if (title.includes(token)) score += 12;
        if (description.includes(token)) score += 6;
        if (category.includes(token)) score += 5;
        if (haystack.includes(token)) score += 3;
      });

      return score;
    }

    function findMatches(
      query: string,
      entries: HeaderSearchEntry[],
      limit = 8,
    ) {
      const seen = new Set<string>();

      return entries
        .map((entry) => ({ entry, score: scoreEntry(query, entry) }))
        .filter(({ score }) => score > 0)
        .sort(
          (a, b) =>
            b.score - a.score || a.entry.title.localeCompare(b.entry.title),
        )
        .map(({ entry }) => entry)
        .filter((entry) => {
          if (seen.has(entry.href)) return false;
          seen.add(entry.href);
          return true;
        })
        .slice(0, limit);
    }

    function goToSearchTarget(href: string) {
      window.location.href = href;
    }

    async function loadDynamicSearchEntries() {
      if (dynamicSearchEntries.length > 0) {
        return dynamicSearchEntries;
      }

      if (!dynamicSearchPromise) {
        dynamicSearchPromise = fetch("/api/get-notes")
          .then((response) => {
            if (!response.ok) {
              throw new Error(`Search fetch failed: ${response.status}`);
            }
            return response.json();
          })
          .then((notes) => {
            if (!Array.isArray(notes)) {
              return [];
            }

            dynamicSearchEntries = notes.map((note) => ({
              title: note.title?.trim() || "Nota sin titulo",
              description:
                note.subtitle?.trim() ||
                stripHtml(note.content || "").slice(0, 180) ||
                "Nota editorial de Auto-Tech-Digital.",
              href: `/notas/${note.id}`,
              category: note.category?.trim() || "general",
              type: "nota",
              keywords: [note.category || "", note.subtitle || ""],
            }));

            return dynamicSearchEntries;
          })
          .catch((error) => {
            console.error(
              "No fue posible cargar las notas del buscador:",
              error,
            );
            return [];
          });
      }

      return dynamicSearchPromise;
    }

    const searchCloseBtn = document.getElementById("search-close");

    function abrirBuscador() {
      const inputEl = document.getElementById(
        "search-input",
      ) as HTMLInputElement | null;
      if (!inputEl) return;
      inputEl.classList.add("show");
      searchCloseBtn?.classList.add("visible");
      inputEl.focus();
      loadDynamicSearchEntries();
    }

    function cerrarBuscador() {
      const inputEl = document.getElementById(
        "search-input",
      ) as HTMLInputElement | null;
      if (!inputEl) return;
      inputEl.classList.remove("show");
      searchCloseBtn?.classList.remove("visible");
      inputEl.value = "";
      const sugerenciasEl = document.getElementById("sugerencias");
      if (sugerenciasEl) {
        sugerenciasEl.style.display = "none";
        sugerenciasEl.innerHTML = "";
      }
    }

    const menuSearchButton = document.getElementById("menu-search-button");
    if (menuSearchButton) {
      menuSearchButton.addEventListener("click", function () {
        if (menu) {
          menu.classList.remove("active");
          document.body.style.overflow = "";
        }
        abrirBuscador();
      });
    }

    if (searchButton && searchInput) {
      searchButton.addEventListener("click", function () {
        if (searchInput.classList.contains("show")) {
          cerrarBuscador();
        } else {
          abrirBuscador();
        }
      });
    } else {
      console.error("Los elementos de búsqueda no se encuentran en el DOM.");
    }

    if (searchCloseBtn) {
      searchCloseBtn.addEventListener("click", function () {
        cerrarBuscador();
      });
    }

    // ---------------------------
    // Botón de registro
    // ---------------------------
    const registerButton = document.querySelector(".register-button");
    if (registerButton) {
      registerButton.addEventListener("click", function () {
        window.location.href = "/registro";
      });
    }

    // Cerrar menú hamburguesa al hacer clic en un enlace
    const menuLinks = document.querySelectorAll(
      "#menu-hamburguesa .menu-content ul li a",
    );
    if (menu) {
      menuLinks.forEach(function (link) {
        link.addEventListener("click", function () {
          menu.classList.remove("active");
          document.body.style.overflow = "";
        });
      });
    }

    // ---------------------------
    // Buscador con sugerencias
    // ---------------------------
    if (!searchInput) {
      return;
    }
    const searchInputEl = searchInput;
    let orientacionTimeout: ReturnType<typeof setTimeout> | null = null;

    // Crear contenedor de sugerencias
    const sugerencias = document.createElement("div");
    sugerencias.id = "sugerencias";
    sugerencias.style.position = "fixed";
    sugerencias.style.background = "#fff";
    sugerencias.style.border = "1px solid #ccc";
    sugerencias.style.width = "380px";
    sugerencias.style.maxHeight = "400px";
    sugerencias.style.overflowY = "auto";
    sugerencias.style.display = "none";
    sugerencias.style.zIndex = "9998";
    sugerencias.style.borderRadius = "10px";
    sugerencias.style.boxShadow = "0 12px 40px rgba(0, 0, 0, 0.18)";
    document.body.appendChild(sugerencias);

    // Posicionar sugerencias debajo del input fijo
    function posicionarSugerencias() {
      sugerencias.style.top = "148px";
      sugerencias.style.right = "20px";
      sugerencias.style.left = "auto";
    }

    function limpiarTimerOrientacion() {
      if (orientacionTimeout) {
        clearTimeout(orientacionTimeout);
        orientacionTimeout = null;
      }
    }

    function programarOcultarOrientacion() {
      limpiarTimerOrientacion();
      orientacionTimeout = setTimeout(() => {
        // Solo ocultar si el input sigue vacío (significa que no escribió nada)
        if (!searchInputEl.value.trim()) {
          sugerencias.style.display = "none";
          sugerencias.innerHTML = "";
        }
      }, 3500);
    }

    function renderSuggestions(results: HeaderSearchEntry[]) {
      sugerencias.innerHTML = "";

      if (results.length === 0) {
        const emptyState = document.createElement("div");
        emptyState.style.padding = "12px";
        emptyState.style.background = "#fff";

        const emptyTitle = document.createElement("div");
        emptyTitle.textContent = "No hubo coincidencias directas";
        emptyTitle.style.fontSize = "13px";
        emptyTitle.style.fontWeight = "700";
        emptyTitle.style.color = "#18130b";
        emptyTitle.style.marginBottom = "4px";

        const emptyText = document.createElement("div");
        emptyText.textContent =
          "Prueba con marcas, modelos o categorias como BMW, Ford Bronco, hibridos o electricos.";
        emptyText.style.fontSize = "12px";
        emptyText.style.color = "#51473a";
        emptyText.style.lineHeight = "1.45";

        emptyState.append(emptyTitle, emptyText);
        sugerencias.appendChild(emptyState);
        sugerencias.style.display = "block";
        posicionarSugerencias();
        return;
      }

      results.forEach((result) => {
        const item = document.createElement("button");
        item.type = "button";
        item.style.display = "block";
        item.style.width = "100%";
        item.style.padding = "10px 12px";
        item.style.textAlign = "left";
        item.style.borderBottom = "1px solid #ece7dd";
        item.style.background = "#fff";
        item.style.cursor = "pointer";

        const meta = document.createElement("div");
        meta.textContent = `${result.type.toUpperCase()} | ${result.category}`;
        meta.style.fontSize = "11px";
        meta.style.color = "#7a6e57";
        meta.style.marginBottom = "4px";
        meta.style.letterSpacing = "0.04em";

        const title = document.createElement("div");
        title.textContent = result.title;
        title.style.fontSize = "14px";
        title.style.fontWeight = "700";
        title.style.color = "#18130b";
        title.style.marginBottom = "2px";

        const description = document.createElement("div");
        description.textContent = result.description;
        description.style.fontSize = "12px";
        description.style.color = "#51473a";
        description.style.lineHeight = "1.4";

        item.append(meta, title, description);

        item.addEventListener("click", () => {
          cerrarBuscador();
          goToSearchTarget(result.href);
        });

        item.addEventListener("mouseover", () => {
          item.style.background = "#f8f2e8";
        });

        item.addEventListener("mouseout", () => {
          item.style.background = "#fff";
        });

        sugerencias.appendChild(item);
      });

      const lastElement = sugerencias.lastElementChild as HTMLElement | null;
      if (lastElement) {
        lastElement.style.borderBottom = "0";
      }

      sugerencias.style.display = "block";
      posicionarSugerencias();
    }

    async function updateSuggestions() {
      limpiarTimerOrientacion(); // Cancelar timeout anterior
      const value = searchInputEl.value.trim();
      if (!value) {
        sugerencias.style.display = "none";
        sugerencias.innerHTML = "";
        return;
      }

      await loadDynamicSearchEntries();
      const results = findMatches(value, [
        ...staticSearchEntries,
        ...dynamicSearchEntries,
      ]);
      renderSuggestions(results);
      // NO programar timeout aquí - solo es para orientación inicial
    }

    // Mostrar sugerencias mientras escribe
    searchInputEl.addEventListener("input", function () {
      updateSuggestions();
    });

    searchInputEl.addEventListener("focus", function () {
      limpiarTimerOrientacion();
      if (!searchInputEl.value.trim()) {
        sugerencias.innerHTML = "";

        const hintState = document.createElement("div");
        hintState.style.padding = "12px";
        hintState.style.background = "#fff";

        const hintTitle = document.createElement("div");
        hintTitle.textContent = "Puedes buscar por:";
        hintTitle.style.fontSize = "13px";
        hintTitle.style.fontWeight = "700";
        hintTitle.style.color = "#18130b";
        hintTitle.style.marginBottom = "4px";

        const hintText = document.createElement("div");
        hintText.textContent =
          "Marcas, modelos o categorias. Ejemplos: BMW, DFSK E5, hibridos, electricos, pruebas.";
        hintText.style.fontSize = "12px";
        hintText.style.color = "#51473a";
        hintText.style.lineHeight = "1.45";

        hintState.append(hintTitle, hintText);
        sugerencias.appendChild(hintState);
        sugerencias.style.display = "block";
        posicionarSugerencias();
        programarOcultarOrientacion(); // Solo timeout para la orientación inicial
      } else {
        // Si ya hay text, mostrar resultados de búsqueda
        updateSuggestions();
      }
    });

    searchInputEl.addEventListener("blur", function () {
      // Al perder foco, ocultar sugerencias pero NO cerrar el input (permite seguir escribiendo)
      setTimeout(() => {
        limpiarTimerOrientacion();
        sugerencias.style.display = "none";
        sugerencias.innerHTML = "";
      }, 200);
    });

    sugerencias.addEventListener("mouseenter", function () {
      limpiarTimerOrientacion();
    });

    sugerencias.addEventListener("mouseleave", function () {
      // No hacer nada aquí - el blur del input o click fuera manejará la ocultación
      limpiarTimerOrientacion();
    });

    // Buscar con Enter
    searchInputEl.addEventListener("keydown", async function (event) {
      if (event.key === "Enter") {
        const value = searchInputEl.value.trim();
        if (!value) {
          sugerencias.style.display = "none";
          return;
        }

        await loadDynamicSearchEntries();
        const results = findMatches(value, [
          ...staticSearchEntries,
          ...dynamicSearchEntries,
        ]);
        const normalizedValue = normalizeSearchText(value);
        const exactMatch = results.find(
          (result) => normalizeSearchText(result.title) === normalizedValue,
        );

        // Cerrar el input antes de navegar
        cerrarBuscador();

        if (exactMatch) {
          goToSearchTarget(exactMatch.href);
          return;
        }

        window.location.href = `/buscar?q=${encodeURIComponent(value)}`;
      }
    });

    window.addEventListener("resize", function () {
      if (sugerencias.style.display === "block") {
        posicionarSugerencias();
      }
    });

    // Ocultar sugerencias al hacer clic fuera
    document.addEventListener("click", function (event) {
      const targetNode = event.target instanceof Node ? event.target : null;
      if (
        targetNode &&
        !searchInputEl.contains(targetNode) &&
        !sugerencias.contains(targetNode) &&
        !searchButton?.contains(targetNode) &&
        !searchCloseBtn?.contains(targetNode)
      ) {
        limpiarTimerOrientacion();
        cerrarBuscador();
      }
    });
  });
</script>

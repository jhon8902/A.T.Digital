---
import { STATIC_SEARCH_ENTRIES } from "../../lib/search";

const headerSearchData = encodeURIComponent(
  JSON.stringify(STATIC_SEARCH_ENTRIES),
);
---

<header class="header">
  <!-- Identidad editorial (se desplaza al hacer scroll) -->
  <div class="brand-identity">
    <div class="brand-copy">
      <p class="brand-tagline">
        <span class="tagline-desktop">
          Encuentra tu auto ideal con <strong>AutoMatch</strong> y explora
          eléctricos, híbridos y lanzamientos en Colombia.
        </span>
        <span class="tagline-mobile">
          AutoMatch y actualidad automotriz en Colombia.
        </span>
      </p>
    </div>
    <div class="brand-mark">
      <div class="brand-logo-frame">
        <img
          src="/img/autlogo2.png"
          alt="AutoTech Digital"
          class="brand-logo"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </div>

  <!-- Barra de navegación (queda fija al hacer scroll) -->
  <div class="top-bar-anchor" id="top-bar-anchor">
  <div class="top-bar" id="site-top-bar">
    <!-- Redes Sociales a la Izquierda -->
    <div class="header-social-icons">
      <a href="/contacto" class="fa-solid fa-envelope" aria-label="Contacto">
      </a>

      <a
        href="https://www.facebook.com/profile.php?id=61564010935908"
        class="fa-brands fa-facebook"
        target="_blank"
        rel="noopener noreferrer"></a>
      <a
        href="https://www.instagram.com/autotechdigital/"
        class="fa-brands fa-instagram"
        target="_blank"
        rel="noopener noreferrer"></a>
      <a
        href="https://www.tiktok.com/@autotechdigital"
        class="fa-brands fa-tiktok"
        target="_blank"
        rel="noopener noreferrer"></a>
    </div>

    <div class="spacer"></div>

    <!-- Menú de navegación para escritorio -->
    <nav id="menu-escritorio" class="menu-escritorio" aria-label="Navegación principal">
      <ul>
        <li>
          <a href="/" class="nav-home">Inicio</a>
        </li>
        <li>
          <a href="/#automatch" data-section="automatch" class="nav-primary">AutoMatch</a>
        </li>
        <li>
          <a href="/automatch-find" class="nav-cta">Encontrar mi auto</a>
        </li>
        <li>
          <a href="/#electricos" data-section="electricos">Eléctricos</a>
        </li>
        <li>
          <a href="/#hibridos" data-section="hibridos">Híbridos</a>
        </li>
        <li>
          <a href="/#noticias" data-section="noticias">Noticias</a>
        </li>
        <li class="nav-dropdown">
          <button
            type="button"
            class="nav-dropdown-toggle"
            aria-expanded="false"
            aria-haspopup="true"
          >
            Más
            <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
          </button>
          <ul class="nav-dropdown-menu">
            <li>
              <a href="/#lanzamientos" data-section="lanzamientos">Lanzamientos</a>
            </li>
            <li>
              <a href="/#pruebas" data-section="pruebas">Pruebas</a>
            </li>
            <li>
              <a href="/deportes">Deportes</a>
            </li>
          </ul>
        </li>
      </ul>
    </nav>

    <div class="spacer"></div>

    <div class="auth-buttons">
      <button id="search-button" class="fa-brands fa-sistrix"></button>
      <input
        type="text"
        id="search-input"
        class="search-input"
        placeholder="Busca marcas, modelos o categorias"
      />
      <button
        id="search-close"
        class="search-close"
        aria-label="Cerrar búsqueda">&times;</button
      >

      <button class="register-button">Registro</button>
    </div>
    <button id="boton-hamburguesa" class="boton-hamburguesa">
      <span>&#9776;</span>
    </button>
  </div>
  </div>

  <section id="inicio" aria-hidden="true"></section>

  <a
    href="/"
    id="boton-inicio"
    class="fa-solid fa-house boton-flotante boton-inicio"
    title="Volver al inicio"
    aria-label="Volver al inicio"></a>

  <button
    type="button"
    id="boton-subir"
    class="fa-solid fa-arrow-up boton-flotante boton-subir"
    title="Subir"
    aria-label="Subir al inicio de la página"></button>

  <!-- Menú hamburguesa para móvil -->
  <nav id="menu-hamburguesa" class="menu-hamburguesa">
    <div class="menu-overlay" id="menu-overlay"></div>
    <div class="menu-content">
      <button id="close-menu" class="close-menu" aria-label="Cerrar menú"
        >&times;</button
      >
      <div class="menu-mobile-actions">
        <button id="menu-search-button" type="button" class="menu-action-btn">
          Buscar
        </button>
        <a href="/registro" class="menu-action-link">Registro</a>
      </div>
      <ul>
        <li class="menu-mobile-group-label">Producto</li>
        <li>
          <a href="/#automatch" data-section="automatch" class="nav-primary">AutoMatch</a>
        </li>
        <li>
          <a href="/automatch-find" class="nav-cta">Encontrar mi auto</a>
        </li>

        <li class="menu-mobile-group-label">Explorar</li>
        <li><a href="/#electricos" data-section="electricos">Eléctricos</a></li>
        <li><a href="/#hibridos" data-section="hibridos">Híbridos</a></li>
        <li>
          <a href="/#lanzamientos" data-section="lanzamientos">Lanzamientos</a>
        </li>
        <li><a href="/#pruebas" data-section="pruebas">Pruebas</a></li>
        <li><a href="/#noticias" data-section="noticias">Noticias</a></li>

        <li class="menu-mobile-group-label">Más</li>
        <li><a href="/deportes">Deportes</a></li>
        <li><a href="/">Inicio</a></li>
      </ul>
    </div>
  </nav>
</header>

<div id="header-search-data" data-search={headerSearchData} hidden></div>

<style>
  /* Reset de box-sizing para todos los elementos */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: var(--header-anchor-offset, 120px);
  }

  [id] {
    scroll-margin-top: var(--header-anchor-offset, 120px);
  }

  /* Estilo principal del header */
  .header {
    position: relative;
    display: block;
    height: auto;
    width: 100%;
    background: black;
    font-family: var(--font-body);
    overflow: visible;
  }

  .top-bar-anchor {
    position: relative;
    width: 100%;
  }

  /* clase para redes sociales contenedor */

  .top-bar {
    display: flex;
    align-items: center;
    padding: 14px 20px;
    gap: 10px;
    position: relative;
    top: 0;
    left: 0;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    z-index: 1200;
    background-color: #fff;
    overflow-x: clip;
    border-top: 0;
    border-bottom: 0;
    box-shadow: none;
    margin: 0;
    border-bottom: 4px solid rgba(59, 43, 1, 0.16);
    transition:
      box-shadow 0.25s ease,
      border-color 0.25s ease;
  }

  .top-bar.is-fixed {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.12);
    border-bottom-color: rgba(59, 43, 1, 0.22);
  }

  /* Espaciadores para centrar el menú */
  .top-bar .spacer {
    flex: 1;
  }

  /* Menú de escritorio */
  .menu-escritorio {
    display: none;
    margin-top: 0;
    text-align: center;
    justify-self: center; /* Centra el menú en la columna del medio */
  }

  /* menu escritorio */
  .menu-escritorio ul {
    display: flex;
    justify-content: center;

    list-style: none;
    padding: 0;
    margin: 0;
  }

  .menu-escritorio ul li {
    margin: 0 10px;
  }

  .menu-escritorio ul li a {
    color: #111;
    font-size: 1.05rem;
    padding: 12px 18px;
    border-radius: 8px;
    text-decoration: none;
    border: 0 !important;
    background: transparent;
  }

  .menu-escritorio ul li a:hover {
    background: #f1f1f1 !important;
    color: #111;
    transform: none;
  }

  .menu-escritorio .nav-home {
    color: #111;
    font-weight: 700;
  }

  .menu-escritorio .nav-home:hover {
    background: #f1f1f1 !important;
    color: #111;
  }

  .menu-escritorio .nav-primary {
    color: var(--color-brand, #08341f);
    font-weight: 700;
  }

  .menu-escritorio .nav-cta {
    background: var(--color-brand, #08341f);
    color: #fff !important;
    font-weight: 700;
    padding: 10px 16px;
    border-radius: 999px;
  }

  .menu-escritorio .nav-cta:hover {
    background: var(--color-brand-hover, #0a4a2b) !important;
    color: #fff !important;
  }

  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: none;
    background: transparent;
    color: #111;
    font-size: 1.05rem;
    padding: 12px 18px;
    border-radius: 8px;
    cursor: pointer;
    font-family: inherit;
    text-transform: uppercase;
    font-weight: 500;
  }

  .nav-dropdown-toggle:hover,
  .nav-dropdown.is-open .nav-dropdown-toggle {
    background: #f1f1f1;
  }

  .nav-dropdown-toggle i {
    font-size: 0.72em;
    transition: transform 0.2s ease;
  }

  .nav-dropdown.is-open .nav-dropdown-toggle i {
    transform: rotate(180deg);
  }

  .nav-dropdown-menu {
    position: absolute;
    top: calc(100% + 0.35rem);
    left: 50%;
    transform: translateX(-50%);
    min-width: 190px;
    list-style: none;
    margin: 0;
    padding: 0.4rem;
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 10px;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.12);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.2s ease, visibility 0.2s ease;
    z-index: 1300;
  }

  .nav-dropdown.is-open .nav-dropdown-menu,
  .nav-dropdown:hover .nav-dropdown-menu,
  .nav-dropdown:focus-within .nav-dropdown-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .nav-dropdown-menu li {
    margin: 0 !important;
  }

  .nav-dropdown-menu a {
    display: block;
    padding: 0.65rem 0.85rem !important;
    border-radius: 6px;
    font-size: 0.95rem !important;
    text-transform: none;
    white-space: nowrap;
  }

  .menu-mobile-group-label {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0 18px;
    margin-top: 0.35rem;
  }

  .menu-content .nav-primary {
    color: #f8ca26;
    font-weight: 700;
  }

  .menu-content .nav-cta {
    background: var(--color-brand, #08341f);
    color: #fff !important;
    font-weight: 700;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  /* Redes sociales icono */

  .header-social-icons {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 32px;
    border-bottom: none;
    flex-shrink: 0; /* Evita que se compriman en móviles */
  }

  /* Espacio interno y tamaño de los iconos */
  .header-social-icons a {
    display: inline-block;
    height: 44px;
    width: 44px;
    padding: 6px; /* Ampliamos el espacio interno */
    padding-top: 12px;
    border-radius: 10px; /* Si deseas bordes redondeados */
    text-align: center;
    line-height: 15px; /* Centra el icono verticalmente */
  }

  /* WhatsApp */
  .header-social-icons a.fa-envelope {
    text-decoration: none;
    background-color: #25d366;
    transition: transform 0.3s ease;
  }
  .header-social-icons a.fa-envelope:hover {
    transform: scale(1.2); /* Efecto de pulso */
  }

  /* Facebook */
  .header-social-icons a.fa-facebook {
    background-color: #1877f2; /* Azul de Facebook */
    transition: transform 0.3s ease;
  }
  .header-social-icons a.fa-facebook:hover {
    transform: scale(1.2); /* Efecto de pulso */
  }

  /* Instagram */
  .header-social-icons a.fa-instagram {
    background: radial-gradient(
      circle at 30% 30%,
      #feda77,
      #f58529,
      #dd2a7b,
      #8134af,
      #515bd4
    ); /* Gradiente de Instagram */
    transition: transform 0.3s ease;
  }
  .header-social-icons a.fa-instagram:hover {
    transform: scale(1.2); /* Efecto de pulso */
  }

  /* TikTok */
  .header-social-icons a.fa-tiktok {
    background-color: #343333; /* Negro de TikTok */
    transition: transform 0.3s ease;
    color: white;
  }
  .header-social-icons a.fa-tiktok:hover {
    transform: scale(1.2); /* Efecto de pulso */
  }
  /* Botón hamburguesa */

  .boton-hamburguesa {
    color: #e1a307;
    font-size: 30px;
    border: 2px solid rgba(225, 163, 7, 0.3);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    padding: 8px 12px;
    flex-shrink: 0; /* Evita que se comprima en móviles */
    background: linear-gradient(
      135deg,
      rgba(225, 163, 7, 0.15),
      rgba(185, 143, 4, 0.1)
    );
    border-radius: 10px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    min-width: 46px;
    min-height: 46px;
  }

  .boton-hamburguesa:hover {
    background: linear-gradient(
      135deg,
      rgba(225, 163, 7, 0.25),
      rgba(185, 143, 4, 0.2)
    );
    border-color: rgba(225, 163, 7, 0.5);
    transform: scale(1.05);
    box-shadow: 0 4px 12px rgba(225, 163, 7, 0.2);
  }

  .boton-hamburguesa:active {
    transform: scale(0.95);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
  }

  .boton-hamburguesa span {
    display: block;
    font-weight: 600;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
  }

  .menu-hamburguesa {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 10000;
  }

  .menu-hamburguesa.active {
    display: block;
  }

  .menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1;
  }

  .menu-content {
    position: fixed;
    top: 0;
    left: 0;
    width: 80vw;
    max-width: 320px;
    height: 100vh;
    background: #111;
    box-shadow: 2px 0 20px rgba(0, 0, 0, 0.2);
    z-index: 2;
    padding: 30px 20px 20px 20px;
    display: flex;
    flex-direction: column;
    animation: slideInMenu 0.4s cubic-bezier(0.77, 0, 0.18, 1) forwards;
  }

  /*animacion menu hamburguesa*/
  @keyframes slideInMenu {
    from {
      transform: translateX(-100%);
    }
    to {
      transform: translateX(0);
    }
  }

  /* boton cerrar menu */
  .close-menu {
    background: none;
    border: none;
    color: #e1a307;
    font-size: 2rem;
    align-self: flex-end;
    cursor: pointer;
    margin-bottom: 20px;
  }

  .menu-mobile-actions {
    display: none;
  }

  .menu-action-btn,
  .menu-action-link {
    border: 0;
    background: #f3f3f3;
    color: #111;
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 0.92rem;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .menu-action-btn:hover,
  .menu-action-link:hover {
    background: #e8e8e8;
  }

  /* menu hamburguesa lista */
  .menu-content ul {
    list-style: none;
    padding: 0;
    margin: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  /* menu hamburguesa enlaces */
  .menu-content ul li a {
    color: white;
    font-size: 1.1rem;
    padding: 12px 18px;
    border-radius: 8px;
    text-decoration: none;

    transition:
      background 0.3s,
      color 0.3s,
      transform 0.2s;
    text-transform: uppercase;
    font-weight: 500;
  }
  .menu-content ul li a:hover {
    background: #bcbcbb;
    color: #111;
    transform: scale(1.05);
  }
  @media (min-width: 768px) {
    .menu-hamburguesa,
    .boton-hamburguesa {
      display: none !important;
    }
  }
  @media (max-width: 767px) {
    .menu-hamburguesa {
      display: none;
    }
    .menu-hamburguesa.active {
      display: block;
    }
    .boton-hamburguesa {
      display: flex;
    }
  }

  /* Media query para pantallas pequeñas */
  @media (max-width: 600px) {
    .header {
      height: auto;
      min-height: 0;
    }
  }

  /* Media query para pantallas medianas */
  @media (min-width: 601px) and (max-width: 1024px) {
    .header {
      height: auto;
      min-height: 0;
    }
  }

  /* Responsive */
  @media (min-width: 768px) {
    .header {
      height: auto;
      min-height: 0;
    }

    .header-social-icons {
      gap: 10px;
    }

    /* Mostrar el menú de navegación solo en escritorio */
    .top-bar .menu-hamburguesa {
      display: flex;
      padding: 5px;
    }
  }

  @media (max-width: 767px) {
    /* Ocultar el menú de navegación en móvil */
    .top-bar .menu-hamburguesa {
      display: none;
    }

    .header {
      height: auto;
      min-height: 0;
    }

    .top-bar {
      padding: 10px 12px;
      margin-top: 0;
      gap: 6px;
      justify-content: flex-start;
      align-items: center;
    }

    .top-bar .spacer {
      display: none;
    }

    /* Redes sociales: ancho específico */
    .header-social-icons {
      gap: 6px;
      font-size: 24px;
      min-width: 130px;
      flex-shrink: 0;
    }

    /* Espacio interno y tamaño de los iconos */
    .header-social-icons a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 36px;
      width: 36px;
      padding: 0;
      border-radius: 8px;
      text-align: center;
      line-height: 1;
    }

    /* Botones de autenticación: empujar hacia la derecha */
    .auth-buttons,
    #search-button,
    .register-button,
    #search-close {
      display: none !important;
    }

    .register-button {
      padding: 8px 12px;
      font-size: 12px;
      white-space: nowrap;
    }

    #search-button {
      padding: 8px 10px;
      font-size: 22px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .boton-hamburguesa {
      width: 44px;
      height: 44px;
      padding: 0;
      font-size: 22px;
      flex-shrink: 0;
      margin-left: auto;
      min-width: 44px;
      min-height: 44px;
      border-radius: 12px;
      border: 1px solid #d6d6d6;
      background: #fff;
      color: #1a1a1a;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .boton-hamburguesa span {
      font-size: 24px;
      line-height: 1;
      text-shadow: none;
    }

    .menu-mobile-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin: -4px 0 18px;
    }
  }

  /* Pantallas muy pequeñas (320px - 380px) */
  @media (max-width: 380px) {
    .header-social-icons {
      gap: 4px;
      font-size: 20px;
      min-width: 0;
    }

    .header-social-icons a {
      height: 30px;
      width: 30px;
    }

    .boton-hamburguesa {
      width: 40px;
      height: 40px;
      min-width: 40px;
      min-height: 40px;
      margin-left: auto;
      margin-right: 0;
    }

    #search-button {
      padding: 6px 8px;
      font-size: 20px;
    }
  }

  /* Botones de búsqueda y registro */
  .auth-buttons {
    display: flex;
    align-items: center; /* Asegura que los botones se alineen verticalmente */
    gap: 10px; /* Ajusta el espacio entre botones */
    font-size: 12px;
    flex-shrink: 0; /* Evita que se compriman en móviles */
  }

  .register-button {
    background-color: #111;
    color: white;
    padding: 8px 16px;
    border-radius: 5px;
    cursor: pointer;

    transition: background-color 0.3s;
    border: 0;
  }

  /* Estilos para el botón de búsqueda */
  #search-button {
    background-color: #111;
    color: white;
    padding: 8px 16px;
    border-radius: 5px;
    cursor: pointer;
    font-size: 30px;
    transition: background-color 0.6s;
    border: 0;
  }

  #search-button:hover {
    background-color: #555;
    color: white;
  }

  /* Estilo específico para el icono de búsqueda */
  .fa-sistrix {
    font-size: 10px;
  }

  /* Estilos para el input de búsqueda */
  .search-input {
    display: none; /* Inicialmente oculto */
    padding: 12px 16px;
    font-size: 14px;
    border-radius: 5px;
    border: 2px solid rgb(171, 129, 4);
    transition: opacity 0.3s ease-in-out;
    color: #333;
    background-color: #fff;
    width: 380px;
    font-family: Arial, sans-serif;
    position: fixed;
    top: 95px;
    right: 20px;
    z-index: 9999;

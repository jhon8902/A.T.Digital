---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__top">
      <div class="site-footer__brand">
        <p class="site-footer__eyebrow">Auto-Tech-Digital</p>
        <h2 class="site-footer__title">
          Tecnología, emoción y <span>futuro del automóvil</span>
        </h2>
        <p class="site-footer__lead">
          Noticias, fichas técnicas y AutoMatch para encontrar tu próximo auto en
          Colombia.
        </p>
        <a href="/automatch-find" class="site-footer__cta">
          <i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true"></i>
          Encontrar mi auto
        </a>
      </div>

      <nav class="site-footer__nav" aria-label="Enlaces del sitio">
        <div class="site-footer__nav-col">
          <h3 class="site-footer__nav-title">Portal</h3>
          <ul>
            <li><a href="/">Inicio</a></li>
            <li><a href="/#noticias">Noticias</a></li>
            <li><a href="/#automatch">AutoMatch</a></li>
            <li><a href="/automatch-find">Buscador</a></li>
            <li><a href="/calculadora-tco">Calculadora TCO</a></li>
          </ul>
        </div>
        <div class="site-footer__nav-col">
          <h3 class="site-footer__nav-title">Secciones</h3>
          <ul>
            <li><a href="/#electricos">Eléctricos</a></li>
            <li><a href="/#hibridos">Híbridos</a></li>
            <li><a href="/#lanzamientos">Lanzamientos</a></li>
            <li><a href="/deportes">Deportes</a></li>
            <li><a href="/#pruebas">Pruebas</a></li>
          </ul>
        </div>
      </nav>

      <div class="site-footer__social">
        <h3 class="site-footer__nav-title">Síguenos</h3>
        <div class="site-footer__social-icons">
          <a href="/contacto" class="site-footer__social-link" aria-label="Contacto">
            <i class="fa-solid fa-envelope" aria-hidden="true"></i>
          </a>
          <a
            href="https://www.facebook.com/profile.php?id=61564010935908"
            class="site-footer__social-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
          >
            <i class="fa-brands fa-facebook-f" aria-hidden="true"></i>
          </a>
          <a
            href="https://www.instagram.com/autotechdigital/"
            class="site-footer__social-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
          >
            <i class="fa-brands fa-instagram" aria-hidden="true"></i>
          </a>
          <a
            href="https://www.tiktok.com/@autotechdigital"
            class="site-footer__social-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="TikTok"
          >
            <i class="fa-brands fa-tiktok" aria-hidden="true"></i>
          </a>
        </div>
      </div>
    </div>

    <div class="site-footer__bottom">
      <p class="site-footer__copy">
        &copy; {year} Auto-Tech-Digital. Todos los derechos reservados.
      </p>
      <div class="site-footer__legal">
        <a href="/politica-privacidad">Política de privacidad</a>
        <a href="/concesionarios" class="site-footer__dealer">
          <i class="fa-solid fa-store" aria-hidden="true"></i>
          Programa concesionarios
        </a>
        <a href="/dashboard-concesionario" class="site-footer__dealer">
          <i class="fa-solid fa-right-to-bracket" aria-hidden="true"></i>
          Acceso al panel
        </a>
      </div>
    </div>
  </div>
</footer>

---
import { resolveSiteNotes, type SiteNote } from "../../lib/api";
import { getNotePublishTimestamp } from "../../lib/note-scheduling";
import {
  buildPruebaVideosFromNotes,
  slugPruebaTitle,
} from "../../lib/pruebas-videos";

interface Props {
  notes?: SiteNote[];
}

const { notes: prefetchedNotes } = Astro.props;

type PruebaItem = {
  noteId?: number;
  title: string;
  subtitle: string;
  video?: string;
  image?: string;
  href?: string;
  showNoteLink?: boolean;
  sortDate: number;
};

const staticPruebas: PruebaItem[] = [
  {
    title: "Ford F-150",
    subtitle:
      "La Ford F-150 es una pick-up que te brinda todo lo que necesitas para esos viajes fuera de la ciudad. Descubre la emoción de nuestro modelo estrella.",
    video: "/img/videos-pruebas/ford f-150.mp4",
    sortDate: new Date("2025-08-10").getTime(),
  },
  {
    title: "Xiaomi YU7",
    subtitle:
      "Diseño y tecnología en armonía, el carro de Xiaomi rompiendo récord como el más vendido en poco tiempo.",
    video: "/img/videos-pruebas/xiaomi YU7.mp4",
    sortDate: new Date("2025-08-09").getTime(),
  },
  {
    title: "Nissan Qashqai",
    subtitle:
      "Con nueva parrilla, la Nissan Qashqai nos sorprende con sus cambios en tecnología y seguridad.",
    video: "/img/videos-pruebas/nissan qashqai.mp4",
    sortDate: new Date("2025-08-08").getTime(),
  },
  {
    title: "Mazda Iconic",
    subtitle:
      "El diseño de este Mazda Iconic es muy moderno y elegante, destaca por sus líneas deportivas y detalles innovadores.",
    video: "/img/videos-pruebas/prueba-mazda.mp4",
    sortDate: new Date("2025-08-07").getTime(),
  },
  {
    title: "DFSK E5",
    subtitle:
      "La SUV eléctrica para 7 pasajeros, confortable y espaciosa, nos sorprendió mucho y seguro que a ustedes también les gustará.",
    video: "/img/videos-pruebas/video-dfsk.mp4",
    sortDate: new Date("2025-08-06").getTime(),
  },
  {
    title: "Kia K4 X-Line",
    subtitle:
      "La marca no quiere dejar los automóviles, por eso nos presenta el K4 Xline: deportivo, seguro y muy confortable.",
    video: "/img/videos-pruebas/video-kia-k4.mp4",
    sortDate: new Date("2025-08-05").getTime(),
  },
  {
    title: "Zeekr 007 GT",
    subtitle:
      "El ZEEKR 007 GT fue lanzado en China en abril del 2025 y a Europa llegará como 007 GT.",
    video: "/img/videos-pruebas/video-zeekr.mp4",
    sortDate: new Date("2025-08-04").getTime(),
  },
];

let dynamicPruebas: PruebaItem[] = [];

try {
  const data = await resolveSiteNotes(prefetchedNotes);

  if (data.length > 0) {
    dynamicPruebas = buildPruebaVideosFromNotes(data);
  }
} catch (err) {
  console.error("Error cargando pruebas dinámicas:", err);
}

const HOME_VISIBLE_COUNT = staticPruebas.length;

function slugTitle(t?: string) {
  return slugPruebaTitle(t);
}

const dynamicPruebasTitles = new Set(
  dynamicPruebas.map((n) => slugTitle(n.title)),
);
const deduplicatedStaticPruebas = staticPruebas.filter(
  (n) => !dynamicPruebasTitles.has(slugTitle(n.title)),
);
const allPruebas = [...dynamicPruebas, ...deduplicatedStaticPruebas].sort(
  (a, b) => b.sortDate - a.sortDate,
);

const homePruebas = allPruebas.slice(0, HOME_VISIBLE_COUNT);
---

<link rel="stylesheet" href="/css/pruebas.css" />

<section
  id="pruebas"
  class="pruebas-section"
  data-pruebas-channel
  aria-labelledby="pruebas-heading"
>
  <div class="pruebas-inner">
    <header class="pruebas-head">
      <p class="pruebas-eyebrow">Test drive en video</p>
      <h2 id="pruebas-heading" class="pruebas-title">Pruebas de manejo</h2>
      <p class="pruebas-lead">
        Ponemos a prueba los vehículos más relevantes del mercado y te contamos
        lo esencial de cada marca en formato video.
      </p>
    </header>

    {
      homePruebas.length > 0 && (
        <div class="pruebas-rail-wrap">
          <div class="pruebas-rail-toolbar">
            <h3 class="pruebas-rail-title">Episodios</h3>
            <div class="pruebas-rail-controls">
              <span class="pruebas-rail-counter" data-rail-counter aria-live="polite">
                1 / {homePruebas.length}
              </span>
              <div class="pruebas-rail-nav" aria-label="Navegación del carril">
                <button
                  type="button"
                  class="pruebas-rail-btn prev"
                  aria-label="Episodio anterior"
                >
                  <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
                </button>
                <button
                  type="button"
                  class="pruebas-rail-btn next"
                  aria-label="Siguiente episodio"
                >
                  <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
                </button>
              </div>
            </div>
          </div>

          <div class="pruebas-rail-viewport">
            <div class="pruebas-rail" data-pruebas-rail tabindex="0" aria-label="Carril de videos">
            {homePruebas.map((prueba, index) => (
              <article class="prueba-rail-card" style={`--rail-i: ${index}`}>
                <div class="prueba-rail-card__media" data-video-card>
                  {prueba.video ? (
                    <>
                      <video playsinline preload="metadata">
                        <source src={prueba.video} type="video/mp4" />
                      </video>
                      <button
                        type="button"
                        class="prueba-play"
                        aria-label={`Reproducir video de ${prueba.title}`}
                      />
                    </>
                  ) : prueba.image ? (
                    <img
                      src={prueba.image}
                      alt={prueba.title}
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="archivo-placeholder">Sin video</div>
                  )}
                </div>
                <div class="prueba-rail-card__body">
                  <p class="prueba-rail-ep">
                    Episodio {index + 1}
                  </p>
                  <h4>{prueba.title}</h4>
                  <p class="prueba-rail-desc">{prueba.subtitle}</p>
                  <div class="prueba-rail-actions">
                    {prueba.showNoteLink && prueba.href && (
                      <a href={prueba.href} class="archivo-link">
                        Ver nota
                      </a>
                    )}
                    <a href="/automatch-find" class="prueba-rail-automatch">
                      Comparar en AutoMatch
                    </a>
                  </div>
                </div>
              </article>
            ))}
            </div>
          </div>
        </div>
      )
    }

    <div class="pruebas-footer">
      <a href="/pruebas" class="pruebas-more">
        Ver más videos
        <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
      </a>
    </div>
  </div>
</section>

<script type="module" src="/js/pruebas-channel.js"></script>

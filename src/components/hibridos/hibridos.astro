---
import { getApiUrl, fetchWithTimeout } from "../../lib/api";

let dynamicHibridos: any[] = [];
const HOME_VISIBLE_COUNT = 6;

// ✅ Función para extraer la primera imagen del HTML
function extractFirstImage(html?: string) {
  if (!html) return null;
  const match = html.match(/<img[^>]+src=["']([^"']+)["'][^>]*>/i);
  return match ? match[1] : null;
}

// ✅ Normaliza strings para comparar sin tildes ni mayúsculas
function normalizeString(str?: string) {
  return str
    ?.normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .trim()
    .toLowerCase();
}

function normalizeSourceScope(scope?: string) {
  return scope?.toLowerCase() === "internacional"
    ? "internacional"
    : "nacional";
}

function sourceScopeLabel(scope?: string) {
  return normalizeSourceScope(scope) === "internacional"
    ? "Internacional"
    : "Nacional";
}

function cleanPublishedDate(value?: string) {
  const cleaned = (value || "").replace(/^Publicado:\s*/i, "").trim();
  if (!cleaned) return "";
  if (/\d{4}/.test(cleaned)) return cleaned;
  if (/^\d{1,2}-[a-záéíóúüñ]+$/i.test(cleaned)) return `${cleaned}-2025`;
  return cleaned;
}

function parseDateValue(value?: string) {
  const cleaned = (value || "").replace(/^Publicado:\s*/i, "").trim();

  if (!cleaned) return 0;

  const direct = new Date(cleaned);
  if (!isNaN(direct.getTime())) return direct.getTime();

  const ddmmyyyy = cleaned.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (ddmmyyyy) {
    const [, dd, mm, yyyy] = ddmmyyyy;
    return new Date(`${yyyy}-${mm}-${dd}`).getTime();
  }

  const ddMonth = cleaned.match(/^(\d{1,2})-([a-záéíóúüñ]+)$/i);
  if (ddMonth) {
    return new Date(`${cleaned}-2025`).getTime();
  }

  return 0;
}

// 🔹 Cargar notas dinámicas
try {
  const apiUrl = getApiUrl("get-notes");
  const data = await fetchWithTimeout(apiUrl);

  if (data && Array.isArray(data)) {
    dynamicHibridos = data
      .filter((note) => normalizeString(note.category) === "hibridos")
      .map((note) => {
        const portada =
          note.image1?.trim() ||
          extractFirstImage(note.content) ||
          "/img/default.jpg";

        return {
          href: `/notas/${note.id}`,
          img: portada,
          alt: note.title,
          title: note.title,
          description: note.subtitle || "",
          fecha: note.created_at
            ? `Publicado: ${new Date(note.created_at).toLocaleDateString("es-CO")}`
            : "",
          editor: note.editor || "Jhon Aparicio",
          source_scope: normalizeSourceScope(note.source_scope),
          sortDate: note.created_at ? new Date(note.created_at).getTime() : 0,
        };
      });
  }
} catch (err) {
  console.error("❌ Error cargando híbridos dinámicos:", err);
}

// 🔹 Notas estáticas
const staticHibridos = [
  {
    href: "/notas-hibridos/nota-scape",
    img: "../img/ford-scape-hibrida/ford-s.webp",
    alt: "ford-scape",
    title: "Ford Escape",
    description:
      "Usa motor eléctrico y de gasolina, brindando bajo consumo y buena autonomía. Ideal para viajes largos y manejo urbano cómodo y eficiente.",
    fecha: "Publicado: 13-mar",
    source_scope: "nacional",
  },
  {
    href: "/notas-hibridos/nota-volvo-cx90",
    img: "/img/volvo-cx90-hibrida/volvo-cx90-portada.webp",
    alt: "Volvo",
    title: "Volvo XC90",
    description:
      "SUV premium con motor híbrido y diseño escandinavo. Potente, eficiente y seguro, pensado para quienes buscan confort y tecnología.",
    fecha: "Publicado: 16-mar",
    source_scope: "nacional",
  },
  {
    href: "/notas-hibridos/nota-subaru",
    img: "/img/subaru-forester-hibrida/subaru-forester-portada.webp",
    alt: "Subaru",
    title: "Subaru Forester E-Boxer",
    description:
      "Integra motor bóxer con eléctrico para una tracción estable y eficiente. Ideal para caminos mixtos y aventuras urbanas.",
    fecha: "Publicado: 21-mar",
    source_scope: "nacional",
  },
  {
    href: "/notas-hibridos/nota-kona",
    img: "/img/kona-hibrida/kona-portada.webp",
    alt: "Kona",
    title: "Hyundai Kona Hybrid",
    description:
      "SUV compacto con consumo eficiente y diseño moderno. Incorpora ayudas de conducción y pantallas digitales para una experiencia conectada.",
    fecha: "Publicado: 25-mar",
    source_scope: "nacional",
  },
  {
    href: "/notas-hibridos/nota-audi-q7",
    img: "/img/audi-q7-hibrida/audi-q7-portada.webp",
    alt: "Audi Q7",
    title: "Audi Q7 TFSI E",
    description:
      "Lujoso SUV híbrido con motor V6 y gran autonomía eléctrica. Tecnología, potencia y confort se combinan en este modelo premium de Audi.",
    fecha: "Publicado: 28-mar",
    source_scope: "nacional",
  },
  {
    href: "/notas-hibridos/nota-nissan",
    img: "../img/nissan-xtrail-hibrida/nissan-x-trail.webp",
    alt: "X-Trail",
    title: "Nissan X-Trail E-Power",
    description:
      "SUV híbrido que destaca en ventas por su diseño, confort y motor eléctrico. Una opción confiable y moderna para la familia y ciudad, disfrutando de su confort.",
    fecha: "Publicado: 30-mar",
    source_scope: "nacional",
  },
];

// ✅ Combinamos dinámicas + estáticas
const staticHibridosWithDate = staticHibridos.map((note) => ({
  ...note,
  sortDate: parseDateValue(note.fecha),
}));

const allHibridos = [...dynamicHibridos, ...staticHibridosWithDate]
  .sort((a, b) => b.sortDate - a.sortDate)
  .slice(0, HOME_VISIBLE_COUNT);
---

<section id="hibridos" class="hibridos-container">
  <div class="central-content">
    <i class="fa-brands fa-megaport icono-central"></i>
    <h1>Carros Híbridos</h1>

    <p class="descripcion-hibridos">
      Modelos híbridos disponibles en el mercado nacional: consumo,
      características y detalles técnicos.
    </p>
  </div>

  <div class="imagenes-container">
    {
      allHibridos.map((nota) => (
        <a href={nota.href} class="hibrido">
          <div class="imagen-wrapper">
            <img
              src={nota.img}
              alt={nota.alt}
              class="hibrido-imagen"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="hibrido-texto">
            <h2>{nota.title}</h2>
            <div class="texto-fecha">
              <i class="fa-regular fa-user" aria-hidden="true" />
              <span class="meta-author">{nota.editor || "Jhon Aparicio"}</span>
              <span class="meta-sep">•</span>
              <i class="fa-regular fa-calendar" aria-hidden="true" />
              <span class="meta-date">{cleanPublishedDate(nota.fecha)}</span>
            </div>
            <span
              class={
                "scope-badge " +
                (normalizeSourceScope(nota.source_scope) === "internacional"
                  ? "scope-badge--internacional"
                  : "scope-badge--nacional")
              }
            >
              {sourceScopeLabel(nota.source_scope)}
            </span>
            <p>{nota.description}</p>
          </div>
        </a>
      ))
    }
  </div>
  <div class="ver-mas-container">
    <a href="/hibridos" class="ver-mas-boton">Ver más Modelos</a>
  </div>
</section>

<!-- CSS -->
<style>
  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    width: 100%;
    min-height: 100vh;
    margin: 0;
    padding: 0;
    overflow-x: hidden; /* Evita desbordamientos laterales */
  }

  section {
    scroll-margin-top: 100px;
  }

  .hibridos-container {
    width: 100%;
    background: linear-gradient(
      to bottom,
      #fafaf8 0%,
      #f3f2f2 50%,
      #fbf7f2 100%
    );
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-family: "Georgia", serif;
    padding: 0;
  }

  .central-content {
    text-align: center;
    padding: 40px;
    width: 100%;

    gap: 0;
    margin: 0;
  }

  .icono-central {
    font-size: 60px;
    color: #036697;
    animation: pulso-electrico 1.5s infinite ease-in-out;
  }

  /* animacion icono titulo 
  @keyframes pulso-electrico {
    0% {
      text-shadow:
        0 0 2px #05aafc,
        0 0 4px #05aafc;
      transform: scale(1);
    }
    50% {
      text-shadow:
        0 0 6px #05aafc,
        0 0 10px #05aafc;
      transform: scale(1.05);
    }
    100% {
      text-shadow:
        0 0 2px #05aafc,
        0 0 4px #05aafc;
      transform: scale(1);
    }
  } */

  .central-content h1 {
    font-size: clamp(40px, 5vw, 60px);
    font-weight: 500;
    color: black;
    text-transform: uppercase;
    font-weight: bold;
    letter-spacing: 3px;
    margin: 0;
    padding: 20px;
    font-family: "Georgia", serif;
  }

  /* animacion titulo aparezca */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(0);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .central-content h1 {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    font-size: 32px;
    color: black;
    text-shadow: 0 4px 8px rgba(236, 220, 200, 0.5);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .central-content h1::before,
  .central-content h1::after {
    content: "";
    flex: 1;
    height: 2px;
    background-color: #036697;
    max-width: 650px;
  }

  .descripcion-hibridos {
    font-size: 1.4rem;
    color: rgb(53, 52, 52);
    margin-top: 2px;
    font-family: "Georgia", serif;
    font-weight: 500;
    margin-top: -20px;
  }

  .animate-title {
    animation: fadeInUp 1s ease-out;
  }

  .imagenes-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
    max-width: 100%;
    width: 100%;
    padding: 30px 30px;
    margin: auto;
  }

  @media (min-width: 768px) {
    .imagenes-container {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .imagenes-container {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .hibrido {
    background-color: #f9f9f9;
    color: black;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    width: 100%;
  }

  .hibrido:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .imagen-wrapper {
    position: relative;
    width: 100%;
  }

  .hibrido-imagen {
    width: 100%;
    height: 400px;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .hibrido:hover .hibrido-imagen {
    transform: scale(1.1);
  }

  .hibrido-texto {
    background: #f3f4f6;
    padding: 20px;
    text-align: start;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .hibrido-texto h2 {
    font-size: 22px;
    font-weight: 600;
    text-transform: uppercase;
    color: #012323;
    text-align: start;
    position: relative;
    display: block;
    width: 85%;
    margin: 0;
    padding-bottom: 10px;
    border-bottom: 1px solid #014668;
  }

  .hibrido-texto h2::first-letter {
    font-size: 2.3rem;
    font-weight: bold;
    color: #036697;
  }

  .hibrido-texto p {
    font-size: clamp(1rem, 1.3vw, 1.3rem);
    line-height: 1.6;
    margin: 0;
    text-align: start; /* Cambia la alineación a la izquierda */
    color: #012323;
    width: 90%;
    padding-top: 15px;
    font-weight: 500;
  }

  .texto-fecha {
    position: static;
    display: block;
    background-color: transparent;
    color: #666;
    padding: 0;
    margin-top: 12px;
    margin-bottom: 10px;
    font-size: 0.75rem;
    font-weight: 400;
    border-radius: 0;
    font-family: "Georgia", serif;
    z-index: auto;
  }

  .texto-fecha::before {
    display: none;
  }

  .scope-badge {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 10px;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    color: #ffffff;
  }

  .scope-badge--nacional {
    background: #1f6f43;
  }

  .scope-badge--internacional {
    background: #1d4ed8;
  }

  .ver-mas-container {
    width: 100%;
    display: flex;
    justify-content: flex-start;
    padding: 30px 20px;
    box-sizing: border-box;
  }

  .ver-mas-boton {
    background-color: #036697;
    color: white;
    font-size: 18px;
    font-weight: 600;
    border: none;
    border-radius: 50px;
    padding: 12px 32px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
    transition: all 0.25s ease;
  }

  /* Efecto hover simple */
  .ver-mas-boton:hover {
    background-color: #024d73;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(3, 102, 151, 0.35);
  }

  /* Ocultar icono y texto-hover original */
  .flecha-icono,
  .texto-hover {
    display: none !important;
  }

  @media (max-width: 768px) {
    .imagenes-container {
      grid-template-columns: 1fr; /* Una sola columna */
      padding: 0; /* Sin padding lateral */
      gap: 20px; /* Espacio entre tarjetas */
    }

    .hibrido {
      width: 100vw; /* Ocupa todo el ancho de la ventana */
      margin-left: -10px; /* Ajusta si hay padding en el contenedor padre */
      border-radius: 0; /* Opcional: sin bordes redondeados */
    }

    .imagen-wrapper,
    .hibrido-imagen {
      width: 100vw; /* Imagen ocupa todo el ancho de la ventana */
      max-width: 100vw;
      left: 50%;
      right: 50%;
      margin-left: -50vw;
      margin-right: -50vw;
      position: relative;
    }

    .hibrido-imagen {
      height: 220px; /* Ajusta la altura si lo deseas */
      object-fit: cover;
      display: block;
    }

    .texto-fecha {
      display: block;
      position: static;
      background-color: transparent;
      color: #666;
      padding: 0;
      margin-top: 10px;
      margin-bottom: 10px;
      margin-left: 0;
      font-size: 12px;
      font-weight: 400;
      border-radius: 0;
    }

    .texto-fecha::before {
      display: none;
    }

    .icono-central {
      font-size: 3rem;

      padding-top: 20px;
    }

    .central-content {
      padding: 10px; /* sin padding */
      text-align: center;
    }

    .central-content h1 {
      font-size: 24px;
      letter-spacing: 0;
      padding: 15px;
    }

    /* Línea izquierda */
    .central-content h1::before,
    .central-content h1::after {
      display: none; /* Oculta las líneas en móvil */
    }

    .descripcion-hibridos {
      width: 100%;
      padding: 20px 15px; /* espacio lateral */
      margin: 10px 0; /* espacio arriba y abajo */
      font-size: 16px;
      text-align: center;
      line-height: 1.5; /* mejor lectura */
      display: block;
      box-sizing: border-box;

      margin-top: -25px;
    }

    .hibrido-texto {
      padding: 20px;
      gap: 0;
      width: 100%;
    }

    .hibrido-texto h2 {
      font-size: 18px;
      text-align: start;
      background: none;
      margin: 0;
      font-weight: 600;
      display: block;
      width: 100%;
      border-bottom: 1px solid #014668;
      margin-bottom: 8px;
      padding-bottom: 8px;
    }

    .hibrido-texto p {
      font-size: 16px;
      line-height: 1.4;
      margin-bottom: 25px;
      padding: 5px;
    }

    .hibrido-imagen {
      width: 100%;
      height: 250px;
    }

    .ver-mas-boton {
      padding: 12px 28px;
      font-size: 1rem;
      width: 100%;
      justify-content: center;
    }

    .ver-mas-container {
      padding: 20px 16px;
      margin: 0;
      justify-content: center;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const tituloHibrido = document.querySelector(
      "#hibridos .central-content h1",
    ) as HTMLElement;

    if (!tituloHibrido) return;

    const observerHibridos = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            tituloHibrido.classList.add("animate-title");
            tituloHibrido.style.opacity = "1";
          } else {
            tituloHibrido.classList.remove("animate-title");
            tituloHibrido.style.opacity = "0";
          }
        });
      },
      { threshold: 0.5 },
    );

    observerHibridos.observe(tituloHibrido);
  });
</script>

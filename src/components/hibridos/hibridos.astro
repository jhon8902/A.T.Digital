---
import { resolveSiteNotes, type SiteNote } from "../../lib/api";
import {
  formatNotePublishedLabel,
  getNotePublishTimestamp,
} from "../../lib/note-scheduling";
import { getNewsCardDeck, getNewsCardTitle } from "../../lib/editorial";

interface Props {
  notes?: SiteNote[];
}

const { notes: prefetchedNotes } = Astro.props;

type HibridoItem = {
  href: string;
  img: string;
  alt: string;
  title: string;
  description: string;
  fecha?: string;
  editor?: string;
  source_scope?: string;
  chips?: string[];
  sortDate: number;
};

let dynamicHibridos: HibridoItem[] = [];
const HOME_VISIBLE_COUNT = 6;

function normalizeString(str?: string) {
  return str
    ?.normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .trim()
    .toLowerCase();
}

function normalizeSourceScope(scope?: string) {
  return scope?.toLowerCase() === "internacional"
    ? "internacional"
    : "nacional";
}

function sourceScopeLabel(scope?: string) {
  return normalizeSourceScope(scope) === "internacional"
    ? "Internacional"
    : "Nacional";
}

function cleanPublishedDate(value?: string) {
  const cleaned = (value || "").replace(/^Publicado:\s*/i, "").trim();
  if (!cleaned) return "";
  if (/\d{4}/.test(cleaned)) return cleaned;
  if (/^\d{1,2}-[a-záéíóúüñ]+$/i.test(cleaned)) return `${cleaned}-2025`;
  return cleaned;
}

const MESES_ES: Record<string, string> = {
  ene: "01",
  enero: "01",
  feb: "02",
  febrero: "02",
  mar: "03",
  marzo: "03",
  abr: "04",
  abril: "04",
  may: "05",
  mayo: "05",
  jun: "06",
  junio: "06",
  jul: "07",
  julio: "07",
  ago: "08",
  agosto: "08",
  sep: "09",
  sept: "09",
  septiembre: "09",
  oct: "10",
  octubre: "10",
  nov: "11",
  noviembre: "11",
  dic: "12",
  diciembre: "12",
};

function parseDateValue(value?: string) {
  const cleaned = (value || "").replace(/^Publicado:\s*/i, "").trim();
  if (!cleaned) return 0;

  const direct = new Date(cleaned);
  if (!isNaN(direct.getTime())) return direct.getTime();

  const ddmmyyyy = cleaned.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (ddmmyyyy) {
    const [, dd, mm, yyyy] = ddmmyyyy;
    return new Date(`${yyyy}-${mm}-${dd}`).getTime();
  }

  const ddMonth = cleaned.match(/^(\d{1,2})-([a-záéíóúüñ]+)$/i);
  if (ddMonth) {
    const [, dd, monthStr] = ddMonth;
    const mm = MESES_ES[monthStr.toLowerCase()];
    if (mm) return new Date(`2025-${mm}-${dd.padStart(2, "0")}`).getTime();
  }

  return 0;
}

function extractFirstImage(html?: string) {
  if (!html) return null;
  const match = html.match(/<img[^>]+src=["']([^"']+)["'][^>]*>/i);
  return match ? match[1] : null;
}

function normalizeImg(src: string) {
  return src
    .replace(/^\.\.\//, "/")
    .replace(/^img\//, "/img/")
    .replace(/^\/\//, "/");
}

function buildChips(item: { description?: string; title?: string; chips?: string[] }) {
  if (item.chips?.length) return item.chips.slice(0, 3);

  const chips: string[] = [];
  const text = `${item.title || ""} ${item.description || ""}`.toLowerCase();

  if (/phev|tfsi\s*e|enchufable|plug/i.test(text)) chips.push("PHEV");
  else if (/e-power|epower/i.test(text)) chips.push("e-Power");
  else if (/híbrido|hibrido|hybrid|hev/i.test(text)) chips.push("HEV");

  if (/suv/i.test(text)) chips.push("SUV");
  if (/compacto/i.test(text)) chips.push("Compacto");
  if (/premium|lujo|lujoso/i.test(text)) chips.push("Premium");
  if (/consumo|eficiente|bajo consumo/i.test(text)) chips.push("Bajo consumo");
  if (/awd|tracción|4x4|bóxer|boxer/i.test(text)) chips.push("AWD");

  if (chips.length === 0) chips.push("Híbrido");
  return chips.slice(0, 3);
}

try {
  const data = await resolveSiteNotes(prefetchedNotes);

  if (data.length > 0) {
    dynamicHibridos = data
      .filter((note) => normalizeString(note.category) === "hibridos")
      .map((note) => {
        const portada =
          note.image1?.trim() ||
          extractFirstImage(note.content) ||
          "/img/default.jpg";

        return {
          href: `/notas/${note.id}`,
          img: normalizeImg(portada),
          alt: note.title,
          title: note.title,
          description: getNewsCardDeck(note.title, note.subtitle),
          fecha: formatNotePublishedLabel(note),
          editor: note.editor || "Jhon Aparicio",
          source_scope: normalizeSourceScope(note.source_scope),
          sortDate: getNotePublishTimestamp(note),
        };
      });
  }
} catch (err) {
  console.error("Error cargando híbridos dinámicos:", err);
}

const staticHibridos: Omit<HibridoItem, "sortDate">[] = [
  {
    href: "/notas-hibridos/nota-scape",
    img: "/img/ford-scape-hibrida/ford-s.webp",
    alt: "Ford Escape",
    title: "Ford Escape Hybrid",
    description:
      "Motor eléctrico y gasolina con bajo consumo y buena autonomía. Ideal para viajes largos y manejo urbano cómodo.",
    fecha: "Publicado: 13-mar",
    source_scope: "nacional",
    chips: ["HEV", "SUV", "Bajo consumo"],
  },
  {
    href: "/notas-hibridos/nota-volvo-cx90",
    img: "/img/volvo-cx90-hibrida/volvo-cx90-portada.webp",
    alt: "Volvo XC90",
    title: "Volvo XC90",
    description:
      "SUV premium con motor híbrido, diseño escandinavo y enfoque en seguridad, confort y tecnología.",
    fecha: "Publicado: 16-mar",
    source_scope: "nacional",
    chips: ["PHEV", "SUV", "Premium"],
  },
  {
    href: "/notas-hibridos/nota-subaru",
    img: "/img/subaru-forester-hibrida/subaru-forester-portada.webp",
    alt: "Subaru Forester",
    title: "Subaru Forester E-Boxer",
    description:
      "Motor bóxer con asistencia eléctrica para tracción estable y eficiencia en caminos mixtos y ciudad.",
    fecha: "Publicado: 21-mar",
    source_scope: "nacional",
    chips: ["HEV", "AWD", "SUV"],
  },
  {
    href: "/notas-hibridos/nota-kona",
    img: "/img/kona-hibrida/kona-portada.webp",
    alt: "Hyundai Kona",
    title: "Hyundai Kona Hybrid",
    description:
      "SUV compacto con consumo eficiente, diseño moderno y asistencias de conducción conectadas.",
    fecha: "Publicado: 25-mar",
    source_scope: "nacional",
    chips: ["HEV", "Compacto", "Conectado"],
  },
  {
    href: "/notas-hibridos/nota-audi-q7",
    img: "/img/audi-q7-hibrida/audi-q7-portada.webp",
    alt: "Audi Q7",
    title: "Audi Q7 TFSI e",
    description:
      "SUV híbrido enchufable con motor V6, autonomía eléctrica y alto nivel de confort y tecnología.",
    fecha: "Publicado: 28-mar",
    source_scope: "nacional",
    chips: ["PHEV", "Premium", "V6"],
  },
  {
    href: "/notas-hibridos/nota-nissan",
    img: "/img/nissan-xtrail-hibrida/nissan-x-trail.webp",
    alt: "Nissan X-Trail",
    title: "Nissan X-Trail e-Power",
    description:
      "SUV híbrido con motor e-Power, confort familiar y manejo suave para ciudad y carretera.",
    fecha: "Publicado: 30-mar",
    source_scope: "nacional",
    chips: ["e-Power", "SUV", "Familiar"],
  },
];

function slugTitle(t?: string) {
  return (t || "")
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]/g, "");
}

const staticHibridosWithDate: HibridoItem[] = staticHibridos.map((note) => ({
  ...note,
  img: normalizeImg(note.img),
  sortDate: parseDateValue(note.fecha),
}));

const dynamicHibridosTitles = new Set(
  dynamicHibridos.map((n) => slugTitle(n.title)),
);

const deduplicatedStaticHibridos = staticHibridosWithDate.filter(
  (n) => !dynamicHibridosTitles.has(slugTitle(n.title)),
);

const allHibridos = [...dynamicHibridos, ...deduplicatedStaticHibridos]
  .sort((a, b) => b.sortDate - a.sortDate)
  .slice(0, HOME_VISIBLE_COUNT);
---

<link rel="stylesheet" href="/css/hibridos-section.css" />

<section
  id="hibridos"
  class="hibridos-section"
  aria-labelledby="hibridos-heading"
>
  <div class="hibridos-inner">
    <header class="hibridos-head">
      <p class="hibridos-eyebrow">Electrificación intermedia</p>
      <h2 id="hibridos-heading" class="hibridos-title">Carros híbridos</h2>
      <p class="hibridos-lead">
        HEV, PHEV y e-Power en Colombia: consumo, tipo de híbrido y fichas para
        comparar con AutoMatch.
      </p>
    </header>

    {
      allHibridos.length > 0 && (
        <div class="hibridos-grid">
          {allHibridos.map((nota) => {
            const chips = buildChips(nota);
            const scope = normalizeSourceScope(nota.source_scope);
            const fecha = cleanPublishedDate(nota.fecha);

            return (
              <article class="hibrido-card">
                <a href={nota.href} class="hibrido-card__media">
                  <img
                    src={nota.img}
                    alt={nota.alt}
                    loading="lazy"
                    decoding="async"
                  />
                </a>
                <div class="hibrido-card__body">
                  <div class="hibrido-card__meta">
                    <span class={`hibrido-scope hibrido-scope--${scope}`}>
                      {sourceScopeLabel(nota.source_scope)}
                    </span>
                    {fecha && (
                      <span class="hibrido-card__date">{fecha}</span>
                    )}
                  </div>
                  <h3>
                    <a href={nota.href}>{getNewsCardTitle(nota.title)}</a>
                  </h3>
                  <div class="hibrido-chips">
                    {chips.map((chip) => (
                      <span class="hibrido-chip">{chip}</span>
                    ))}
                  </div>
                  {
                    nota.description && (
                      <p class="hibrido-desc">{nota.description}</p>
                    )
                  }
                  <div class="hibrido-card__actions">
                    <a href={nota.href} class="hibrido-card__cta">
                      Ver ficha
                    </a>
                    <a href="/automatch-find" class="hibrido-card__automatch">
                      Comparar en AutoMatch
                    </a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      )
    }

    <footer class="hibridos-footer">
      <a href="/hibridos" class="hibridos-more">
        Ver más modelos
        <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
      </a>
    </footer>
  </div>
</section>

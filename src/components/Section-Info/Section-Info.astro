    height: 2px;
    background: linear-gradient(90deg, #d4a742, #000);
    min-width: 0;
    max-width: 650px;
  }

  .info-descripcion {
    font-size: 1.3rem;
    color: #2f2f2f;
    font-family: "Georgia", serif;

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const tituloNoticias = document.querySelector(
      "#noticias .info-titulo",
    ) as HTMLElement;

    if (!tituloNoticias) return;

    const observerNoticias = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            tituloNoticias.classList.add("animate-title");
            tituloNoticias.style.opacity = "1";
          } else {
            tituloNoticias.classList.remove("animate-title");
            tituloNoticias.style.opacity = "0";
          }
        });
      },
      { threshold: 0.5 },
    );

    observerNoticias.observe(tituloNoticias);
  });
</script>

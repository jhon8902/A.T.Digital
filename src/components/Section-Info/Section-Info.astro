---
import { getApiUrl, fetchWithTimeout } from "../../lib/api";
// --- CARGA Y FILTRO DE NOTAS DE CATEGORÍA "noticias" ---

let dynamicNotes: any[] = [];
const HOME_VISIBLE_COUNT = 5;

function normalizeSourceScope(scope?: string) {
  return scope?.toLowerCase() === "internacional"
    ? "internacional"
    : "nacional";
}

function sourceScopeLabel(scope?: string) {
  return normalizeSourceScope(scope) === "internacional"
    ? "Internacional"
    : "Nacional";
}

function cleanPublishedDate(value?: string) {
  return (value || "").replace(/^Publicado:\s*/i, "").trim();
}

function extractFirstImage(html?: string) {
  if (!html) return null;
  const match = html.match(/<img[^>]+src=["']([^"']+)["'][^>]*>/i);
  return match ? match[1] : null;
}

function parseDateValue(value?: string) {
  if (!value) return 0;

  const cleaned = value
    .replace(/^Publicado:\s*/i, "")
    .replace(/^Nota:\s*/i, "")
    .trim();

  const monthMap: Record<string, number> = {
    ene: 0,
    enero: 0,
    feb: 1,
    febrero: 1,
    mar: 2,
    marzo: 2,
    abr: 3,
    abril: 3,
    may: 4,
    mayo: 4,
    jun: 5,
    junio: 5,
    jul: 6,
    julio: 6,
    ago: 7,
    agosto: 7,
    sep: 8,
    septiembre: 8,
    oct: 9,
    octubre: 9,
    nov: 10,
    noviembre: 10,
    dic: 11,
    diciembre: 11,
  };

  const dayMonthMatch = cleaned.match(
    /^(\d{1,2})-([a-záéíóúüñ]+)(?:-(\d{4}))?$/i,
  );
  if (dayMonthMatch) {
    const [, dayRaw, monthRaw, yearRaw] = dayMonthMatch;
    const normalizedMonth = monthRaw
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "");
    const monthIndex = monthMap[normalizedMonth];
    if (Number.isInteger(monthIndex)) {
      const year = yearRaw ? Number(yearRaw) : 2025;
      return new Date(year, monthIndex, Number(dayRaw)).getTime();
    }
  }

  const direct = new Date(cleaned);
  if (!isNaN(direct.getTime())) return direct.getTime();

  const ddmmyyyy = cleaned.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (ddmmyyyy) {
    const [, dd, mm, yyyy] = ddmmyyyy;
    return new Date(`${yyyy}-${mm}-${dd}`).getTime();
  }

  return 0;
}

try {
  const data = await fetchWithTimeout(getApiUrl("get-notes"));

  if (data && Array.isArray(data)) {
    // 2️⃣ Filtramos solo las notas de la categoría "noticias"
    const filtered = data.filter(
      (note: any) => note.category?.toLowerCase() === "noticias",
    );

    // 3️⃣ Normalizamos formato para el carrusel
    dynamicNotes = filtered.map((note: any) => ({
      href: `/notas/${note.id}`,
      img: note.image1 || extractFirstImage(note.content) || "/img/default.jpg",
      alt: note.title,
      caption: note.title,
      fecha: `Publicado: ${new Date(note.created_at).toLocaleDateString("es-CO")}`,
      editor: note.editor || "Jhon Aparicio",
      source_scope: normalizeSourceScope(note.source_scope),
      sortDate: note.created_at ? new Date(note.created_at).getTime() : 0,
    }));
  }
} catch (err) {
  console.error("❌ Error cargando notas dinámicas:", err);
}

// 4️⃣ Notas estáticas (las que ya tenías)
const staticNotes = [
  {
    href: "/noticias-carrusel/noticia-ford",
    img: "/img/ford-bronco/ford-bronco-suspension.webp",
    alt: "Ford Bronco, SUV todo terreno",
    caption: "Ford Bronco: la última apuesta todoterreno.",
    fecha: "Publicado: 01/07/2025",
    source_scope: "nacional",
  },
  {
    href: "/noticias-carrusel/noticia-audi",
    img: "/img/audi-etron/audi-portada.webp",
    alt: "Audi E-TRON: SUV eléctrico de lujo",
    caption: "Audi E-TRON: el SUV eléctrico más elegante de la marca.",
    fecha: "Publicado: 28/06/2025",
    source_scope: "nacional",
  },
  {
    href: "/noticias-carrusel/noticia-bmw-concept",
    img: "/img/bmw-concept/bmw-concept-portada.webp",
    alt: "BMW Concept XM",
    caption: "BMW Concept XM: El Futuro del Lujo y la Potencia Híbrida",
    fecha: "Publicado: 25/06/2025",
    source_scope: "nacional",
  },
  {
    href: "/noticias-carrusel/noticia-bmw",
    img: "/img/bmw-330e/bmw.webp",
    alt: "BMW Serie 5 eléctrico y potente",
    caption: "BMW Serie 5: poderoso y ahora electrificado.",
    fecha: "Publicado: 20/06/2025",
    source_scope: "nacional",
  },
  {
    href: "/noticias-carrusel/noticia-dfsk",
    img: "/img/dfsk-e5/dfsk-ultima-portada.webp",
    alt: "DFSK E5: híbrida para 7 pasajeros",
    caption: "DFSK seres e5: la híbrida para 7 pasajeros en Colombia.",
    fecha: "Publicado: 15/06/2025",
    source_scope: "nacional",
  },
];

const staticNotesWithDate = staticNotes.map((note) => ({
  ...note,
  sortDate: parseDateValue(note.fecha),
}));

// 5️⃣ Combinamos dinámicas + estáticas, ordenamos y mostramos máximo 5
const allNotes = [...dynamicNotes, ...staticNotesWithDate]
  .sort((a, b) => b.sortDate - a.sortDate)
  .slice(0, HOME_VISIBLE_COUNT);
---

<section id="noticias" class="section-info w-full py-30">
  <div class="info-header">
    <h1 class="info-titulo anim-titulo">
      <!-- Botón Ver más noticias 
      <span class="icono-rueda">
        <i class="fa-solid fa-circle"></i>
      </span>-->
      Noticias
    </h1>
    <p class="info-descripcion">
      La actualidad del sector automotor colombiano: lanzamientos, regulaciones,
      tecnología y más.
    </p>
  </div>

  <div class="container mx-auto px-2">
    <div class="news-grid">
      {
        allNotes.map((nota, index) => (
          <>
            <article
              class={"news-card" + (index === 0 ? " news-card--featured" : "")}
            >
              <a href={nota.href} class="news-card-link">
                <div class="news-card-image">
                  <img
                    src={nota.img}
                    alt={nota.alt}
                    class="w-full h-full object-cover"
                    loading={index === 0 ? "eager" : "lazy"}
                    fetchpriority={index === 0 ? "high" : "auto"}
                    decoding="async"
                  />
                </div>
                <div class="news-card-content">
                  <div class="news-meta-tags">
                    <span
                      class={
                        "news-tag" + (index === 0 ? " news-tag--featured" : "")
                      }
                    >
                      {index === 0 ? "Destacado" : "Noticias"}
                    </span>
                    <span
                      class={
                        "scope-tag" +
                        (nota.source_scope === "internacional"
                          ? " scope-tag--international"
                          : " scope-tag--national") +
                        (index === 0 ? " scope-tag--featured" : "")
                      }
                    >
                      {sourceScopeLabel(nota.source_scope)}
                    </span>
                  </div>
                  <h3 class="news-title">{nota.caption}</h3>
                  <p class="news-date">
                    <i class="fa-regular fa-user" aria-hidden="true" />
                    <span class="meta-author">
                      {nota.editor || "Jhon Aparicio"}
                    </span>
                    <span class="meta-sep">•</span>
                    <i class="fa-regular fa-calendar" aria-hidden="true" />
                    <span class="meta-date">
                      {cleanPublishedDate(nota.fecha)}
                    </span>
                  </p>
                </div>
              </a>
            </article>
          </>
        ))
      }
      <article class="news-card news-card--insight">
        <div class="news-card-content">
          <span class="news-tag news-tag--insight">Radar del sector</span>
          <h3 class="news-title">
            Tendencias clave que estamos siguiendo esta semana
          </h3>
          <p class="news-date">
            Electromovilidad, ADAS y lanzamientos locales con foco en Colombia.
          </p>
          <a class="news-read-more" href="/tendencias-del-sector">
            Explorar tendencias →
          </a>
        </div>
      </article>
    </div>

    <!-- Botón Ver más noticias -->
    <div class="ver-mas-noticias-section">
      <a href="/noticias" class="ver-mas-noticias-btn">Ver más noticias</a>
    </div>
  </div>
</section>

<style>

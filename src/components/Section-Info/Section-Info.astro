      width: 4px;
      min-width: 4px;
      max-width: 4px;
      height: 1.1em;
      background: linear-gradient(180deg, #d4a742 0%, #2a2a2a 100%);
      border-radius: 999px;
    }

    .info-titulo::after {
      display: none;
    }

    .info-descripcion {
      display: none;
    }
  }

  .icono-rueda {
    display: inline-block;
    position: relative;
    width: 60px;
    height: 60px;
  }

  .icono-rueda i {
    display: block;
    width: 100%;
    height: 100%;
    border: 4px solid #d69a0c; /* aro exterior dorado */
    border-radius: 50%;
    background: radial-gradient(circle at center, #222 40%, #000 100%);
    position: relative;
    box-shadow:
      inset 0 0 10px #000,
      0 0 8px #d69a0c;
  }

  /* Divisiones tipo rayos del rin */
  .icono-rueda i::before,
  .icono-rueda i::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 55%;
    height: 3px;
    background-color: #d69a0c;
    transform-origin: center;
  }

  .icono-rueda i::before {
    transform: translate(-50%, -50%) rotate(0deg);
  }

  .icono-rueda i::after {
    transform: translate(-50%, -50%) rotate(60deg);
  }

  /* Creamos más divisiones con pseudo-elementos extra */
  .icono-rueda::before,
  .icono-rueda::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 55%;
    height: 3px;
    background-color: #d69a0c;
    transform-origin: center;
  }

  .icono-rueda::before {
    transform: translate(-50%, -50%) rotate(120deg);
  }

  .icono-rueda::after {
    transform: translate(-50%, -50%) rotate(180deg);
  }

  /* Efecto central tipo tuerca */
  .icono-rueda i span {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 12px;
    height: 12px;
    background: #d69a0c;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 4px #000 inset;
  }

  /* Efecto hover: giro del rin */
  .icono-rueda:hover i {
    animation: spin 2s linear infinite;
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  /* ⚙️ Ajuste en pantallas pequeñas */
  @media (max-width: 768px) {
    .icono-rueda {
      --tamano-rin: 45px; /* más pequeño */
    }

    .icono-rueda i {
      border-width: 2px;
      font-size: 0.6rem;
    }
  }


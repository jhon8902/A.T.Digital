      justify-content: flex-start;
      text-align: left;
      gap: 16px;
      font-size: clamp(2rem, 3.8vw, 2.5rem);
      letter-spacing: 2px;
    }

    .info-titulo::before {
      display: none;
    }

    .info-titulo::after {
      min-width: 110px;
    }

    .info-descripcion {
      max-width: 760px;
    }
  }

  @media (max-width: 600px) {

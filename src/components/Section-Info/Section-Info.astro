---
import { resolveSiteNotes, type SiteNote } from "../../lib/api";
import {
  getNewsCardDeck,
  getNewsCardTitle,
} from "../../lib/editorial";
import {
  formatNotePublishedLabel,
  getNotePublishTimestamp,
} from "../../lib/note-scheduling";

import { inferSourceScope } from "../../lib/notes-query";
import { isPublicEditorialNote } from "../../lib/pruebas-solo";
import {
  HOME_NEWS_CAROUSEL_LIMIT,
  HOME_NEWS_HERO_COUNT,
  HOME_NEWS_POOL_SIZE,
  HOME_NEWS_SCOPE_POOL_SIZE,
} from "../../lib/home-news-config";
import { sectorRadarPreview } from "../../lib/sector-radar";

interface Props {
  notes?: SiteNote[];
}

const { notes: prefetchedNotes } = Astro.props;
// --- CARGA Y FILTRO DE NOTAS RECIENTES PARA PORTADA ---

let dynamicNotes: any[] = [];
const HOME_NEWS_CATEGORIES = new Set([
  "noticias",
  "lanzamientos",
  "hibridos",
  "electricos",
  "deportes",
  "pruebas",
]);

function normalizeCategory(value?: string) {
  return (value || "")
    .toString()
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "");
}

function normalizeSourceScope(scope?: string) {
  return scope?.toLowerCase() === "internacional"
    ? "internacional"
    : "nacional";
}

function resolveNoteScope(note: {
  source_scope?: string;
  spec_origen?: string;
}) {
  return inferSourceScope(note);
}

function sourceScopeLabel(scope?: string) {
  return normalizeSourceScope(scope) === "internacional"
    ? "Internacional"
    : "Nacional";
}

function categoryLabel(category?: string) {
  const normalized = normalizeCategory(category);
  const labels: Record<string, string> = {
    lanzamientos: "Lanzamiento",
    electricos: "Eléctricos",
    hibridos: "Híbridos",
    deportes: "Deportes",
    pruebas: "Pruebas",
    noticias: "Noticias",
  };
  return labels[normalized] || "Noticias";
}

const HOME_NEWS_HERO_SLIDE_LIMIT =
  HOME_NEWS_HERO_COUNT + HOME_NEWS_CAROUSEL_LIMIT;

function cleanPublishedDate(value?: string) {
  return (value || "").replace(/^Publicado:\s*/i, "").trim();
}

function extractFirstImage(html?: string) {
  if (!html) return null;
  const match = html.match(/<img[^>]+src=["']([^"']+)["'][^>]*>/i);
  return match ? match[1] : null;
}

const MESES_ES: Record<string, string> = {
  ene: "01",
  enero: "01",
  feb: "02",
  febrero: "02",
  mar: "03",
  marzo: "03",
  abr: "04",
  abril: "04",
  may: "05",
  mayo: "05",
  jun: "06",
  junio: "06",
  jul: "07",
  julio: "07",
  ago: "08",
  agosto: "08",
  sep: "09",
  sept: "09",
  septiembre: "09",
  oct: "10",
  octubre: "10",
  nov: "11",
  noviembre: "11",
  dic: "12",
  diciembre: "12",
};

function parseDateValue(value?: string) {
  if (!value) return 0;

  const cleaned = value
    .replace(/^Publicado:\s*/i, "")
    .replace(/^Nota:\s*/i, "")
    .trim();

  const monthMap: Record<string, number> = {
    ene: 0,
    enero: 0,
    feb: 1,
    febrero: 1,
    mar: 2,
    marzo: 2,
    abr: 3,
    abril: 3,
    may: 4,
    mayo: 4,
    jun: 5,
    junio: 5,
    jul: 6,
    julio: 6,
    ago: 7,
    agosto: 7,
    sep: 8,
    septiembre: 8,
    oct: 9,
    octubre: 9,
    nov: 10,
    noviembre: 10,
    dic: 11,
    diciembre: 11,
  };

  const dayMonthMatch = cleaned.match(
    /^(\d{1,2})-([a-záéíóúüñ]+)(?:-(\d{4}))?$/i,
  );
  if (dayMonthMatch) {
    const [, dayRaw, monthRaw, yearRaw] = dayMonthMatch;
    const normalizedMonth = monthRaw
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "");
    const monthIndex = monthMap[normalizedMonth];
    if (Number.isInteger(monthIndex)) {
      const year = yearRaw ? Number(yearRaw) : 2025;
      return new Date(year, monthIndex, Number(dayRaw)).getTime();
    }
  }

  const direct = new Date(cleaned);
  if (!isNaN(direct.getTime())) return direct.getTime();

  const ddmmyyyy = cleaned.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  if (ddmmyyyy) {
    const [, dd, mm, yyyy] = ddmmyyyy;
    return new Date(`${yyyy}-${mm}-${dd}`).getTime();
  }

  return 0;
}

try {
  const data = await resolveSiteNotes(prefetchedNotes);

  if (data.length > 0) {
    // 2️⃣ Mostramos en portada lo más reciente de categorías editoriales
    const filtered = data.filter((note: any) =>
      HOME_NEWS_CATEGORIES.has(normalizeCategory(note.category)) &&
      isPublicEditorialNote(note),
    );

    // 3️⃣ Normalizamos formato para el carrusel
    dynamicNotes = filtered.map((note: any) => ({
      href: `/notas/${note.id}`,
      img: note.image1 || extractFirstImage(note.content) || "/img/default.jpg",
      alt: note.title,
      caption: note.title,
      subtitle: note.subtitle || "",
      fecha: formatNotePublishedLabel(note),
      editor: note.editor || "Jhon Aparicio",
      source_scope: resolveNoteScope(note),
      category: normalizeCategory(note.category),
      sortDate: getNotePublishTimestamp(note),
    }));
  }
} catch (err) {
  console.error("❌ Error cargando notas dinámicas:", err);
}

// 4️⃣ Notas estáticas (las que ya tenías)
const staticNotes = [
  {
    href: "/noticias-carrusel/noticia-ford",
    img: "/img/ford-bronco/ford-bronco-suspension.webp",
    alt: "Ford Bronco, SUV todo terreno",
    caption: "Ford Bronco: la última apuesta todoterreno.",
    fecha: "Publicado: 01/07/2025",
    source_scope: "nacional",
    category: "noticias",
  },
  {
    href: "/noticias-carrusel/noticia-audi",
    img: "/img/audi-etron/audi-portada.webp",
    alt: "Audi E-TRON: SUV eléctrico de lujo",
    caption: "Audi E-TRON: el SUV eléctrico más elegante de la marca.",
    fecha: "Publicado: 28/06/2025",
    source_scope: "nacional",
    category: "noticias",
  },
  {
    href: "/noticias-carrusel/noticia-bmw-concept",
    img: "/img/bmw-concept/bmw-concept-portada.webp",
    alt: "BMW Concept XM",
    caption: "BMW Concept XM: El Futuro del Lujo y la Potencia Híbrida",
    fecha: "Publicado: 25/06/2025",
    source_scope: "nacional",
    category: "noticias",
  },
  {
    href: "/noticias-carrusel/noticia-bmw",
    img: "/img/bmw-330e/bmw.webp",
    alt: "BMW Serie 5 eléctrico y potente",
    caption: "BMW Serie 5: poderoso y ahora electrificado.",
    fecha: "Publicado: 20/06/2025",
    source_scope: "nacional",
    category: "noticias",
  },
  {
    href: "/noticias-carrusel/noticia-dfsk",
    img: "/img/dfsk-e5/dfsk-ultima-portada.webp",
    alt: "DFSK E5: híbrida para 7 pasajeros",
    caption: "DFSK seres e5: la híbrida para 7 pasajeros en Colombia.",
    fecha: "Publicado: 15/06/2025",
    source_scope: "nacional",
    category: "noticias",
  },
];

const staticNotesWithDate = staticNotes.map((note) => ({
  ...note,
  sortDate: parseDateValue(note.fecha),
}));

// 5️⃣ Combinamos dinámicas + estáticas, ordenamos y mostramos máximo 5
function slugTitle(t?: string) {
  return (t || "")
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]/g, "");
}
const dynamicNotesTitles = new Set(
  dynamicNotes.map((n) => slugTitle(n.caption)),
);
const deduplicatedStaticNotes = staticNotesWithDate.filter(
  (n) => !dynamicNotesTitles.has(slugTitle(n.caption)),
);
const allCandidates = [...dynamicNotes, ...deduplicatedStaticNotes].sort(
  (a, b) => b.sortDate - a.sortDate,
);
const allNotes = allCandidates.slice(0, HOME_NEWS_POOL_SIZE);
const heroCarouselNotes = allNotes;

function buildScopeCarouselNotes(
  candidates: typeof allCandidates,
  limitPerScope = 24,
) {
  const nacionalNotes = candidates.filter(
    (note) => normalizeSourceScope(note.source_scope) === "nacional",
  );
  const internacionalNotes = candidates.filter(
    (note) => normalizeSourceScope(note.source_scope) === "internacional",
  );
  const merged = [
    ...internacionalNotes.slice(0, limitPerScope),
    ...nacionalNotes.slice(0, limitPerScope),
  ];
  const seen = new Set<string>();

  return merged.filter((note) => {
    if (seen.has(note.href)) return false;
    seen.add(note.href);
    return true;
  });
}

const scopeCarouselNotes = buildScopeCarouselNotes(
  allCandidates,
  HOME_NEWS_SCOPE_POOL_SIZE / 2,
);
---

<link rel="stylesheet" href="/css/news-interactive.css?v=42" />

<section
  id="noticias"
  class="section-info section-info--interactive w-full py-30"
  aria-labelledby="noticias-heading"
  data-hero-slide-limit={HOME_NEWS_HERO_SLIDE_LIMIT}
  data-carousel-limit={HOME_NEWS_CAROUSEL_LIMIT}
>
  <header class="info-header">
    <p class="noticias-eyebrow">Noticias</p>
    <h2 id="noticias-heading" class="info-titulo">Sector automotor</h2>
    <p class="noticias-home-lead">
      Lo más reciente que publicamos a diario: lanzamientos, fichas técnicas y
      cobertura del sector en un solo lugar.
    </p>
  </header>

  <div class="container mx-auto px-2">
    <div class="news-showcase">
      <div
        class="news-filters"
        role="tablist"
        aria-label="Filtrar noticias por alcance"
      >
        <button
          type="button"
          class="news-filter-btn is-active"
          data-filter="all"
          role="tab"
          aria-selected="true"
        >
          Todas
        </button>
        <button
          type="button"
          class="news-filter-btn"
          data-filter="nacional"
          role="tab"
          aria-selected="false"
        >
          Nacional
        </button>
        <button
          type="button"
          class="news-filter-btn"
          data-filter="internacional"
          role="tab"
          aria-selected="false"
        >
          Internacional
        </button>
      </div>

      {
        heroCarouselNotes.length > 0 && (
          <div
            class="news-hero-carousel"
            data-hero-carousel-root
            aria-roledescription="carrusel"
            aria-label="Noticias destacadas del sector automotor"
          >
            <div class="news-hero-carousel-toolbar">
              <p class="news-hero-carousel-status" aria-live="polite">
                <span class="news-hero-carousel-counter">1 / 1</span>
                <span class="news-hero-carousel-hint">
                  Desliza o usa las flechas para explorar
                </span>
              </p>
              <div class="news-carousel-nav">
                <button
                  type="button"
                  class="news-carousel-btn news-hero-carousel-btn--prev"
                  aria-label="Noticia anterior"
                >
                  <i class="fa-solid fa-chevron-left" aria-hidden="true" />
                </button>
                <button
                  type="button"
                  class="news-carousel-btn news-hero-carousel-btn--next"
                  aria-label="Noticia siguiente"
                >
                  <i class="fa-solid fa-chevron-right" aria-hidden="true" />
                </button>
              </div>
            </div>

            <div class="news-hero-carousel-viewport">
              <div class="news-hero-carousel-track news-hero-carousel-track--fade">
                {
                  heroCarouselNotes.map((nota, index) => (
                    <article
                      class:list={[
                        "news-hero",
                        "news-hero-carousel-slide",
                        { "is-active": index === 0 },
                      ]}
                      data-scope={normalizeSourceScope(nota.source_scope)}
                      data-category={nota.category || "noticias"}
                      data-carousel-index={index}
                      aria-roledescription="slide"
                    >
                      <a href={nota.href} class="news-hero__link">
                        <div class="news-hero__media">
                          <img
                            src={nota.img}
                            alt={nota.alt}
                            loading={index === 0 ? "eager" : "lazy"}
                            fetchpriority={index === 0 ? "high" : "auto"}
                            decoding="async"
                          />
                          <div class="news-meta-tags news-meta-tags--overlay">
                            <span class="news-tag">
                              {categoryLabel(nota.category)}
                            </span>
                            <span
                              class={
                                "scope-tag" +
                                (nota.source_scope === "internacional"
                                  ? " scope-tag--international"
                                  : " scope-tag--national")
                              }
                            >
                              {sourceScopeLabel(nota.source_scope)}
                            </span>
                          </div>
                        </div>
                        <div class="news-hero__body">
                          <h3 class="news-hero__title">
                            {getNewsCardTitle(nota.caption)}
                          </h3>
                          {
                            getNewsCardDeck(nota.caption, nota.subtitle) && (
                              <p class="news-hero__deck">
                                {getNewsCardDeck(nota.caption, nota.subtitle)}
                              </p>
                            )
                          }
                          <p class="news-date">
                            <i class="fa-regular fa-user" aria-hidden="true" />
                            <span>{nota.editor || "Jhon Aparicio"}</span>
                            <span class="meta-sep">•</span>
                            <i class="fa-regular fa-calendar" aria-hidden="true" />
                            <span>{cleanPublishedDate(nota.fecha)}</span>
                          </p>
                          <span class="news-hero__cta">Leer nota →</span>
                        </div>
                      </a>
                    </article>
                  ))
                }
              </div>
            </div>

            <div
              class="news-hero-carousel-dots"
              role="tablist"
              aria-label="Ir a una noticia"
            />
          </div>
        )
      }

      {
        scopeCarouselNotes.length > 0 && (
          <div
            class="news-carousel-wrap news-scope-carousel"
            data-scope-carousel-root
            hidden
          >
            <div class="news-carousel-header">
              <h3 class="news-carousel-heading">Noticias del sector</h3>
              <div class="news-carousel-nav">
                <button
                  type="button"
                  class="news-carousel-btn news-carousel-btn--prev"
                  aria-label="Noticia anterior"
                >
                  <i class="fa-solid fa-chevron-left" aria-hidden="true" />
                </button>
                <button
                  type="button"
                  class="news-carousel-btn news-carousel-btn--next"
                  aria-label="Noticia siguiente"
                >
                  <i class="fa-solid fa-chevron-right" aria-hidden="true" />
                </button>
              </div>
            </div>
            <div class="news-carousel">
              {
                scopeCarouselNotes.map((nota, index) => (
                  <article
                    class="news-carousel-card"
                    data-scope={normalizeSourceScope(nota.source_scope)}
                    data-category={nota.category || "noticias"}
                  >
                    <a href={nota.href} class="news-carousel-card__link">
                      <div class="news-carousel-card__image">
                        <img
                          src={nota.img}
                          alt={nota.alt}
                          loading="lazy"
                          decoding="async"
                        />
                      </div>
                      <div class="news-carousel-card__body">
                        <div class="news-meta-tags">
                          <span class="news-tag">
                            {categoryLabel(nota.category)}
                          </span>
                          <span
                            class={
                              "scope-tag" +
                              (nota.source_scope === "internacional"
                                ? " scope-tag--international"
                                : " scope-tag--national")
                            }
                          >
                            {sourceScopeLabel(nota.source_scope)}
                          </span>
                        </div>
                        <h4 class="news-carousel-card__title">
                          {getNewsCardTitle(nota.caption)}
                        </h4>
                        {
                          getNewsCardDeck(nota.caption, nota.subtitle) && (
                            <p class="news-carousel-card__deck">
                              {getNewsCardDeck(nota.caption, nota.subtitle)}
                            </p>
                          )
                        }
                        <p class="news-date">
                          <i class="fa-regular fa-calendar" aria-hidden="true" />
                          <span>{cleanPublishedDate(nota.fecha)}</span>
                        </p>
                      </div>
                    </a>
                  </article>
                ))
              }
            </div>
          </div>
        )
      }

      <p class="news-filter-empty" hidden>
        No hay noticias en este alcance por ahora.
      </p>

      <div class="ver-mas-noticias-section ver-mas-noticias-section--above-radar">
        <a href="/noticias" class="ver-mas-noticias-btn">Ver más noticias</a>
      </div>

      <article class="news-insight">
        <div class="news-card-content">
          <span class="news-tag">Radar del sector</span>
          <h3 class="news-title">
            {sectorRadarPreview.title}
          </h3>
          <p class="news-date">
            {sectorRadarPreview.summary}
          </p>
          <a class="news-read-more" href="/tendencias-del-sector">
            Explorar tendencias →
          </a>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .container {
    width: min(96%, 1760px);
    max-width: 1760px;
    margin: 0 auto; /* Centra el contenido */
    padding: 32px 20px;
    font-family: "Georgia", serif;
    background: #fff;
  }

  .section-info.section-info--interactive {
    background-color: #f0f3f0 !important;
    background-image: var(--home-relief-image);
    background-size: var(--home-relief-size);
    background-repeat: repeat;
  }

  .section-info--interactive .container {
    background: #fff !important;
  }

  .section-info--interactive .info-header {
    background: transparent !important;
  }

  .section-info--interactive .info-header .info-titulo {
    color: #08341f !important;
  }

  .section-info--interactive .info-header .noticias-home-lead {
    color: #5a6470 !important;
  }

  .section-info--interactive .info-header .info-titulo::before {
    background: linear-gradient(90deg, #000, #d4a742);
  }

  .section-info--interactive .info-header .info-titulo::after {
    background: linear-gradient(90deg, #d4a742, #000);
  }

  .section-info {
    width: 100%;
    margin: 0 auto;
    padding: 0;
    position: relative;
    overflow: hidden;
    scroll-margin-top: 5.5rem;
  }

  .section-info::before {
    content: "";
    position: absolute;
    top: -140px;
    right: -220px;
    width: 520px;
    height: 520px;

    pointer-events: none;
  }

  .info-header {
    background: transparent;
    padding: clamp(2.5rem, 5vw, 3.75rem) clamp(0.5rem, 1.25vw, 1rem)
      clamp(1.5rem, 3vw, 2.25rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.55rem;
    width: min(94%, 1700px);
    max-width: 1700px;
    margin: 0 auto;
  }

  .noticias-eyebrow {
    font-family: var(--font-body, "Source Sans 3", sans-serif);
    font-size: var(--home-eyebrow, 0.8125rem);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent, #e6b410);
    margin: 0 0 0.45rem;
  }

  .noticias-home-lead {
    font-family: var(--font-body, "Source Sans 3", sans-serif);
    font-size: var(--home-section-lead, 1.1rem);
    line-height: 1.65;
    color: #5a6470;
    max-width: 42rem;
    margin: 0.35rem auto 0;
    font-weight: 400;
  }

  .info-titulo {
    color: var(--color-brand, #08341f);
    font-size: var(--home-section-title, clamp(2.1rem, 3.2vw, 2.95rem));
    letter-spacing: 0.02em;
    font-family: var(--font-display, "Georgia", serif);
    text-transform: none;
    font-weight: 700;
    line-height: 1.1;
    text-shadow: none;
    opacity: 1;
    transform: translateY(0);
    transition: none;
    background: none;
    margin: 0 0 0.35rem;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
    width: 100%;
    min-height: 40px;
    max-width: 1480px;
    padding: 0;
  }

  .info-titulo::before {
    content: "";
    flex: 1;
    height: 2px;
    background: linear-gradient(90deg, #000, #d4a742);
    min-width: 0;
    max-width: 650px;
    opacity: 0;
    transform: scaleX(0.88);
    transform-origin: right center;
    animation: infoTituloLineIn 1.2s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 1.15s;
  }

  .info-titulo::after {
    content: "";
    flex: 1;
    height: 2px;
    background: linear-gradient(90deg, #d4a742, #000);
    min-width: 0;
    max-width: 650px;
    opacity: 0;
    transform: scaleX(0.88);
    transform-origin: left center;
    animation: infoTituloLineIn 1.2s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 1.28s;
  }

  @keyframes infoTituloLineIn {
    0% {
      opacity: 0;
      transform: scaleX(0.88);
    }
    100% {
      opacity: 1;
      transform: scaleX(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .info-titulo::before,
    .info-titulo::after {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  .info-descripcion {
    font-size: 1.3rem;
    color: #2f2f2f;
    font-family: "Georgia", serif;
    font-weight: 400;
    line-height: 1.6;
    max-width: 900px;
  }

  @media (max-width: 1024px) {
    .info-header {
      align-items: center;
      text-align: center;
      padding: 32px clamp(0.5rem, 2vw, 1rem) 24px;
    }

    .info-titulo {
      display: block;
      justify-content: center;
      text-align: center;
      gap: 0;
      font-size: clamp(2rem, 3.8vw, 2.5rem);
      letter-spacing: 0.02em;
    }

    .info-titulo::before,
    .info-titulo::after {
      display: none !important;
      content: none !important;
    }

    .info-descripcion {
      max-width: 760px;
    }
  }

  @media (max-width: 600px) {
    .info-header {
      padding: 20px 0 1.5rem;
      background: transparent;
      border-bottom: none;
      align-items: center;
      text-align: center;
    }

    .section-info--interactive .info-header {

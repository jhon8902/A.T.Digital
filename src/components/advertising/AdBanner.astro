---
interface Props {
  position?: string;
  inGrid?: boolean;
  variant?: "autotech" | "byd" | "toyota" | "mazda";
  href?: string;
}

const {
  position = "section",
  inGrid = false,
  variant = "autotech",
  href,
} = Astro.props;

const ads = {
  autotech: {
    brand: "AUTO-TECH-DIGITAL",
    title: "Tecnología, emoción y futuro del automóvil",
    subtitle:
      "Noticias, fichas técnicas y AutoMatch para encontrar tu próximo auto en Colombia.",
    cta: "Encontrar mi auto",
    bg: "#062818",
    image: "/img/autlogo2.png",
    textColor: "#ffffff",
    href: "/automatch-find",
    external: false,
  },
  byd: {
    brand: undefined as string | undefined,
    title: "BYD Sealion7 Electrico",
    subtitle: undefined as string | undefined,
    cta: "Conoce más",
    bg: "black",
    image: "/img/byd-sealion-7/byd-sealion7-principal.webp",
    textColor: "#ffffff",
    href: "/dashboard-concesionario",
    external: true,
  },
  toyota: {
    brand: "TOYOTA",
    title: "Nueva Land Cruiser Prado 2026",
    subtitle: "Potencia y tecnología sin límites",
    cta: "Descubre más",
    bg: "#f87171",
    image: "/img/toyota-prado/toyota-prado-copia1.webp",
    textColor: "#ffffff",
    href: "/dashboard-concesionario",
    external: true,
  },
  mazda: {
    brand: undefined as string | undefined,
    title: "Mazda EZ-6 Híbrido",
    subtitle: undefined as string | undefined,
    cta: "Ver detalles",
    bg: "black",
    image: "/img/mazda-ez6/mazda-ez6-diseño-portada.webp",
    textColor: "#ffffff",
    href: "/dashboard-concesionario",
    external: true,
  },
};

const currentAd = ads[variant];
const adHref = href ?? currentAd.href;
const isBrandBanner = variant === "autotech";
const isExternal =
  href?.startsWith("http") ?? ("external" in currentAd && currentAd.external);
---

<div
  class={`ad-container ad-${variant} ${inGrid ? "ad-in-grid" : "ad-section"}`}
  data-position={position}
>
  {
    isBrandBanner ? (
      <div class="ad-brand-banner">
        <div class="ad-brand-panel" aria-hidden="true">
          <img
            class="ad-logo"
            src={currentAd.image}
            alt="Auto-Tech-Digital"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="ad-copy-panel">
          <div class="ad-copy-inner">
            {currentAd.brand && (
              <span class="ad-brand">{currentAd.brand}</span>
            )}
            <h3 class="ad-title">
              Tecnología, emoción y{" "}
              <span class="ad-title-accent">futuro del automóvil</span>
            </h3>
            {currentAd.subtitle && (
              <p class="ad-subtitle">{currentAd.subtitle}</p>
            )}
            <a class="ad-cta ad-cta--brand" href={adHref}>
              {currentAd.cta} →
            </a>
          </div>
        </div>
      </div>
    ) : (
      <div
        class="ad-content"
        style={`background-color: ${currentAd.bg}; color: ${currentAd.textColor};`}
      >
        <img
          class="ad-car"
          src={currentAd.image}
          alt={currentAd.title}
          loading="lazy"
          decoding="async"
        />
        <div class="ad-banner">
          <div class="ad-text">
            {currentAd.brand && <span class="ad-brand">{currentAd.brand}</span>}
            {currentAd.subtitle && (
              <p class="ad-subtitle">{currentAd.subtitle}</p>
            )}
          </div>
          <div class="ad-cta-block">
            <h3 class="ad-title">{currentAd.title}</h3>
            <a
              class="ad-cta"
              href={adHref}
              {...(isExternal
                ? { target: "_blank", rel: "noopener noreferrer" }
                : {})}
            >
              {currentAd.cta} →
            </a>
          </div>
        </div>
      </div>
    )
  }
</div>

<style>
  .ad-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .ad-section {
    padding: 40px 20px;
    background: #f9f9f9;
    border-top: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
  }

  .ad-in-grid {
    grid-column: 1 / -1;
    padding: 18px;
    background: #f4f4f4;
    border-radius: 12px;
  }

  .ad-container.ad-autotech.ad-section {
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    padding: 0;
    background: transparent;
    border: none;
    align-items: stretch;
  }

  /* —— Brand banner (Auto-Tech-Digital) —— */
  .ad-brand-banner {
    display: grid;
    grid-template-columns: minmax(280px, 42%) 1fr;
    width: 100%;
    min-height: 300px;
    overflow: hidden;
    border-top: 1px solid rgba(240, 193, 74, 0.2);
  }

  .ad-brand-panel {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 32px;
    background: linear-gradient(165deg, #062818 0%, #08341f 52%, #0a4228 100%);
    position: relative;
    overflow: hidden;
  }

  .ad-brand-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 30% 40%,
      rgba(240, 193, 74, 0.12) 0%,
      transparent 55%
    );
    pointer-events: none;
  }

  .ad-logo {
    position: relative;
    z-index: 1;
    width: min(100%, 340px);
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 8px 20px rgba(0, 0, 0, 0.35));
  }

  .ad-copy-panel {
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, #041a10 0%, #062818 100%);
    color: #fff;
    padding: 40px clamp(28px, 4vw, 56px);
  }

  .ad-copy-inner {
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 560px;
  }

  .ad-container.ad-autotech .ad-brand {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #f0c14a;
    font-family: "Oswald", "Arial Narrow", sans-serif;
  }

  .ad-container.ad-autotech .ad-title {
    font-size: clamp(1.35rem, 2.4vw, 2rem);
    font-weight: 700;
    margin: 0;
    line-height: 1.25;
    color: #fff;
    font-family: "Playfair Display", "Times New Roman", serif;
    text-transform: none;
  }

  .ad-title-accent {
    color: #f0c14a;
  }

  .ad-container.ad-autotech .ad-subtitle {
    font-size: clamp(0.95rem, 1.4vw, 1.1rem);
    margin: 0;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.82);
    font-weight: 400;
    text-shadow: none;
  }

  .ad-cta--brand {
    align-self: flex-start;
    margin-top: 6px;
    background: #f0c14a;
    color: #08341f;
    border: 2px solid #f0c14a;
    padding: 12px 28px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    text-decoration: none;
    transition: all 0.25s ease;
    white-space: nowrap;
  }

  .ad-cta--brand:hover {
    background: #f8d066;
    border-color: #f8d066;
    color: #062818;
    transform: translateY(-1px);
  }

  /* —— Legacy car banners —— */
  .ad-content {
    position: relative;
    width: 100%;
    max-width: 1600px;
    min-height: 350px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-blend-mode: normal;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 10px 25px rgba(241, 240, 240, 0.15);
    border: 1px solid rgba(230, 12, 12, 0.25);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .ad-content::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.04);
    opacity: 1;
    pointer-events: none;
  }

  .ad-car {
    position: absolute;
    right: 30%;
    top: 50%;
    transform: translateY(-50%);
    width: 1200px;
    height: auto;
    object-fit: contain;
    z-index: 0;
    filter: drop-shadow(0 10px 18px rgba(0, 0, 0, 0.25));
    pointer-events: none;
    animation: slideInCar 0.8s ease-out forwards;
  }

  .ad-container.ad-mazda .ad-car {
    animation: slideInFromRight 0.8s ease-out forwards;
  }

  .ad-container.ad-byd .ad-car {
    animation: slideInFromLeft 0.8s ease-out forwards;
  }

  .ad-container.ad-toyota .ad-car {
    animation: slideInFromRight 0.8s ease-out forwards;
  }

  @keyframes slideInFromRight {
    from {
      opacity: 0;
      transform: translateY(-50%) translateX(600px);
    }
    to {
      opacity: 1;
      transform: translateY(-50%) translateX(0);
    }
  }

  @keyframes slideInFromLeft {
    from {
      opacity: 0;
      transform: translateY(-50%) translateX(-600px);
    }
    to {
      opacity: 1;
      transform: translateY(-50%) translateX(0);
    }
  }

  .ad-content:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.2);
  }

  .ad-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 40px 50px;
    gap: 30px;
    position: relative;
    z-index: 1;
  }

  .ad-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ad-brand {
    font-size: 30px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 0.9;
    font-family: "Oswald", "Arial Narrow", sans-serif;
  }

  .ad-title {
    font-size: 25px;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
    font-family: "Playfair Display", "Times New Roman", serif;
  }

  .ad-cta-block {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
  }

  .ad-content .ad-subtitle {
    font-size: 25px;
    margin: 0;
    opacity: 0.95;
    font-weight: 500;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
  }

  .ad-container.ad-byd .ad-brand {
    color: white;
    font-family: "Georgia", serif;
  }

  .ad-container.ad-byd .ad-title {
    color: white;
    text-transform: uppercase;
  }

  .ad-container.ad-toyota .ad-brand,
  .ad-container.ad-toyota .ad-title,
  .ad-container.ad-toyota .ad-subtitle {
    color: white;
    text-transform: uppercase;
  }

  .ad-container.ad-mazda .ad-brand {
    color: black;
    font-family: "Georgia", serif;
  }

  .ad-container.ad-mazda .ad-title {
    color: whitesmoke;
    text-transform: uppercase;
  }

  .ad-container.ad-mazda .ad-subtitle {
    color: rgb(14, 14, 14);
  }

  .ad-cta {
    background: white;
    color: rgb(35, 35, 35);
    border: 2px solid rgba(21, 21, 21, 0.85);
    padding: 12px 66px;
    display: block;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    text-decoration: none;
  }

  .ad-cta:hover {
    background: rgb(221, 220, 220);
    color: #1a1a1a;
    transform: translateY(-1px);
  }

  @media (max-width: 900px) {
    .ad-brand-banner {
      grid-template-columns: 1fr;
      min-height: auto;
      border-top: none;
    }

    .ad-brand-panel {
      padding: 32px 24px;
      min-height: 160px;
    }

    .ad-logo {
      width: min(100%, 260px);
    }

    .ad-copy-panel {
      padding: 28px 24px 32px;
    }

    .ad-copy-inner {
      align-items: center;
      text-align: center;
    }

    .ad-cta--brand {
      align-self: center;
    }
  }

  @media (max-width: 768px) {
    .ad-section {
      padding: 28px 16px;
    }

    .ad-container.ad-autotech.ad-section {
      padding: 0;
    }

    .ad-content {
      max-width: 100%;
      min-height: 350px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .ad-car {
      position: absolute;
      width: 100%;
      height: 100%;
      object-fit: cover;
      left: 0;
      right: 0;
      top: 0;
      bottom: 0;
      transform: translateX(0) !important;
      animation: none !important;
    }

    .ad-in-grid {
      padding: 16px;
    }

    .ad-banner {
      flex-direction: column;
      text-align: center;
      padding: 20px 18px;
      gap: 10px;
      position: absolute;
      top: 0;
      bottom: 0;
      width: 100%;
      left: 0;
      right: 0;
      display: flex;
      justify-content: space-between;
      background: linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0.6) 0%,
        transparent 30%,
        transparent 70%,
        rgba(0, 0, 0, 0.7) 100%
      );
    }

    .ad-text {
      order: 2;
      align-items: center;
      text-align: center;
    }

    .ad-cta-block {
      align-items: center;
      width: 100%;
      padding-top: 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
      order: 3;
    }

    .ad-banner .ad-title {
      font-size: 20px;
      order: 0;
      position: absolute;
      top: 20px;
      left: 0;
      right: 0;
      width: 100%;
      margin: 0;
    }

    .ad-banner .ad-subtitle {
      font-size: 13px;
    }

    .ad-cta {
      width: 100%;
      padding: 10px 10px;
    }
  }
</style>

---
interface Props {
  position?: string;
  inGrid?: boolean;
  variant?: "byd" | "toyota" | "mazda";
}

const { position = "section", inGrid = false, variant = "byd" } = Astro.props;

const ads = {
  byd: {
    brand: undefined as string | undefined,
    title: "BYD Sealion7 Electrico",
    subtitle: undefined as string | undefined,
    cta: "Conoce más",
    bg: "black",
    image: "/img/byd-sealion-7/byd-sealion7-principal.webp",
    textColor: "#ffffff",
  },
  toyota: {
    brand: "TOYOTA",
    title: "Nueva Land Cruiser Prado 2026",
    subtitle: "Potencia y tecnología sin límites",
    cta: "Descubre más",
    bg: "#f87171",
    image: "/img/toyota-prado/toyota-prado-copia1.jpg",
    textColor: "#ffffff",
  },
  mazda: {
    brand: undefined as string | undefined,
    title: "Mazda EZ-6 Híbrido",
    subtitle: undefined as string | undefined,
    cta: "Ver detalles",
    bg: "black",
    image: "/img/mazda-ez6/mazda-ez6-diseño-portada.webp",
    textColor: "#ffffff",
  },
};

const currentAd = ads[variant];
---

<div
  class={`ad-container ad-${variant} ${inGrid ? "ad-in-grid" : "ad-section"}`}
>
  {/* <div class="ad-label">Publicidad</div> */}
  <div
    class="ad-content"
    style={`background-color: ${currentAd.bg}; color: ${currentAd.textColor};`}
  >
    <img
      class="ad-car"
      src={currentAd.image}
      alt={currentAd.title}
      loading="lazy"
      decoding="async"
    />
    <div class="ad-banner">
      <div class="ad-text">
        {currentAd.brand && <span class="ad-brand">{currentAd.brand}</span>}
        {currentAd.subtitle && <p class="ad-subtitle">{currentAd.subtitle}</p>}
      </div>
      <div class="ad-cta-block">
        <h3 class="ad-title">{currentAd.title}</h3>
        <button class="ad-cta">{currentAd.cta} →</button>
      </div>
    </div>
  </div>
</div>

<style>
  .ad-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .ad-section {
    padding: 40px 20px;
    background: #f9f9f9;
    border-top: 1px solid #e5e5e5;
    border-bottom: 1px solid #e5e5e5;
  }

  .ad-in-grid {
    grid-column: 1 / -1;
    padding: 18px;
    background: #f4f4f4;
    border-radius: 12px;
  }

  .ad-label {
    font-size: 20px;
    color: #5b5b5b;
    text-transform: uppercase;
    letter-spacing: 2.4px;
    font-weight: 600;
    background: #f0f0f0;
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid #e2e2e2;
  }

  .ad-content {
    position: relative;
    width: 100%;
    max-width: 1600px;
    min-height: 350px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-blend-mode: normal;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 10px 25px rgba(241, 240, 240, 0.15);
    border: 1px solid rgba(230, 12, 12, 0.25);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .ad-content::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.04);
    opacity: 1;
    pointer-events: none;
  }

  .ad-car {
    position: absolute;
    right: 30%;
    top: 50%;
    transform: translateY(-50%);
    width: 1200px;
    height: auto;
    object-fit: contain;
    z-index: 0;
    filter: drop-shadow(0 10px 18px rgba(0, 0, 0, 0.25));
    pointer-events: none;
    animation: slideInCar 0.8s ease-out forwards;
  }

  /* Animación por defecto (derecha a izquierda - Mazda) */
  .ad-container.ad-mazda .ad-car {
    animation: slideInFromRight 0.8s ease-out forwards;
  }

  /* Animación para BYD (izquierda a derecha) */
  .ad-container.ad-byd .ad-car {
    animation: slideInFromLeft 0.8s ease-out forwards;
  }

  /* Animación para Toyota */
  .ad-container.ad-toyota .ad-car {
    animation: slideInFromRight 0.8s ease-out forwards;
  }

  @keyframes slideInFromRight {
    from {
      opacity: 0;
      transform: translateY(-50%) translateX(600px);
    }
    to {
      opacity: 1;
      transform: translateY(-50%) translateX(0);
    }
  }

  @keyframes slideInFromLeft {
    from {
      opacity: 0;
      transform: translateY(-50%) translateX(-600px);
    }
    to {
      opacity: 1;
      transform: translateY(-50%) translateX(0);
    }
  }

  .ad-content:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.2);
  }

  .ad-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 40px 50px;
    gap: 30px;
    position: relative;
    z-index: 1;
  }

  .ad-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ad-brand {
    font-size: 30px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 0.9;
    font-family: "Oswald", "Arial Narrow", sans-serif;
  }

  .ad-title {
    font-size: 25px;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
    font-family: "Playfair Display", "Times New Roman", serif;
  }

  .ad-cta-block {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
  }

  .ad-content .ad-subtitle {
    font-size: 25px;
    margin: 0;
    opacity: 0.95;
    font-weight: 500;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
  }

  .ad-container.ad-byd .ad-brand {
    color: white;
    font-family: "Georgia", serif;
  }

  .ad-container.ad-byd .ad-title {
    color: white;
    text-transform: uppercase;
  }

  .ad-container.ad-toyota .ad-brand,
  .ad-container.ad-toyota .ad-title,
  .ad-container.ad-toyota .ad-subtitle {
    color: white;
    text-transform: uppercase;
  }

  .ad-container.ad-mazda .ad-brand {
    color: black;
    font-family: "Georgia", serif;
  }

  .ad-container.ad-mazda .ad-title {
    color: whitesmoke;
    text-transform: uppercase;
  }

  .ad-container.ad-mazda .ad-subtitle {
    color: rgb(14, 14, 14);
  }

  .ad-cta {
    background: white;
    color: rgb(35, 35, 35);
    border: 2px solid rgba(21, 21, 21, 0.85);
    padding: 12px 66px;
    display: block;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 1.2px;
  }

  .ad-cta:hover {
    background: rgb(221, 220, 220);
    color: #1a1a1a;
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .ad-section {
      padding: 28px 16px;
    }

    .ad-content {
      max-width: 100%;
      min-height: 350px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .ad-car {
      position: absolute;
      width: 100%;
      height: 100%;
      object-fit: cover;
      left: 0;
      right: 0;
      top: 0;
      bottom: 0;
      transform: translateX(0) !important;
      animation: none !important;
    }

    .ad-in-grid {
      padding: 16px;
    }

    .ad-banner {
      flex-direction: column;
      text-align: center;
      padding: 20px 18px;
      gap: 10px;
      position: absolute;
      top: 0;
      bottom: 0;
      width: 100%;
      left: 0;
      right: 0;
      display: flex;
      justify-content: space-between;
      background: linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0.6) 0%,
        transparent 30%,
        transparent 70%,
        rgba(0, 0, 0, 0.7) 100%
      );
    }

    .ad-text {
      order: 2;
      align-items: center;
      text-align: center;
    }

    .ad-cta-block {
      align-items: center;
      width: 100%;
      padding-top: 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
      order: 3;
    }

    .ad-title {
      font-size: 20px;
      order: 0;
      position: absolute;
      top: 20px;
      left: 0;
      right: 0;
      width: 100%;
      margin: 0;
    }

    .ad-title h3 {
      padding: 0;
    }

    .ad-subtitle {
      font-size: 13px;
    }

    .ad-cta {
      width: 100%;
      padding: 10px 10px;
    }

    .ad-text {
      align-items: center;
      text-align: center;
    }
  }
</style>

  /* ========== RESPONSIVE ========== */
  @media (max-width: 1024px) {
    .cards {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .titulo {
      font-size: 2rem;
    }
  }

  @media (max-width: 768px) {
    .automatch-section {
      padding: 2rem 1rem;
      margin: 2rem 0;
      background: #ffffff;
    }

    .automatch-section h2 {
      font-size: 28px;
    }

    .titulo {
      font-size: 1.6rem;
      flex-direction: column;
      gap: 0.5rem;
    }

    .titulo::before,
    .titulo::after {
      display: none;
    }

    .automatch-section h2 {
      font-size: 1.6rem;
    }

    .automatch-section p {

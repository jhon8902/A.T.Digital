---
const { autos: incomingAutos = [], mode = "home" } = Astro.props;
const HOME_VISIBLE_COUNT = 3;

function stripHtml(input = "") {
  return String(input)
    .replace(/<[^>]*>/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

const normalizedIncoming = Array.isArray(incomingAutos)
  ? incomingAutos
      .map((auto, index) => {
        const images = Array.isArray(auto?.imagenes)
          ? auto.imagenes.filter(Boolean)
          : [];
        return {
          id: String(auto?.id ?? `auto-${index + 1}`),
          nombre: String(auto?.nombre || "AutoMatch"),
          descripcion: String(
            auto?.descripcion || stripHtml(auto?.content || ""),
          ),
          imagenes: images.length > 0 ? images : ["/img/default.jpg"],
          href: String(auto?.href || "/automatch-find"),
          toolHref: String(auto?.toolHref || "/automatch-find"),
          ctaLabel: String(auto?.ctaLabel || "Ver modelo"),
          toolCtaLabel: String(auto?.toolCtaLabel || "Usar AutoMatch"),
          catalogId: auto?.catalogId,
          noteId: auto?.noteId,
          condicion: String(auto?.condicion || "nuevo"),
        };
      })
      .filter((auto) => auto.nombre && auto.imagenes.length > 0)
  : [];

const mergedAutos = normalizedIncoming;

const autosToRender =
  mode === "archive" ? mergedAutos : mergedAutos.slice(0, HOME_VISIBLE_COUNT);

const catalogFilters = [
  { id: "todos", label: "Todos" },
  { id: "nuevo", label: "Nuevos" },
  { id: "seminuevo", label: "Seminuevos" },
  { id: "usado", label: "Usados" },
];

const searchCtaLabel = "Buscar auto para comprar";
---

{
  mode === "home" ? (
    <div class="automatch-home">
      <header class="automatch-hero">
        <p class="automatch-hero__eyebrow">Herramienta inteligente · Colombia</p>
        <h1 class="automatch-hero__title">
          Encuentra tu auto ideal con <span>AutoMatch</span>
        </h1>
        <p class="automatch-hero__lead">
          Compara autos nuevos, seminuevos y usados en Colombia. Elige cómo quieres
          empezar:
        </p>

        <div class="automatch-hero__paths">
          <div class="automatch-hero__path">
            <p class="automatch-hero__path-label">¿Ya sabes qué buscas?</p>
            <p class="automatch-hero__path-desc">
              Explora el catálogo con fotos, precios y datos de cada modelo.
            </p>
            <a
              href="#automatch-destacados"
              class="btn-automatch btn-automatch--ghost btn-automatch--path"
            >
              <i class="fa-solid fa-car-side" aria-hidden="true"></i>
              Explorar catálogo
            </a>
          </div>

          <div class="automatch-hero__path automatch-hero__path--accent">
            <p class="automatch-hero__path-label">¿Aún no?</p>
            <p class="automatch-hero__path-desc">
              Responde unas preguntas y te sugerimos opciones según tu perfil.
            </p>
            <a
              href="/automatch-find"
              class="btn-automatch btn-automatch--primary btn-automatch--hero btn-automatch--path"
            >
              <i class="fa-solid fa-sliders" aria-hidden="true"></i>
              {searchCtaLabel}
            </a>
            <p class="automatch-hero__path-note">Gratis · menos de 1 minuto</p>
          </div>
        </div>

      </header>

      <section
        class="automatch-section automatch-section--cards"
        id="automatch-destacados"
      >
        <h2 class="titulo titulo--cards">
          <i class="fas fa-car titulo-icon" aria-hidden="true"></i>
          Autos destacados
        </h2>
        <p class="subtitulo">
          Empieza por aquí si ya tienes una idea. Luego filtra por nuevo, seminuevo
          o usado en el catálogo completo.
        </p>

        <div class="cards">
          {
            autosToRender.map((auto: any) => (
              <article
              class="auto-card"
              data-id={auto.id}
              data-condicion={auto.condicion || "nuevo"}
            >
                <div class="auto-carousel-shell">
                  <div class="auto-carousel">
                    {(auto.imagenes as string[]).map((img, index) => (
                      <img
                        src={img}
                        alt={`${auto.nombre} — imagen ${index + 1}`}
                        class={`auto-img ${index === 0 ? "visible" : "hidden"}`}
                        loading="eager"
                        decoding="async"
                        fetchpriority={index === 0 ? "high" : "auto"}
                      />
                    ))}
                  </div>
                  <div class="carousel-meta-bar">
                    <div class="carousel-dots" aria-label="Navegacion de imagenes">
                      {(auto.imagenes as string[]).map((_, index) => (
                        <button
                          type="button"
                          class={`carousel-dot ${index === 0 ? "active" : ""}`}
                          data-index={String(index)}
                          aria-label={`Ir a la imagen ${index + 1}`}
                        />
                      ))}
                    </div>
                    <span class="carousel-counter">
                      1 / {(auto.imagenes as string[]).length}
                    </span>
                  </div>
                </div>

                <div class="auto-card-titlebar">
                  <button type="button" class="carousel-nav prev" aria-label="Imagen anterior">
                    <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
                  </button>
                  <h3>{auto.nombre}</h3>
                  <button type="button" class="carousel-nav next" aria-label="Imagen siguiente">
                    <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
                  </button>
                </div>

                <div class="auto-card-actions">
                  <a href={auto.href} class="auto-card-cta auto-card-cta--primary">
                    <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
                    {auto.ctaLabel}
                  </a>
                </div>
              </article>
            ))
          }
        </div>

        <div class="automatch-section__footer">
          <a href="/automatch/archivo" class="btn-automatch btn-automatch--primary btn-automatch--footer">
            <i class="fas fa-th-large" aria-hidden="true"></i>
            Ver catálogo completo
          </a>
          <a href="/automatch-find" class="btn-automatch btn-automatch--ver-mas">
            {searchCtaLabel}
            <i class="fas fa-arrow-right" aria-hidden="true"></i>
          </a>
        </div>
      </section>
    </div>
  ) : (
    <section class="automatch-section automatch-section--catalog">
      <h2 class="titulo">
        <i class="fas fa-car titulo-icon"></i>
        Catálogo de modelos
      </h2>
      <p class="subtitulo">
        Explora todos los autos disponibles en AutoMatch, filtrados por condición.
      </p>

      <div class="catalog-filters" role="tablist" aria-label="Filtrar por condición">
        {
          catalogFilters.map((filter, index) => (
            <button
              type="button"
              class={`catalog-filter ${index === 0 ? "is-active" : ""}`}
              data-filter={filter.id}
              role="tab"
              aria-selected={index === 0 ? "true" : "false"}
            >
              {filter.label}
            </button>
          ))
        }
      </div>

      <p class="catalog-empty" hidden>No hay modelos en esta categoría por ahora.</p>

      <div class="cards">
        {
          autosToRender.map((auto: any) => (
            <article
              class="auto-card"
              data-id={auto.id}
              data-condicion={auto.condicion || "nuevo"}
            >
              <div class="auto-carousel-shell">
                <div class="auto-carousel">
                  {(auto.imagenes as string[]).map((img, index) => (
                    <img
                      src={img}
                      alt={`${auto.nombre} — imagen ${index + 1}`}
                      class={`auto-img ${index === 0 ? "visible" : "hidden"}`}
                      loading="eager"
                      decoding="async"
                      fetchpriority={index === 0 ? "high" : "auto"}
                    />
                  ))}
                </div>
                <div class="carousel-meta-bar">
                  <div class="carousel-dots" aria-label="Navegacion de imagenes">
                    {(auto.imagenes as string[]).map((_, index) => (
                      <button
                        type="button"
                        class={`carousel-dot ${index === 0 ? "active" : ""}`}
                        data-index={String(index)}
                        aria-label={`Ir a la imagen ${index + 1}`}
                      />
                    ))}
                  </div>
                  <span class="carousel-counter">
                    1 / {(auto.imagenes as string[]).length}
                  </span>
                </div>
              </div>

              <div class="auto-card-titlebar">
                <button type="button" class="carousel-nav prev" aria-label="Imagen anterior">
                  <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
                </button>
                <h3>{auto.nombre}</h3>
                <button type="button" class="carousel-nav next" aria-label="Imagen siguiente">
                  <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
                </button>
              </div>

              <div class="auto-card-actions">
                <a href={auto.href} class="auto-card-cta auto-card-cta--primary">
                  <i class="fa-solid fa-file-lines" aria-hidden="true"></i>
                  {auto.ctaLabel}
                </a>
              </div>
            </article>
          ))
        }
      </div>

      {
        autosToRender.length === 0 && (
          <p class="subtitulo">Aún no hay más modelos para mostrar.</p>
        )
      }

      <div class="automatch-section__footer automatch-section__footer--catalog">
        <a href="/automatch-find" class="btn-automatch btn-automatch--primary btn-automatch--footer">
          <i class="fa-solid fa-sliders" aria-hidden="true"></i>
          {searchCtaLabel}
        </a>
        <a href="/" class="btn-automatch btn-automatch--ver-mas">
          Volver al inicio
          <i class="fas fa-arrow-left" aria-hidden="true"></i>
        </a>
      </div>
    </section>
  )
}

<style>
  /* ========== HERO HOME ========== */
  .automatch-home {
    width: 100%;
  }

  .automatch-hero {
    text-align: center;
    padding: clamp(2.25rem, 4.5vw, 3.5rem) clamp(1rem, 4vw, 2rem)
      clamp(2.5rem, 4vw, 3rem);
    color: #fff;
    position: relative;
    background:
      radial-gradient(ellipse 80% 60% at 50% -10%, rgba(230, 180, 16, 0.18), transparent),
      linear-gradient(165deg, #062818 0%, #08341f 45%, #0a4228 100%);
    border-bottom: none;
  }

  .automatch-hero__eyebrow {
    font-family: var(--font-body, "Source Sans 3", sans-serif);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #f0c14a;
    margin: 0 0 0.85rem;
  }

  .automatch-hero__title {
    font-family: var(--font-editorial, "Georgia", serif);
    font-size: clamp(2rem, 4.5vw, 3.35rem);
    font-weight: 700;
    line-height: 1.12;
    margin: 0 auto 1rem;
    max-width: 18ch;
    letter-spacing: 0.01em;
    color: #ffffff !important;
  }

  .automatch-hero__title span {
    color: #f0c14a !important;
  }

  .automatch-hero__lead {
    font-family: var(--font-body, "Source Sans 3", sans-serif);
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.88);
    max-width: 42rem;
    margin: 0 auto 1.75rem;
  }

  .automatch-hero__paths {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    max-width: 52rem;
    margin: 0 auto;
    text-align: left;
  }

  .automatch-hero__path {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 1.15rem 1.2rem 1.25rem;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.06);
  }

  .automatch-hero__path--accent {
    border-color: rgba(240, 193, 74, 0.45);
    background: rgba(240, 193, 74, 0.08);
  }

  .automatch-hero__path-label {
    margin: 0;
    font-size: 1.02rem;
    font-weight: 700;
    color: #f0c14a;
    font-family: var(--font-body, "Source Sans 3", sans-serif);
  }

  .automatch-hero__path-desc {
    margin: 0 0 0.35rem;
    font-size: 0.94rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.86);
    flex: 1;
  }

  .automatch-hero__path-note {
    margin: 0.15rem 0 0;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.65);
  }

  .btn-automatch--path {
    width: 100%;
    justify-content: center;
    margin-top: auto;
  }

  .automatch-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.85rem 1rem;
  }

  .btn-automatch--hero {
    padding: 1rem 1.85rem;
    font-size: 1.02rem;
    background: #f0c14a;
    color: #08341f;
    border-color: #f0c14a;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.22);
  }

  .btn-automatch--hero:hover {
    background: #ffd966;
    border-color: #ffd966;
    color: #062818;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.28);
  }

  .btn-automatch--ghost {
    padding: 0.95rem 1.35rem;
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.55);
    text-decoration: none;
    text-transform: none;
    letter-spacing: 0.02em;
    font-weight: 600;
    box-shadow: none;
  }

  .btn-automatch--ghost:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.85);
    color: #fff;
    transform: translateY(-1px);
  }

  .btn-automatch--ghost.btn-automatch--path {
    margin-top: auto;
  }

  #automatch-destacados {
    scroll-margin-top: 6rem;
  }

  .automatch-section--cards {
    margin: 0;
    border-radius: 0;
    box-shadow: none;
    background: transparent;
    padding-top: clamp(2rem, 4vw, 2.75rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
    animation: none;
  }

  .titulo--cards {
    font-size: clamp(1.65rem, 2.5vw, 2.1rem);
  }

  /* ========== SECCIÓN AUTOMATCH PRINCIPAL ========== */

  .automatch-section {
    text-align: center;
    padding: 3rem 1rem;
    background: #ffffff;
    border-radius: 1.2rem;
    margin: 3rem 0;
    font-size: 1.4rem;
    box-shadow: 0 8px 32px rgba(225, 163, 7, 0.1);
    animation: slideInSection 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes slideInSection {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .automatch-section h2 {
    font-size: 3.2rem;
    color: #08341f;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .automatch-section p {
    color: #1f1f1f;
    font-size: 1.4rem;
    margin-bottom: 2rem;
  }

  /* ========== TÍTULO CON LÍNEAS ========== */
  .titulo {
    font-size: 2.4rem;
    font-weight: 700;
    color: #02350f;
    margin-bottom: 0.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
  }

  .titulo-icon {
    font-size: 2rem;
    color: #08341f;
    opacity: 0.85;
  }

  .titulo::before,
  .titulo::after {
    content: "";
    flex: 1;
    height: 2px;
    background-color: #1b5e3f;
    max-width: 650px;
  }

  .subtitulo {
    color: #555;
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  /* ========== GRID DE TARJETAS ========== */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    font-size: 1.1rem;
    text-align: start;
    margin-bottom: 2rem;
  }

  .auto-card {
    background: transparent;
    border-radius: 0;
    box-shadow: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    transition:
      transform 0.35s,
      box-shadow 0.35s;
    border: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    position: relative;
    isolation: isolate;
  }

  .auto-card::before {
    content: none;
  }

  .auto-card-titlebar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    margin: 0.15rem 0 0.45rem;
    padding: 0 0.35rem;
  }

  .auto-card-titlebar h3 {
    margin: 0;
    color: #111;
    text-transform: uppercase;
    font-weight: 700;
    font-size: 1.1rem;
    line-height: 1.22;
    text-align: center;
    letter-spacing: 0.03em;
    flex: 0 1 auto;
    max-width: calc(100% - 5.75rem);
  }

  @media (min-width: 900px) {
    .auto-card-titlebar {
      gap: 0.8rem;
      margin: 0.2rem 0 0.5rem;
    }

    .auto-card-titlebar h3 {
      font-size: 1.28rem;
      max-width: none;
    }
  }

  .auto-card-actions {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    margin-top: 0;
  }

  .auto-card-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    padding: 0.62rem 1rem;
    border-radius: 999px;
    font-size: 0.92rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }

  .auto-card-cta--primary {
    background: #08341f;
    color: #fff;
  }

  .auto-card-cta--primary:hover {
    background: #0a4228;
    transform: translateY(-1px);
  }

  .auto-card-cta--secondary {
    background: transparent;
    color: #08341f;
    border: 1.5px solid #08341f;
  }

  .auto-card-cta--secondary:hover {
    background: rgba(8, 52, 31, 0.06);
    transform: translateY(-1px);
  }

  @media (prefers-reduced-motion: reduce) {
    .auto-img.entering {
      animation: none;
    }
  }

  .auto-card:hover {
    transform: translateY(-10px) scale(1.01);
    box-shadow: none;
    background: transparent;
  }

  /* ========== CARRUSEL DE IMÁGENES ========== */
  .auto-carousel-shell {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background: #0f1f17;
    margin-bottom: 0.75rem;
  }

  .auto-carousel-shell::after {
    content: "";
    position: absolute;
    inset: auto 0 0;
    height: 3.5rem;
    background: linear-gradient(to top, rgba(8, 20, 14, 0.62), transparent);
    z-index: 2;
    pointer-events: none;
  }

  .auto-carousel {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 2;
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: skeleton-loading 1.5s infinite;
  }

  @keyframes skeleton-loading {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  .auto-carousel.loaded {
    background: none;
    animation: none;
  }

  .auto-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 12px;
    object-fit: cover;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .auto-img.visible {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    z-index: 1;
  }

  .auto-img.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .auto-img.entering {
    animation: autoImageIn 0.52s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @keyframes autoImageIn {
    0% {
      opacity: 0.25;
      transform: translateY(6px) scale(1.03);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .carousel-nav {
    position: static;
    flex: 0 0 auto;
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid #3d6b57;
    border-radius: 50%;
    padding: 0;
    cursor: pointer;
    color: #3d6b57;
    background: #fff;
    box-shadow: 0 2px 8px rgba(42, 92, 69, 0.12);
    transform: none;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .carousel-nav i {
    font-size: 0.9rem;
    font-weight: 700;
  }

  .carousel-nav:hover {
    background: linear-gradient(135deg, #3d6b57 0%, #2f5f4c 100%);
    color: #fff;
    border-color: #3d6b57;
    transform: scale(1.06);
    box-shadow: 0 4px 14px rgba(42, 92, 69, 0.24);
  }

  .carousel-nav:active {
    transform: scale(0.96);
  }

  .carousel-meta-bar {
    position: absolute;
    bottom: 0.55rem;
    left: 0;
    right: 0;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0;
    padding: 0 0.65rem;
    pointer-events: none;
  }

  .carousel-dots {
    display: flex;
    align-items: center;
    gap: 0.42rem;
    pointer-events: auto;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    border: none;
    background: rgba(255, 255, 255, 0.45);
    cursor: pointer;
    transition:
      width 0.2s ease,
      background-color 0.2s ease,
      opacity 0.2s ease;
    opacity: 0.95;
    padding: 0;
  }

  .carousel-dot:hover {
    background: rgba(255, 255, 255, 0.72);
  }

  .carousel-dot.active {
    width: 22px;
    background: #e6b410;
    opacity: 1;
  }

  .carousel-counter {
    font-family: var(--font-body, "Source Sans 3", sans-serif);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #fff;
    background: rgba(8, 52, 31, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    padding: 0.28rem 0.62rem;
    white-space: nowrap;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    pointer-events: auto;

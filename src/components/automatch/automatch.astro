  .automatch-section--finder {
    margin-top: 1rem;
    padding-top: 2.35rem;
    position: relative;
  }

  .automatch-section--finder::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(460px, 74%);
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(27, 94, 63, 0) 0%,
      rgba(27, 94, 63, 0.35) 50%,

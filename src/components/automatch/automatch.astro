---
const { autos: incomingAutos = [], mode = "home" } = Astro.props;
const HOME_VISIBLE_COUNT = 3;

function stripHtml(input = "") {
  return String(input)
    .replace(/<[^>]*>/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function toSingleLine(text = "", max = 96) {
  const clean = stripHtml(text) || "Informacion destacada del modelo.";
  if (clean.length <= max) {
    return clean;
  }

  const cutAt = clean.lastIndexOf(" ", max);
  const safeCut = cutAt > 20 ? cutAt : max;
  return `${clean.slice(0, safeCut).trim()}...`;
}

function parseAutomatchMeta(content = "") {
  const match = String(content).match(/AUTOMATCH_META:([^>]*)-->/i);
  if (!match || !match[1]) return {};

  try {
    const decoded = decodeURIComponent(match[1].trim());
    const parsed = JSON.parse(decoded);
    return parsed?.texts && typeof parsed.texts === "object"
      ? parsed.texts
      : {};
  } catch (_error) {
    return {};
  }
}

const slideTopics = [
  "Vista exterior principal",
  "Perfil y presencia lateral",
  "Detalles de diseno",
  "Interior y cabina",
  "Espacio y practicidad",
  "Tecnologia y conectividad",
];

const normalizedIncoming = Array.isArray(incomingAutos)
  ? incomingAutos
      .map((auto, index) => {
        const images = Array.isArray(auto?.imagenes)
          ? auto.imagenes.filter(Boolean)
          : [];
        return {
          id: String(auto?.id ?? `auto-${index + 1}`),
          nombre: String(auto?.nombre || "AutoMatch"),
          descripcion: String(
            auto?.descripcion || stripHtml(auto?.content || "Sin descripcion"),
          ),
          metaTexts: parseAutomatchMeta(auto?.content || ""),
          imagenes: images.length > 0 ? images : ["/img/default.jpg"],
          href: String(auto?.href || "/automatch-find"),
          ctaLabel: String(auto?.ctaLabel || "Ver en AutoMatch"),
          catalogId: auto?.catalogId,
          noteId: auto?.noteId,
        };
      })
      .filter((auto) => auto.nombre && auto.imagenes.length > 0)
  : [];

const mergedAutos = normalizedIncoming;

const autosToRender =
  mode === "archive"
    ? mergedAutos.slice(HOME_VISIBLE_COUNT)
    : mergedAutos.slice(0, HOME_VISIBLE_COUNT);

const autosWithTexts = autosToRender.map((auto: any) => {
  const firstSlideText = toSingleLine(auto.descripcion, 98);

  const texts = (auto.imagenes as string[]).map((_, index) => {
    if (index === 0) {
      return {
        line1: firstSlideText,
      };
    }

    const key = `img${index + 1}`;
    const custom = auto?.metaTexts?.[key] || {};
    const customLine1 = stripHtml(custom?.line1 || "");
    const customLine2 = stripHtml(custom?.line2 || "");

    return {
      line1:
        customLine1 ||
        slideTopics[index % slideTopics.length] ||
        "Detalle destacado del modelo",
    };
  });

  return {
    ...auto,
    texts,
  };
});

const hasMoreAutos = mergedAutos.length > HOME_VISIBLE_COUNT;
---

{
  mode === "home" ? (
    <div class="automatch-home">
      <header class="automatch-hero">
        <p class="automatch-hero__eyebrow">Herramienta inteligente · Colombia</p>
        <h1 class="automatch-hero__title">
          Encuentra tu auto ideal con <span>AutoMatch</span>
        </h1>
        <p class="automatch-hero__lead">
          Cuéntanos cómo usas el carro, tu presupuesto y tu ciudad. Te mostramos
          modelos reales en Colombia y te conectamos con un asesor para test drive.
        </p>
        <div class="automatch-hero__actions">
          <a href="/automatch-find" class="btn-automatch btn-automatch--primary btn-automatch--hero">
            <i class="fa-solid fa-sliders" aria-hidden="true"></i>
            Encontrar mi auto
          </a>
          <a href="#automatch-fichas" class="btn-automatch btn-automatch--ghost">
            Ver fichas destacadas
          </a>
        </div>
      </header>

      <section class="automatch-section automatch-section--cards" id="automatch-fichas">
        <h2 class="titulo titulo--cards">
          <i class="fas fa-car titulo-icon" aria-hidden="true"></i>
          Fichas destacadas
        </h2>
        <p class="subtitulo">
          Explora modelos con galería, datos clave y enlace directo a la herramienta.
        </p>

        <div class="cards">
          {
            autosWithTexts.map((auto: any) => (
              <article class="auto-card" data-id={auto.id}>
                <div class="auto-carousel-shell">
                  <div class="auto-carousel">
                    {(auto.imagenes as string[]).map((img, index) => (
                      <img
                        src={img}
                        alt={`${auto.nombre} — imagen ${index + 1}`}
                        class={`auto-img ${index === 0 ? "visible" : "hidden"}`}
                        loading="eager"
                        decoding="async"
                        fetchpriority={index === 0 ? "high" : "auto"}
                      />
                    ))}
                  </div>
                  <button type="button" class="carousel-nav prev" aria-label="Imagen anterior">
                    <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
                  </button>
                  <button type="button" class="carousel-nav next" aria-label="Imagen siguiente">
                    <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
                  </button>
                  <div class="carousel-overlay-bar">
                    <div class="carousel-dots" aria-label="Navegacion de imagenes">
                      {(auto.imagenes as string[]).map((_, index) => (
                        <button
                          type="button"
                          class={`carousel-dot ${index === 0 ? "active" : ""}`}
                          data-index={String(index)}
                          aria-label={`Ir a la imagen ${index + 1}`}
                        />
                      ))}
                    </div>
                    <span class="carousel-counter">
                      1 / {(auto.imagenes as string[]).length}
                    </span>
                  </div>
                </div>

                <h3>{auto.nombre}</h3>
                <div class="auto-info">
                  {auto.texts.map((text: any, index: number) => (
                    <p class={`auto-texto ${index === 0 ? "visible" : "hidden"}`}>
                      <span class="auto-texto-linea">{text.line1}</span>
                    </p>
                  ))}
                </div>
                <a href={auto.href} class="auto-card-cta">
                  <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
                  {auto.ctaLabel}
                </a>
              </article>
            ))
          }
        </div>

        {
          hasMoreAutos && (
            <div class="ver-mas-automatch-container">
              <a href="/automatch" class="btn-automatch btn-automatch--secondary">
                <i class="fas fa-arrow-right" aria-hidden="true"></i> Ver mas AutoMatch
              </a>
            </div>
          )
        }
      </section>
    </div>
  ) : (
    <section class="automatch-section">
      <h2 class="titulo">
        <i class="fas fa-car titulo-icon"></i>
        Mas contenido AutoMatch
      </h2>
      <p class="subtitulo">
        Listado de fichas AutoMatch con el mismo formato de tarjetas y carrusel.
      </p>

      <div class="cards">
        {
          autosWithTexts.map((auto: any) => (
            <article class="auto-card" data-id={auto.id}>
              <div class="auto-carousel-shell">
                <div class="auto-carousel">
                  {(auto.imagenes as string[]).map((img, index) => (
                    <img
                      src={img}
                      alt={`${auto.nombre} — imagen ${index + 1}`}
                      class={`auto-img ${index === 0 ? "visible" : "hidden"}`}
                      loading="eager"
                      decoding="async"
                      fetchpriority={index === 0 ? "high" : "auto"}
                    />
                  ))}
                </div>
                <button type="button" class="carousel-nav prev" aria-label="Imagen anterior">
                  <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
                </button>
                <button type="button" class="carousel-nav next" aria-label="Imagen siguiente">
                  <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
                </button>
                <div class="carousel-overlay-bar">
                  <div class="carousel-dots" aria-label="Navegacion de imagenes">
                    {(auto.imagenes as string[]).map((_, index) => (
                      <button
                        type="button"
                        class={`carousel-dot ${index === 0 ? "active" : ""}`}
                        data-index={String(index)}
                        aria-label={`Ir a la imagen ${index + 1}`}
                      />
                    ))}
                  </div>
                  <span class="carousel-counter">
                    1 / {(auto.imagenes as string[]).length}
                  </span>
                </div>
              </div>

              <h3>{auto.nombre}</h3>
              <div class="auto-info">
                {auto.texts.map((text: any, index: number) => (
                  <p class={`auto-texto ${index === 0 ? "visible" : "hidden"}`}>
                    <span class="auto-texto-linea">{text.line1}</span>
                  </p>
                ))}
              </div>
              <a href={auto.href} class="auto-card-cta">
                <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
                {auto.ctaLabel}
              </a>
            </article>
          ))
        }
      </div>

      {
        autosToRender.length === 0 && (
          <p class="subtitulo">Aun no hay mas fichas para mostrar.</p>
        )
      }
    </section>
  )
}

<style>
  /* ========== HERO HOME ========== */
  .automatch-home {
    width: 100%;
  }

  .automatch-hero {
    text-align: center;
    padding: clamp(2.5rem, 5vw, 4rem) clamp(1rem, 4vw, 2rem)
      clamp(2rem, 4vw, 3rem);
    color: #fff;
    background:
      radial-gradient(ellipse 80% 60% at 50% -10%, rgba(230, 180, 16, 0.18), transparent),
      linear-gradient(165deg, #062818 0%, #08341f 45%, #0a4228 100%);
    border-bottom: 1px solid rgba(230, 180, 16, 0.2);
  }

  .automatch-hero__eyebrow {
    font-family: var(--font-body, "Source Sans 3", sans-serif);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #f0c14a;
    margin: 0 0 0.85rem;
  }

  .automatch-hero__title {
    font-family: var(--font-editorial, "Georgia", serif);
    font-size: clamp(2rem, 4.5vw, 3.35rem);
    font-weight: 700;
    line-height: 1.12;
    margin: 0 auto 1rem;
    max-width: 18ch;
    letter-spacing: 0.01em;
    color: #ffffff !important;
  }

  .automatch-hero__title span {
    color: #f0c14a !important;
  }

  .automatch-hero__lead {
    font-family: var(--font-body, "Source Sans 3", sans-serif);
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.88);
    max-width: 42rem;
    margin: 0 auto 1.75rem;
  }

  .automatch-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.85rem 1rem;
  }

  .btn-automatch--hero {
    padding: 1rem 1.85rem;
    font-size: 1.02rem;
    background: #f0c14a;
    color: #08341f;
    border-color: #f0c14a;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.22);
  }

  .btn-automatch--hero:hover {
    background: #ffd966;
    border-color: #ffd966;
    color: #062818;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.28);
  }

  .btn-automatch--ghost {
    padding: 0.95rem 1.35rem;
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.55);
    text-decoration: none;
    text-transform: none;
    letter-spacing: 0.02em;
    font-weight: 600;
    box-shadow: none;
  }

  .btn-automatch--ghost:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.85);
    color: #fff;
    transform: translateY(-1px);
  }

  #automatch-fichas {
    scroll-margin-top: 6rem;
  }

  .automatch-section--cards {
    margin: 0;
    border-radius: 0;
    box-shadow: none;
    background: #f4f5f7;
    padding-top: clamp(2rem, 4vw, 2.75rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }

  .titulo--cards {
    font-size: clamp(1.65rem, 2.5vw, 2.1rem);
  }

  /* ========== SECCIÓN AUTOMATCH PRINCIPAL ========== */

  .automatch-section {
    text-align: center;
    padding: 3rem 1rem;
    background: #ffffff;
    border-radius: 1.2rem;
    margin: 3rem 0;
    font-size: 1.4rem;
    box-shadow: 0 8px 32px rgba(225, 163, 7, 0.1);
    animation: slideInSection 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes slideInSection {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .automatch-section h2 {
    font-size: 3.2rem;
    color: #08341f;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .automatch-section p {
    color: #1f1f1f;
    font-size: 1.4rem;
    margin-bottom: 2rem;
  }

  /* ========== TÍTULO CON LÍNEAS ========== */
  .titulo {
    font-size: 2.4rem;
    font-weight: 700;
    color: #02350f;
    margin-bottom: 0.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
  }

  .titulo-icon {
    font-size: 2rem;
    color: #08341f;
    opacity: 0.85;
  }

  .titulo::before,
  .titulo::after {
    content: "";
    flex: 1;
    height: 2px;
    background-color: #1b5e3f;
    max-width: 650px;
  }

  .subtitulo {
    color: #555;
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  /* ========== GRID DE TARJETAS ========== */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    font-size: 1.1rem;
    text-align: start;
    margin-bottom: 2rem;
  }

  .auto-card {
    background: transparent;
    border-radius: 0;
    box-shadow: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    transition:
      transform 0.35s,
      box-shadow 0.35s;
    border: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    position: relative;
    isolation: isolate;
  }

  .auto-card::before {
    content: none;
  }

  .auto-card h3 {
    margin: 0.9rem 0 0.5rem;
    color: black;
    text-transform: uppercase;
    font-weight: 600;
  }

  .auto-card p {
    margin: 0;
    line-height: 1.5;
    min-height: 3em;
    color: #000;
  }

  .auto-info {
    min-height: 2.2em;
    margin-bottom: 0.35rem;
  }

  .auto-card-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    margin-top: 0.65rem;
    padding: 0.62rem 1rem;
    border-radius: 999px;
    background: #08341f;
    color: #fff;
    font-size: 0.92rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.15s ease, background 0.15s ease;
  }

  .auto-card-cta:hover {
    background: #0a4228;
    transform: translateY(-1px);
  }

  .auto-texto {
    margin: 0;
    color: #000;
  }

  .auto-texto.hidden {
    display: none;
  }

  .auto-texto.visible {
    display: block;
  }

  .auto-texto-linea {
    display: block;
    line-height: 1.35;
  }

  .auto-texto.entering {
    animation: autoTextIn 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @keyframes autoTextIn {
    0% {
      opacity: 0;
      transform: translateY(14px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .auto-texto.entering {
      animation: none;
    }

    .auto-img.entering {
      animation: none;
    }
  }

  .auto-card:hover {
    transform: translateY(-10px) scale(1.01);
    box-shadow: none;
    background: transparent;
  }

  /* ========== CARRUSEL DE IMÁGENES ========== */
  .auto-carousel-shell {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background: #0f1f17;
    margin-bottom: 0.85rem;
  }

  .auto-carousel {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 2;
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: skeleton-loading 1.5s infinite;
  }

  @keyframes skeleton-loading {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  .auto-carousel.loaded {
    background: none;
    animation: none;
  }

  .auto-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 12px;
    object-fit: cover;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .auto-img.visible {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    z-index: 1;
  }

  .auto-img.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .auto-img.entering {
    animation: autoImageIn 0.52s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @keyframes autoImageIn {
    0% {
      opacity: 0.25;
      transform: translateY(6px) scale(1.03);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .carousel-nav {
    position: absolute;
    top: 50%;
    z-index: 4;
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 50%;
    padding: 0;
    cursor: pointer;
    color: #fff;
    background: rgba(8, 52, 31, 0.78);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.28);
    transform: translateY(-50%);
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      box-shadow 0.2s ease,
      opacity 0.2s ease;
    opacity: 0.94;
  }

  .carousel-nav i {
    font-size: 0.95rem;
  }

  .carousel-nav.prev {
    left: 12px;
  }

  .carousel-nav.next {
    right: 12px;
  }

  .auto-carousel-shell:hover .carousel-nav,
  .auto-carousel-shell:focus-within .carousel-nav {
    opacity: 1;
  }

  .carousel-nav:hover {
    background: rgba(8, 52, 31, 0.95);
    transform: translateY(-50%) scale(1.06);
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.32);
  }

  .carousel-nav:active {
    transform: translateY(-50%) scale(0.96);
  }

  .carousel-overlay-bar {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1.6rem 0.85rem 0.7rem;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.55) 100%
    );
    pointer-events: none;
  }

  .carousel-overlay-bar > * {
    pointer-events: auto;
  }

  .carousel-dots {
    display: flex;
    align-items: center;
    gap: 0.42rem;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    border: none;
    background: rgba(255, 255, 255, 0.45);
    cursor: pointer;
    transition:
      width 0.2s ease,
      background-color 0.2s ease,
      opacity 0.2s ease;
    opacity: 0.9;
    padding: 0;
  }

  .carousel-dot:hover {
    background: rgba(255, 255, 255, 0.85);
  }

  .carousel-dot.active {
    width: 22px;
    background: #f0c14a;
    opacity: 1;
  }

  .carousel-counter {
    font-family: var(--font-body, "Source Sans 3", sans-serif);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.92);
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    padding: 0.28rem 0.62rem;
  }

  /* ========== BOTÓN AUTOMATCH ========== */
  .ver-mas-automatch-container {
    display: flex;
    justify-content: center;
    margin-top: 0.3rem;
    margin-bottom: 0.25rem;
  }

  .btn-automatch {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.8rem;
    padding: 0.78rem 1.3rem;
    background: transparent;
    color: #1b5e3f;
    text-decoration: none;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.93rem;
    transition: all 0.25s ease;
    text-transform: uppercase;
    letter-spacing: 0.35px;
    border: 1px solid rgba(27, 94, 63, 0.3);
    cursor: pointer;
  }

  .btn-automatch i {
    font-size: 0.88rem;
  }

  .btn-automatch:hover {
    transform: translateY(-2px);
  }

  .btn-automatch--secondary {
    margin-top: 0.35rem;
    padding: 0;
    border: none;
    border-radius: 0;
    background: transparent;
    color: #1f5f43;
    box-shadow: none;
    font-size: 0.97rem;
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0.1px;
    text-decoration: underline;
    text-decoration-color: rgba(31, 95, 67, 0.32);
    text-underline-offset: 0.22rem;
  }

  .btn-automatch--secondary:hover {
    background: transparent;
    color: #174a33;
    box-shadow: none;
    transform: none;
    text-decoration-color: rgba(23, 74, 51, 0.75);
  }

  .btn-automatch--secondary i {
    font-size: 0.86rem;
    opacity: 0.85;
    transition: transform 0.2s ease;
  }

  .btn-automatch--secondary:hover i {
    transform: translateX(2px);
  }

  .btn-automatch--primary {
    padding: 0.95rem 1.75rem;
    background: #1b5e3f;
    color: white;
    border-color: #1b5e3f;

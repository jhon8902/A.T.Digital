---
const staticAutos = [
  {
    id: "tesla-model-3",
    nombre: "Maserati GranCabrio",
    descripcion: "Sedán eléctrico con más de 500 km de autonomía.",
    imagenes: [
      "/img/automatch/maseratti-grancabrio.webp",
      "/img/automatch/maserati-grancabrio1.webp",
      "/img/automatch/maserati-grancabrio2.webp",
      "/img/automatch/maserati-grancabrio3.webp",
    ],
  },
  {
    id: "bmw-i4",
    nombre: "Subaru BRZ",
    descripcion:
      "Deportivo de alto rendimiento: potencia, precisión y emociones al máximo.",
    imagenes: [
      "/img/automatch/subaru brz 1.webp",
      "/img/automatch/subaru brz.webp",
      "/img/automatch/subaru brz 2.webp",
      "/img/automatch/subaru brz 3.webp",
    ],
  },
  {
    id: "porsche-taycan",
    nombre: "Bugatti Chiron",
    descripcion: "El auto eléctrico más emocionante del mundo.",
    imagenes: [
      "/img/automatch/bugatti.webp",
      "/img/automatch/bugatti1.webp",
      "/img/automatch/bugatti2.webp",
      "/img/automatch/bugatti3.webp",
    ],
  },
];

const { autos: incomingAutos = [], mode = "home" } = Astro.props;
const HOME_VISIBLE_COUNT = 3;

function stripHtml(input = "") {
  return String(input)
    .replace(/<[^>]*>/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function normalizeText(input = "") {
  return String(input)
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "");
}

function toSingleLine(text = "", max = 96) {
  const clean = stripHtml(text) || "Informacion destacada del modelo.";
  if (clean.length <= max) {
    return clean;
  }

  const cutAt = clean.lastIndexOf(" ", max);
  const safeCut = cutAt > 20 ? cutAt : max;
  return `${clean.slice(0, safeCut).trim()}...`;
}

const defaultFactsByModel: Record<string, string[]> = {
  "maserati grancabrio": [
    "Convertible de lujo con enfoque GT y respuesta progresiva.",
    "Cabina premium con acabados artesanales y gran nivel de detalle.",
    "Tren motriz electrificado pensado para acelerar con suavidad y fuerza.",
  ],
  "subaru brz": [
    "Coupe de traccion trasera con reparto de peso equilibrado.",
    "Motor boxer 2.4L atmosferico con respuesta lineal en altas vueltas.",
    "Puesta a punto enfocada en precision de chasis y control en curva.",
  ],
  "bugatti chiron": [
    "Hiperdeportivo con arquitectura extrema y aerodinamica activa.",
    "Motor W16 quad-turbo de altas prestaciones para uso de coleccion.",
    "Ingenieria orientada a velocidad maxima y estabilidad a alta carga.",
  ],
  "maserati mcxtrema": [
    "Modelo de pista con enfoque radical y produccion muy limitada.",
    "V6 biturbo de alto rendimiento y calibracion orientada a circuito.",
    "Aero funcional para generar carga y confianza en curvas rapidas.",
  ],
};

function parseAutomatchMeta(content = "") {
  const match = String(content).match(/AUTOMATCH_META:([^>]*)-->/i);
  if (!match || !match[1]) return {};

  try {
    const decoded = decodeURIComponent(match[1].trim());
    const parsed = JSON.parse(decoded);
    return parsed?.texts && typeof parsed.texts === "object"
      ? parsed.texts
      : {};
  } catch (_error) {
    return {};
  }
}

const slideTopics = [
  "Vista exterior principal",
  "Perfil y presencia lateral",
  "Detalles de diseno",
  "Interior y cabina",
  "Espacio y practicidad",
  "Tecnologia y conectividad",
];

const normalizedIncoming = Array.isArray(incomingAutos)
  ? incomingAutos
      .map((auto, index) => {
        const images = Array.isArray(auto?.imagenes)
          ? auto.imagenes.filter(Boolean)
          : [];
        return {
          id: String(auto?.id ?? `auto-${index + 1}`),
          nombre: String(auto?.nombre || "AutoMatch"),
          descripcion: String(
            auto?.descripcion || stripHtml(auto?.content || "Sin descripcion"),
          ),
          metaTexts: parseAutomatchMeta(auto?.content || ""),
          imagenes: images.length > 0 ? images : ["/img/default.jpg"],
        };
      })
      .filter((auto) => auto.nombre && auto.imagenes.length > 0)
  : [];

const incomingIdSet = new Set(
  normalizedIncoming.map((auto) => String(auto.id)),
);
const incomingTitleSet = new Set(
  normalizedIncoming.map((auto) => normalizeText(auto.nombre)),
);

const mergedAutos = [
  ...normalizedIncoming,
  ...staticAutos.filter(
    (auto) =>
      !incomingIdSet.has(String(auto.id)) &&
      !incomingTitleSet.has(normalizeText(auto.nombre)),
  ),
];

const autosToRender =
  mode === "archive"
    ? mergedAutos.slice(HOME_VISIBLE_COUNT)
    : mergedAutos.slice(0, HOME_VISIBLE_COUNT);

const autosWithTexts = autosToRender.map((auto: any) => {
  const modelFacts =
    defaultFactsByModel[normalizeText(auto.nombre)] || ([] as string[]);
  const firstSlideText = toSingleLine(auto.descripcion, 98);

  const texts = (auto.imagenes as string[]).map((_, index) => {
    if (index === 0) {
      return {
        line1: firstSlideText,
      };
    }

    const key = `img${index + 1}`;
    const custom = auto?.metaTexts?.[key] || {};
    const customLine1 = stripHtml(custom?.line1 || "");
    const customLine2 = stripHtml(custom?.line2 || "");

    return {
      line1:
        customLine1 ||
        modelFacts[index - 1] ||
        slideTopics[index % slideTopics.length] ||
        "Detalle destacado del modelo",
    };
  });

  return {
    ...auto,
    texts,
  };
});

const hasMoreAutos = mergedAutos.length > HOME_VISIBLE_COUNT;
---

<section class="automatch-section">
  <h2 class="titulo">
    <i class="fas fa-car titulo-icon"></i>
    {mode === "archive" ? "Mas contenido AutoMatch" : "AutoMatch"}
    <i class="fas fa-heart titulo-icon titulo-icon--heart"></i>
  </h2>
  <p class="subtitulo">
    {
      mode === "archive"
        ? "Listado de fichas AutoMatch con el mismo formato de tarjetas y carrusel."
        : "Infórmate, comenta y dale like a tus favoritos."
    }
  </p>

  <div class="cards">
    {
      autosWithTexts.map((auto: any) => (
        <article class="auto-card" data-id={auto.id}>
          <div class="auto-carousel">
            {(auto.imagenes as string[]).map((img, index) => (
              <img
                src={img}
                alt={auto.nombre}
                class={`auto-img ${index === 0 ? "visible" : "hidden"}`}
                loading="lazy"
                decoding="async"
              />
            ))}
          </div>
          <div class="auto-carousel-controls">
            <button type="button" class="prev" aria-label="Imagen anterior">
              <i class="fas fa-chevron-left" />
            </button>
            <div class="carousel-dots" aria-label="Navegacion de imagenes">
              {(auto.imagenes as string[]).map((_, index) => (
                <button
                  type="button"
                  class={`carousel-dot ${index === 0 ? "active" : ""}`}
                  data-index={String(index)}
                  aria-label={`Ir a la imagen ${index + 1}`}
                />
              ))}
            </div>
            <button type="button" class="next" aria-label="Imagen siguiente">
              <i class="fas fa-chevron-right" />
            </button>
          </div>

          <h3>{auto.nombre}</h3>
          <div class="auto-info">
            {auto.texts.map((text: any, index: number) => (
              <p class={`auto-texto ${index === 0 ? "visible" : "hidden"}`}>
                <span class="auto-texto-linea">{text.line1}</span>
              </p>
            ))}
          </div>

          <div class="acciones">
            <button class="btn-like" data-id={auto.id}>
              <i class="fas fa-thumbs-up" /> <span>0</span>
            </button>
            <button class="btn-corazon" data-id={auto.id}>
              <i class="fas fa-heart" /> <span>0</span>
            </button>
          </div>

          <div class="comentarios">
            <h4>
              <i class="far fa-comment-dots" /> Comentarios{" "}
              <span class="contador-comentarios">(0)</span>
            </h4>
            <ul class="lista-comentarios" />
            <button class="btn-expand-comentarios" style="display: none;">
              <i class="fas fa-chevron-down" /> Ver comentarios
            </button>

            <form class="form-comentario" data-id={auto.id}>
              <input
                type="text"
                name="nombre"
                placeholder="Tu nombre"
                required
              />
              <textarea
                name="mensaje"
                placeholder="Escribe tu comentario..."
                required
              />
              <button type="submit">
                <i class="fas fa-paper-plane" /> Enviar
              </button>
            </form>
          </div>
        </article>
      ))
    }
  </div>

  {
    mode === "archive" && autosToRender.length === 0 && (
      <p class="subtitulo">Aun no hay mas fichas para mostrar.</p>
    )
  }

  {
    mode === "home" && hasMoreAutos && (
      <div class="ver-mas-automatch-container">
        <a href="/automatch" class="btn-automatch btn-automatch--secondary">
          <i class="fas fa-arrow-right" /> Ver mas AutoMatch
        </a>
      </div>
    )
  }
</section>

{
  mode === "home" && (
    <section class="automatch-section automatch-section--finder">
      <h2>
        <i class="fas fa-car-side" />
        Encuentra tu AutoMatch
      </h2>
      <p>
        Usa nuestra herramienta inteligente para descubrir el auto perfecto para
        ti.
      </p>

      <a href="/automatch-find" class="btn-automatch btn-automatch--primary">
        <i class="fas fa-sliders-h" /> Probar AutoMatch
      </a>
    </section>
  )
}

<style>
  /* ========== SECCIÓN AUTOMATCH PRINCIPAL ========== */

  .automatch-section {
    text-align: center;
    padding: 3rem 1rem;
    background: #ffffff;
    border-radius: 1.2rem;
    margin: 3rem 0;
    font-size: 1.4rem;
    box-shadow: 0 8px 32px rgba(225, 163, 7, 0.1);
    animation: slideInSection 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes slideInSection {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .automatch-section h2 {
    font-size: 3.2rem;
    color: #08341f;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .automatch-section p {
    color: #1f1f1f;
    font-size: 1.4rem;
    margin-bottom: 2rem;
  }

  /* ========== TÍTULO CON LÍNEAS ========== */
  .titulo {
    font-size: 2.4rem;
    font-weight: 700;
    color: #02350f;
    margin-bottom: 0.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
  }

  .titulo-icon {
    font-size: 2rem;
    color: #08341f;
    opacity: 0.85;
  }

  .titulo-icon--heart {
    color: #e63946;
    opacity: 1;
  }

  .titulo::before,
  .titulo::after {
    content: "";
    flex: 1;
    height: 2px;
    background-color: #1b5e3f;
    max-width: 650px;
  }

  .subtitulo {
    color: #555;
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  /* ========== GRID DE TARJETAS ========== */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    font-size: 1.1rem;
    text-align: start;
    margin-bottom: 2rem;
  }

  .auto-card {
    background: transparent;
    border-radius: 0;
    box-shadow: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    transition:
      transform 0.35s,
      box-shadow 0.35s;
    border: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    position: relative;
    isolation: isolate;
  }

  .auto-card::before {
    content: none;
  }

  .auto-card h3 {
    margin: 0.9rem 0 0.5rem;
    color: black;
    text-transform: uppercase;
    font-weight: 600;
  }

  .auto-card p {
    margin: 0;
    line-height: 1.5;
    min-height: 3em;
    color: #000;
  }

  .auto-info {
    min-height: 2.2em;
    margin-bottom: 0.35rem;
  }

  .auto-texto {
    margin: 0;
    color: #000;
  }

  .auto-texto.hidden {
    display: none;
  }

  .auto-texto.visible {
    display: block;
  }

  .auto-texto-linea {
    display: block;
    line-height: 1.35;
  }

  .auto-texto.entering {
    animation: autoTextIn 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @keyframes autoTextIn {
    0% {
      opacity: 0;
      transform: translateY(14px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .auto-texto.entering {
      animation: none;
    }

    .auto-img.entering {
      animation: none;
    }
  }

  .auto-card:hover {
    transform: translateY(-10px) scale(1.01);
    box-shadow: none;
    background: transparent;
  }

  /* ========== CARRUSEL DE IMÁGENES ========== */
  .auto-carousel {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: skeleton-loading 1.5s infinite;
  }

  @keyframes skeleton-loading {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  .auto-carousel.loaded {
    background: none;
    animation: none;
  }

  .auto-img {
    width: 100%;
    border-radius: 12px;
    display: none;
    transition: opacity 0.4s ease;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .auto-img.visible {
    display: block;
  }

  .auto-img.entering {
    animation: autoImageIn 0.52s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @keyframes autoImageIn {
    0% {
      opacity: 0.25;
      transform: translateY(6px) scale(1.03);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .auto-carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.95rem;
    margin-top: 0.55rem;
    margin-bottom: 0.7rem;
  }

  .carousel-dots {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(207, 213, 220, 0.95);
  }

  .carousel-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: none;
    background: #b7c2ce;
    cursor: pointer;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      opacity 0.2s ease;
    opacity: 0.8;
  }

  .carousel-dot:hover {
    opacity: 1;
    transform: scale(1.18);
  }

  .carousel-dot.active {
    background: #1b5e3f;
    transform: scale(1.28);
    opacity: 1;
  }

  .prev,
  .next {
    position: static;
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, #ffffff 0%, #f2f5f8 100%);
    color: #26323f;
    border: 1px solid #cfd7e0;
    border-radius: 50%;
    padding: 0;
    font-size: 0.82rem;
    cursor: pointer;
    transition:
      transform 0.2s,
      box-shadow 0.2s,
      background-color 0.2s,
      color 0.2s,
      border-color 0.2s;
    box-shadow:
      0 5px 14px rgba(19, 38, 57, 0.16),
      0 1px 2px rgba(19, 38, 57, 0.08);
  }

  .prev:hover,
  .next:hover {
    background: #1b5e3f;
    color: white;
    border-color: #1b5e3f;
    transform: scale(1.06);
    box-shadow: 0 6px 16px rgba(27, 94, 63, 0.28);
  }

  .prev:active,
  .next:active {
    transform: scale(0.96);
  }

  /* ========== ACCIONES (LIKES Y CORAZONES) ========== */
  .acciones {
    display: flex;
    justify-content: start;
    gap: 1rem;
    margin-top: 0.8rem;
    flex-wrap: wrap;
  }

  .btn-like,
  .btn-corazon {
    border: none;
    background: transparent;
    color: #5f6b77;
    cursor: pointer;
    transition:
      transform 0.2s,
      color 0.2s;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.25rem 0.5rem;
    font-size: 1rem;
  }

  .btn-like i {
    color: currentColor;
    font-size: 1.3rem;
    transition: color 0.2s;
  }

  .btn-like:hover i {
    color: currentColor;
  }

  .btn-like:hover {
    color: #0055cc;
    transform: scale(1.08);
  }

  .btn-corazon i {
    color: currentColor;
    font-size: 1.3rem;
    transition: color 0.2s;
  }

  .btn-corazon:hover i {
    color: currentColor;
  }

  .btn-corazon:hover {
    color: #d62828;
    transform: scale(1.08);
  }

  .btn-like.activo {
    color: #0077ff;
  }

  .btn-corazon.activo {
    color: #e63946;
  }

  .btn-like.is-animating,
  .btn-corazon.is-animating {
    animation: pulse 0.3s ease;
  }

  @keyframes pulse {
    0% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.2);
    }
    100% {
      transform: scale(1.4);
    }
  }

  /* ========== SECCIÓN DE COMENTARIOS ========== */
  .comentarios {
    margin-top: 1rem;
    text-align: left;
  }

  .comentarios h4 {
    margin-bottom: 0.5rem;
    color: #000;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .comentarios h4 i {
    color: #000;
    font-size: 1rem;
  }

  .contador-comentarios {
    font-size: 0.85rem;
    font-weight: 500;
    color: #000;
  }

  .lista-comentarios {
    list-style: none;
    padding-left: 0;
    margin-bottom: 0.8rem;
    max-height: 300px;
    overflow-y: auto;
  }

  .lista-comentarios li {
    background: #f7f8fa;
    color: #000;
    margin-bottom: 0.4rem;
    padding: 0.5rem 0.8rem;
    border-left: 4px solid #1b5e3f;
    border-radius: 6px;
    transition:
      background 0.3s,
      border-color 0.3s,
      transform 0.3s;
    font-size: 0.9rem;
  }

  .lista-comentarios li.nuevo {
    animation: highlightComment 0.6s ease;
  }

  @keyframes highlightComment {
    0% {
      background: #fff8dc;
      transform: translateX(-10px);
    }
    50% {
      background: #fffb00;
      transform: translateX(0);
    }
    100% {
      background: #f7f8fa;
      transform: translateX(0);
    }
  }

  .lista-comentarios li.hidden {
    display: none;
  }

  .btn-expand-comentarios {
    background: transparent;
    color: #1b5e3f;
    border: 1px solid #1b5e3f;
    border-radius: 6px;
    padding: 0.4rem 0.8rem;
    margin-top: 0.6rem;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    transition: all 0.3s;
  }

  .btn-expand-comentarios:hover {
    background: #1b5e3f;
    color: white;
  }

  .btn-expand-comentarios.expanded {
    background: #1b5e3f;
    color: white;
  }

  @keyframes slideInComment {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .lista-comentarios li strong {
    color: #000;
    font-weight: 600;
  }

  .lista-comentarios li .fecha {
    float: right;
    font-size: 0.75rem;
    color: #000;
  }

  .btn-vote-comment {
    background: transparent;
    color: #0077ff;
    border: 1px solid #0077ff;
    border-radius: 6px;
    padding: 0.2rem 0.6rem;
    cursor: pointer;
    font-size: 0.75rem;
    font-weight: 600;
    transition: all 0.3s;
    margin-top: 0.4rem;
  }

  .btn-vote-comment:hover:not(:disabled) {
    background: #0077ff;
    color: white;
    transform: scale(1.1);
  }

  .btn-vote-comment:disabled {
    background: #e0e0e0;
    color: #888;
    border-color: #ccc;
    cursor: not-allowed;
  }

  .btn-vote-comment.voted::before {
    content: "✓ ";
    font-weight: 700;
    margin-right: 0.2rem;
  }

  /* ========== FORMULARIO DE COMENTARIOS ========== */
  .form-comentario {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: #1a1a2e;
    margin-top: 1rem;
  }

  .form-comentario input,
  .form-comentario textarea {
    width: 100%;
    padding: 0.6rem 0.8rem;
    border-radius: 6px;
    border: 1px solid #ddd;
    font-size: 0.9rem;
    resize: none;
    background: #fafafa;
    font-family: inherit;
    transition:
      border 0.3s,
      background 0.3s;
  }

  .form-comentario input::placeholder,
  .form-comentario textarea::placeholder {
    color: #555;
    opacity: 1;
  }

  .form-comentario input:focus,
  .form-comentario textarea:focus {
    outline: none;
    border-color: #e1a307;
    background: white;
  }

  .form-comentario button {
    background: #1b5e3f;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 0.6rem 1rem;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .form-comentario button i {
    font-size: 0.9rem;
  }

  .form-comentario button:hover {
    transform: scale(1.05);
    box-shadow: 0 4px 12px rgba(225, 163, 7, 0.3);
  }

  .form-comentario button:active {
    transform: scale(0.98);
  }

  /* ========== BOTÓN AUTOMATCH ========== */
  .ver-mas-automatch-container {
    display: flex;
    justify-content: center;
    margin-top: 0.3rem;
    margin-bottom: 0.25rem;
  }

  .btn-automatch {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.8rem;
    padding: 0.78rem 1.3rem;
    background: transparent;
    color: #1b5e3f;
    text-decoration: none;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.93rem;
    transition: all 0.25s ease;
    text-transform: uppercase;

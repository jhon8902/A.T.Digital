  }

  .btn-automatch:hover {
    transform: translateY(-2px);
  }

  .btn-automatch--secondary {
    margin-top: 0.35rem;
    padding: 0;
    border: none;
    border-radius: 0;
    background: transparent;
    color: #1f5f43;
    box-shadow: none;
    font-size: 0.97rem;
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0.1px;
    text-decoration: underline;
    text-decoration-color: rgba(31, 95, 67, 0.32);
    text-underline-offset: 0.22rem;
  }

  .btn-automatch--secondary:hover {
    background: transparent;
    color: #174a33;
    box-shadow: none;
    transform: none;
    text-decoration-color: rgba(23, 74, 51, 0.75);
  }

  .btn-automatch--secondary i {
    font-size: 0.86rem;
    opacity: 0.85;
    transition: transform 0.2s ease;
  }

  .btn-automatch--secondary:hover i {
    transform: translateX(2px);
  }

  .btn-automatch--primary {
    padding: 0.95rem 1.75rem;
    background: #1b5e3f;
    color: white;
    border-color: #1b5e3f;
    box-shadow: 0 8px 20px rgba(27, 94, 63, 0.24);
    font-size: 0.98rem;
  }

  .btn-automatch--primary:hover {
    background: #154c33;
    border-color: #154c33;
    box-shadow: 0 10px 24px rgba(21, 76, 51, 0.28);
  }

  .btn-automatch:active {
    transform: translateY(0);

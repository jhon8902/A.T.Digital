    }

    .lista-comentarios li {
      padding: 0.4rem 0.6rem;
      font-size: 0.8rem;
      margin-bottom: 0.3rem;
    }

    .form-comentario button {
      width: 95%;
      margin: 0.15rem auto 0;
      justify-content: center;
      border-radius: 10px;
      padding: 0.62rem 0.8rem;
      font-size: 0.84rem;
      letter-spacing: 0.4px;
    }

    .btn-expand-comentarios {
      width: 95%;
      margin-left: auto;
      margin-right: auto;
      text-align: center;
      padding: 0.52rem 0.8rem;
      border-radius: 10px;
    }

    .ver-mas-automatch-container {
      width: 100%;
      justify-content: center;
    }

    .btn-automatch {
      width: 95%;
      justify-content: center;
      border-radius: 999px;
      padding: 0.72rem 1rem;
      font-size: 0.88rem;
    }

    .btn-automatch--secondary {
      width: auto;
      min-width: 0;
      padding: 0;
      font-size: 0.92rem;
    }

    .btn-automatch--primary {
      width: 95%;
      padding: 0.82rem 1.1rem;
      font-size: 0.9rem;
    }

    .automatch-section--finder {
      margin-top: 0.85rem;
      padding-top: 1.85rem;
    }

    .ver-mas-automatch-container {
      margin-top: 0;
    }

    .lista-comentarios {
      max-height: 150px;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", async () => {
    type LikeType = "like" | "corazon";
    type AutoMatchComment = {
      nombre: string;
      mensaje: string;
      created_at?: string;
    };

    const likedState = JSON.parse(
      localStorage.getItem("automatchLikedState") || "{}",
    );
    const autoCards = Array.from(document.querySelectorAll(".auto-card"));
    const autoplayTimers = new Map<HTMLElement, number>();
    const AUTOPLAY_MS = 5000;
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    );
    const autoIds = autoCards
      .map((card) => (card as HTMLElement).dataset.id || "")
      .filter(Boolean);

    let clientId = localStorage.getItem("automatchClientId");
    if (!clientId) {
      clientId = `client-${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
      localStorage.setItem("automatchClientId", clientId);
    }

    function setCounter(autoId: string, tipo: LikeType, value: number) {
      const selector = tipo === "like" ? ".btn-like" : ".btn-corazon";
      const btn = document.querySelector(
        `.auto-card[data-id="${autoId}"] ${selector}`,
      );
      if (!btn) return;
      const span = btn.querySelector("span");
      if (span) span.textContent = String(value || 0);
    }

    function pulseActionButton(button: HTMLElement) {
      button.classList.add("is-animating");
      setTimeout(() => button.classList.remove("is-animating"), 300);
    }

    function aplicarEstadoLikes() {
      const actionButtons = document.querySelectorAll(
        ".btn-like, .btn-corazon",
      );
      actionButtons.forEach((button) => {
        if (!(button instanceof HTMLElement)) return;
        const autoId = button.dataset.id;
        if (!autoId) return;
        const tipo = button.classList.contains("btn-like") ? "like" : "corazon";
        const key = `${autoId}-${tipo}`;
        button.classList.toggle("activo", Boolean(likedState[key]));
      });
    }

    async function cargarLikes() {
      if (autoIds.length === 0) return;
      try {
        const response = await fetch(
          `/.netlify/functions/api-automatch-likes?auto_ids=${encodeURIComponent(autoIds.join(","))}`,
        );
        if (!response.ok) return;
        const data = await response.json();
        const counts = data?.counts || {};

        autoIds.forEach((autoId) => {
          setCounter(autoId, "like", counts?.[autoId]?.like || 0);
          setCounter(autoId, "corazon", counts?.[autoId]?.corazon || 0);
        });
      } catch (error) {
        // Evita choque con instrumentacion de consola en dev.
        void error;
      }
    }

    function createCommentItem(comment: AutoMatchComment) {
      const li = document.createElement("li");
      const dateStr = comment?.created_at
        ? new Date(comment.created_at).toLocaleString("es-CO", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
            hour: "2-digit",
            minute: "2-digit",
          })
        : "";
      li.innerHTML = `<strong>${comment.nombre}</strong> <span class="fecha">${dateStr}</span><br>${comment.mensaje}`;
      li.classList.add("hidden");
      return li;
    }

    async function cargarComentarios(autoId: string) {
      const ul = document.querySelector(
        `.auto-card[data-id="${autoId}"] .lista-comentarios`,
      ) as HTMLElement | null;
      const btnExpand = document.querySelector(
        `.auto-card[data-id="${autoId}"] .btn-expand-comentarios`,
      ) as HTMLButtonElement | null;
      const contador = document.querySelector(
        `.auto-card[data-id="${autoId}"] .contador-comentarios`,
      ) as HTMLElement | null;
      if (!ul || !btnExpand || !contador) return;

      try {
        const response = await fetch(
          `/.netlify/functions/api-automatch-comments?auto_id=${encodeURIComponent(autoId)}`,
        );
        if (!response.ok) return;
        const data = await response.json();
        const comments = Array.isArray(data?.comments) ? data.comments : [];

        ul.innerHTML = "";
        comments.forEach((comment: AutoMatchComment) => {
          ul.appendChild(createCommentItem(comment));
        });
        contador.textContent = `(${comments.length})`;
        btnExpand.style.display = comments.length > 0 ? "block" : "none";
      } catch (error) {
        void autoId;
        void error;
      }
    }

    // Marcar imágenes como cargadas para remover skeleton loader
    document.querySelectorAll(".auto-img").forEach((img) => {
      const htmlImg = img as HTMLImageElement;
      if (htmlImg.complete) {
        htmlImg.closest(".auto-carousel")?.classList.add("loaded");
      }
      htmlImg.addEventListener("load", () => {
        htmlImg.closest(".auto-carousel")?.classList.add("loaded");
      });
    });

    await cargarLikes();
    aplicarEstadoLikes();
    await Promise.all(autoIds.map((autoId) => cargarComentarios(autoId)));

    function animateTextEntry(textEl: HTMLElement | undefined) {
      if (!textEl) return;
      textEl.classList.remove("entering");
      void textEl.offsetWidth;
      textEl.classList.add("entering");
    }

    function animateImageEntry(imageEl: HTMLElement | undefined) {
      if (!imageEl) return;
      imageEl.classList.remove("entering");
      void imageEl.offsetWidth;
      imageEl.classList.add("entering");
    }

    function getCurrentImageIndex(images: Element[]) {
      const current = images.findIndex((img) =>
        img.classList.contains("visible"),
      );
      return current < 0 ? 0 : current;
    }

    function updateCarousel(card: HTMLElement, nextIndex: number) {
      const carousel = card.querySelector(".auto-carousel");
      if (!(carousel instanceof HTMLElement)) return;

      carousel.classList.add("loaded");
      const images = Array.from(carousel.querySelectorAll(".auto-img"));
      const texts = Array.from(card.querySelectorAll(".auto-texto"));
      const dots = Array.from(card.querySelectorAll(".carousel-dot"));
      if (images.length === 0) return;

      const current = getCurrentImageIndex(images);
      const normalizedNext =
        ((nextIndex % images.length) + images.length) % images.length;

      images[current]?.classList.remove("visible");
      images[current]?.classList.add("hidden");
      images[current]?.classList.remove("entering");

      images[normalizedNext]?.classList.remove("hidden");
      images[normalizedNext]?.classList.add("visible");
      animateImageEntry(images[normalizedNext] as HTMLElement | undefined);

      if (texts.length > 0) {
        const currentText = texts[current] as HTMLElement | undefined;
        const nextText = texts[normalizedNext] as HTMLElement | undefined;
        if (currentText) {
          currentText.classList.remove("visible");
          currentText.classList.add("hidden");
          currentText.classList.remove("entering");
        }
        if (nextText) {
          nextText.classList.remove("hidden");
          nextText.classList.add("visible");
          animateTextEntry(nextText);
        }
      }

      dots.forEach((dot, index) => {
        dot.classList.toggle("active", index === normalizedNext);
      });
    }

    function moveCarouselBy(card: HTMLElement, step: number) {
      const images = Array.from(
        card.querySelectorAll(".auto-carousel .auto-img"),
      );
      if (images.length === 0) return;
      const current = getCurrentImageIndex(images);
      updateCarousel(card, current + step);
    }

    function stopAutoplay(card: HTMLElement) {
      const timer = autoplayTimers.get(card);
      if (timer) {
        window.clearInterval(timer);
        autoplayTimers.delete(card);
      }
    }

    function startAutoplay(card: HTMLElement) {
      if (prefersReducedMotion.matches) return;
      stopAutoplay(card);
      const timer = window.setInterval(() => {
        moveCarouselBy(card, 1);
      }, AUTOPLAY_MS);
      autoplayTimers.set(card, timer);
    }

    autoCards.forEach((cardNode) => {
      if (!(cardNode instanceof HTMLElement)) return;
      const card = cardNode;
      startAutoplay(card);
      card.addEventListener("mouseenter", () => stopAutoplay(card));
      card.addEventListener("mouseleave", () => startAutoplay(card));
      card.addEventListener("focusin", () => stopAutoplay(card));
      card.addEventListener("focusout", (event) => {
        const nextFocus = event.relatedTarget as Node | null;
        if (!nextFocus || !card.contains(nextFocus)) {
          startAutoplay(card);
        }
      });
    });

    prefersReducedMotion.addEventListener("change", () => {
      autoCards.forEach((cardNode) => {
        if (!(cardNode instanceof HTMLElement)) return;
        if (prefersReducedMotion.matches) {
          stopAutoplay(cardNode);
        } else {
          startAutoplay(cardNode);
        }
      });
    });

    // Clicks globales: carrusel + likes
    document.addEventListener("click", async (e) => {
      const target = e.target;
      if (!(target instanceof HTMLElement)) return;

      // Carrusel
      if (
        target.matches(".next, .prev") ||
        target.closest(".next, .prev") ||
        target.matches(".carousel-dot")
      ) {
        const trigger = target.matches(".next, .prev, .carousel-dot")
          ? target
          : target.closest(".next, .prev");
        if (!(trigger instanceof HTMLElement)) return;

        const card = trigger.closest(".auto-card");
        if (!(card instanceof HTMLElement)) return;
        const images = Array.from(
          card.querySelectorAll(".auto-carousel .auto-img"),
        );
        if (images.length === 0) return;

        const current = getCurrentImageIndex(images);

        let nextIndex = current;
        if (trigger.matches(".next")) {
          nextIndex = (current + 1) % images.length;
        } else if (trigger.matches(".prev")) {
          nextIndex = (current - 1 + images.length) % images.length;
        } else {
          const dotIndex = Number(trigger.dataset.index);
          if (
            !Number.isNaN(dotIndex) &&
            dotIndex >= 0 &&
            dotIndex < images.length
          ) {
            nextIndex = dotIndex;
          }
        }

        updateCarousel(card, nextIndex);
        startAutoplay(card);
        return;
      }

      // Likes y corazones persistentes
      const actionButton = target.closest(".btn-like, .btn-corazon");
      if (actionButton instanceof HTMLElement) {
        const autoId = actionButton.dataset.id;
        if (!autoId) return;
        const tipo = actionButton.classList.contains("btn-like")
          ? "like"
          : "corazon";
        const key = `${autoId}-${tipo}`;

        if (likedState[key]) {
          actionButton.classList.add("activo");
          pulseActionButton(actionButton);
          return;
        }

        try {
          const response = await fetch(
            "/.netlify/functions/api-automatch-like",
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                auto_id: autoId,
                tipo,
                client_id: clientId,
              }),
            },
          );

          if (!response.ok) return;
          const data = await response.json();
          if (typeof data?.total === "number") {
            const span = actionButton.querySelector("span");
            if (span) span.textContent = String(data.total);
          }

          likedState[key] = true;
          localStorage.setItem(
            "automatchLikedState",
            JSON.stringify(likedState),
          );
          actionButton.classList.add("activo");
          pulseActionButton(actionButton);
        } catch (error) {
          void error;
        }
      }
    });

    // Nuevo comentario persistente
    document.querySelectorAll(".form-comentario").forEach((form) => {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const htmlForm = form as HTMLFormElement;
        const autoId = htmlForm.dataset.id;
        if (!autoId) return;

        const nombreInput = htmlForm.querySelector(
          'input[name="nombre"]',
        ) as HTMLInputElement | null;
        const mensajeInput = htmlForm.querySelector(
          'textarea[name="mensaje"]',
        ) as HTMLTextAreaElement | null;
        const nombre = nombreInput?.value?.trim() || "";
        const mensaje = mensajeInput?.value?.trim() || "";
        if (!nombre || !mensaje) return;

        try {
          const response = await fetch(
            "/.netlify/functions/api-automatch-comment",
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ auto_id: autoId, nombre, mensaje }),
            },
          );

          if (!response.ok) return;
          const data = await response.json();
          const savedComment = data?.comment;
          if (!savedComment) return;

          const ul = htmlForm.parentElement?.querySelector(
            ".lista-comentarios",
          ) as HTMLElement | null;
          const contador = htmlForm.parentElement?.querySelector(
            ".contador-comentarios",
          ) as HTMLElement | null;
          const btnExpand = htmlForm.parentElement?.querySelector(
            ".btn-expand-comentarios",
          ) as HTMLButtonElement | null;
          if (!ul || !contador || !btnExpand) return;

          const li = createCommentItem(savedComment);
          li.classList.add("nuevo");
          ul.prepend(li);

          const total = ul.querySelectorAll("li").length;
          contador.textContent = `(${total})`;
          btnExpand.style.display = "block";

          if (!btnExpand.classList.contains("expanded")) {
            btnExpand.classList.add("expanded");
            btnExpand.textContent = "Ocultar comentarios ⬆️";
          }

          ul.querySelectorAll("li").forEach((item) => {
            item.classList.remove("hidden");
          });

          htmlForm.reset();
          setTimeout(() => {
            li.scrollIntoView({ behavior: "smooth", block: "nearest" });
            li.classList.remove("nuevo");
          }, 100);
        } catch (error) {
          void error;
        }
      });
    });

    // Expandir/Ocultar comentarios
    let expandedCard: string | null = null;
    document.querySelectorAll(".btn-expand-comentarios").forEach((btn) => {
      btn.addEventListener("click", () => {
        const htmlBtn = btn as HTMLButtonElement;
        const ul = htmlBtn.parentElement?.querySelector(
          ".lista-comentarios",
        ) as HTMLElement | null;
        const card = htmlBtn.closest(".auto-card") as HTMLElement | null;
        const cardId = card?.dataset.id || null;
        if (!ul) return;

        const items = ul.querySelectorAll("li");
        if (htmlBtn.classList.contains("expanded")) {
          htmlBtn.classList.remove("expanded");
          htmlBtn.textContent = "Ver comentarios ⬇️";
          items.forEach((item) => item.classList.add("hidden"));
          expandedCard = null;
        } else {
          if (expandedCard && expandedCard !== cardId) {
            const otherBtn = document.querySelector(
              `.auto-card[data-id="${expandedCard}"] .btn-expand-comentarios`,
            ) as HTMLButtonElement | null;
            const otherItems = document.querySelectorAll(
              `.auto-card[data-id="${expandedCard}"] .lista-comentarios li`,
            );
            if (otherBtn) {
              otherBtn.classList.remove("expanded");
              otherBtn.textContent = "Ver comentarios ⬇️";
            }
            otherItems.forEach((item) => item.classList.add("hidden"));
          }

          htmlBtn.classList.add("expanded");
          htmlBtn.textContent = "Ocultar comentarios ⬆️";
          items.forEach((item) => item.classList.remove("hidden"));
          expandedCard = cardId;
        }
      });
    });
  });
</script>

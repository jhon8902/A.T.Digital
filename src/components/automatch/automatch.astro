    }
  }

  @media (max-width: 768px) {
    .automatch-hero__title {
      max-width: none;
    }

    .automatch-hero__actions {
      flex-direction: column;
      width: 100%;
    }

    .automatch-hero__actions .btn-automatch {
      width: min(100%, 20rem);
      justify-content: center;
    }

    .automatch-section {

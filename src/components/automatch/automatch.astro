    }

    .ver-mas-automatch-container {
      margin-top: 0.25rem;
    }

    .lista-comentarios {
      max-height: 200px;
    }
  }

  @media (max-width: 480px) {
    .automatch-section {
      padding: 1.5rem 0.75rem;
      margin: 1.5rem 0;
      border-radius: 0.8rem;
    }

    .titulo {

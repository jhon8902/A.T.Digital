---
import Layout from "../layouts/Layout.astro";
import TestDriveCTA from "../components/leads/TestDriveCTA.astro";

interface Props {
  categoria: string;
  titulo: string;
  showTestDrive?: boolean;
  autoNombre?: string;
  noteId?: number;
  autoId?: string | number;
  dealerId?: number;
  dealerNombre?: string;
}

const {
  categoria,
  titulo,
  showTestDrive = false,
  autoNombre,
  noteId,
  autoId,
  dealerId,
  dealerNombre,
} = Astro.props as Props;

let claseCategoria = "";
switch (categoria?.toLowerCase()) {
  case "hibridos":
  case "eléctricos":
  case "electricos":
  case "pruebas":
  case "lanzamientos":
  case "noticias":
    claseCategoria = categoria.toLowerCase();
    break;
  default:
    claseCategoria = "general";
}
---

<Layout title={titulo} bodyClass={`nota-${claseCategoria}`}>
  <section class={`articulo-container ${claseCategoria}`}>
    <slot />
  </section>
  {
    showTestDrive && autoNombre && (
      <TestDriveCTA
        autoNombre={autoNombre}
        noteId={noteId}
        autoId={autoId}
        dealerId={dealerId}
        dealerNombre={dealerNombre}
      />
    )
  }
</Layout>

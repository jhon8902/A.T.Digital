---
interface Props {
  title: string;
  bodyClass?: string;
  class?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  source_scope?: "nacional" | "internacional";
  sourceScope?: "nacional" | "internacional";
  editor?: string;
  showChrome?: boolean;
}

const {
  title,
  bodyClass,
  class: classProp,
  description = "Auto-Tech-Digital: la guía más completa sobre autos eléctricos, híbridos, lanzamientos y noticias automotrices en Colombia.",
  ogImage = "/img/og-default.webp",
  ogType = "website",
  canonical,
  source_scope,
  sourceScope,
  editor,
  showChrome = true,
} = Astro.props;

const siteUrl = "https://autotechdigital.netlify.app";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage.startsWith("http")
  ? ogImage
  : `${siteUrl}${ogImage}`;

// ✅ Si pasas class, úsalo como bodyClass
const finalBodyClass = bodyClass ?? classProp;
const pathname = Astro.url.pathname.toLowerCase();

const staticNotePrefixes = [
  "/notas-electricos/",
  "/notas-hibridos/",
  "/notas-deportes/",
  "/noticias-carrusel/",
  "/noticias-nacionales/",
];

const isStaticNotePath = staticNotePrefixes.some((prefix) =>
  pathname.startsWith(prefix),
);

const normalizeSourceScope = (
  value: unknown,
): "nacional" | "internacional" | null => {
  if (typeof value !== "string") return null;
  const normalized = value.trim().toLowerCase();
  return normalized === "internacional"
    ? "internacional"
    : normalized === "nacional"
      ? "nacional"
      : null;
};

const explicitScope = normalizeSourceScope(source_scope ?? sourceScope);
const inferredScope = pathname.includes("internacional")
  ? "internacional"
  : "nacional";
const layoutScope = explicitScope ?? (isStaticNotePath ? inferredScope : null);
const layoutScopeLabel =
  layoutScope === "internacional" ? "Internacional" : "Nacional";
const layoutEditor =
  typeof editor === "string" && editor.trim() ? editor.trim() : "Jhon Aparicio";

// 🔹 Detectamos si el bodyClass corresponde a una nota
let categoria = "";
if (finalBodyClass) {
  const classTokens = finalBodyClass
    .split(/\s+/)
    .map((token) => token.trim())
    .filter(Boolean);

  const noteCategoryToken = classTokens.find(
    (token) => token.startsWith("nota-") && token !== "nota-page",
  );

  if (noteCategoryToken) {
    categoria = noteCategoryToken.replace("nota-", "").toLowerCase();
  }
}

const categoryLabel = (() => {
  switch (categoria) {
    case "electricos":
    case "eléctricos":
      return "Eléctricos";
    case "hibridos":
    case "híbridos":
      return "Híbridos";
    case "deportes":
      return "Deportes";
    case "lanzamientos":
      return "Lanzamientos";
    case "noticias":
      return "Noticias";
    default:
      // Inferir desde URL cuando bodyClass no provee la categoría
      if (pathname.startsWith("/notas-electricos")) return "Eléctricos";
      if (pathname.startsWith("/notas-hibridos")) return "Híbridos";
      if (pathname.startsWith("/notas-deportes")) return "Deportes";
      if (
        pathname.startsWith("/noticias-nacionales") ||
        pathname.startsWith("/noticias-carrusel")
      )
        return "Noticias";
      return "Actualidad";
  }
})();

// 🔹 Definimos el CSS de categoría que se cargará dinámicamente
let categoriaCSS = "";
switch (categoria) {
  case "electricos":
  case "eléctricos":
    categoriaCSS = "/css/electricos.css";
    break;
  case "hibridos":
    categoriaCSS = "/css/hibridos.css";
    break;
  case "noticias":
    categoriaCSS = "/css/noticias.css";
    break;
  case "lanzamientos":
    categoriaCSS = "/css/lanzamientos.css";
    break;
  case "deportes":
  case "pruebas":
    categoriaCSS = "/css/lanzamientos.css";
    break;
  case "automatch":
    categoriaCSS = "/css/automatch.css";
    break;
  default:
    categoriaCSS = "";
    break;
}
import Header from "../components/header/Header.astro";
import Footer from "../components/footer/footer.astro";
import "swiper/css";
import "swiper/css/pagination";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- SEO Básico -->
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Auto-Tech-Digital" />
    <meta name="theme-color" content="#08341f" />

    <!-- Open Graph (Facebook, WhatsApp, LinkedIn) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Auto-Tech-Digital" />
    <meta property="og:locale" content="es_CO" />

    <!-- Twitter / X Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:site" content="@autotechdigital" />

    <!-- Tailwind CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css"
      rel="stylesheet"
    />

    <!-- Fuentes (sistema tipográfico unificado) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Font Awesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />

    <!-- Estilos globales -->
    <link rel="stylesheet" href="/css/base.css" />
    <link rel="stylesheet" href="/css/common.css" />

    <!-- Estilos específicos según la categoría (solo para notas) -->
    {categoriaCSS && <link rel="stylesheet" href={categoriaCSS} />}

    <!-- Estilos del footer -->
    <link rel="stylesheet" href="/css/footer.css" />
  </head>

  <body class={finalBodyClass}>
    {showChrome && <Header />}
    <main>
      {
        layoutScope && (
          <div class="scope-bar-outer">
            <div class="layout-scope-wrap">
              <span class="layout-meta-item">
                <i class="fa-regular fa-user" aria-hidden="true" />
                <span>{layoutEditor}</span>
              </span>
              <span class="layout-meta-item">
                <i class="fa-regular fa-bookmark" aria-hidden="true" />
                <span>{categoryLabel}</span>
              </span>
              <span
                class={`layout-meta-item ${layoutScope === "internacional" ? "scope-internacional" : "scope-nacional"}`}
              >
                <i class="fa-regular fa-compass" aria-hidden="true" />
                <span>{layoutScopeLabel}</span>
              </span>
            </div>
          </div>
        )
      }
      <slot />
    </main>
    {showChrome && <Footer />}
    <script>
      // Observador global para animar títulos principales (h1, h2)
      document.addEventListener("DOMContentLoaded", function () {
        const targets = document.querySelectorAll("h1, h2");
        if (!targets || targets.length === 0) return;

        targets.forEach((el) => el.classList.add("animated-title"));

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("in-view");
              }
            });
          },
          { threshold: 0.15 },
        );

        targets.forEach((el) => io.observe(el));
      });
    </script>

    <style>
      .scope-bar-outer {
        width: 100%;
        background: #faf5f0;
        padding-top: 2rem;
        padding-bottom: 0.5rem;
      }

      .layout-scope-wrap {
        width: min(1120px, calc(100% - 2rem));
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 0.6rem 0.95rem;
        flex-wrap: wrap;
      }

      .layout-meta-item {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        border-radius: 999px;
        padding: 0.36rem 0.86rem;
        font-family: var(--font-body);
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: #404040;
        background: #f3f3f3;
        border: 1px solid #dedede;
      }

      .layout-meta-item i {
        font-size: 0.82rem;
        opacity: 0.82;
      }

      .layout-meta-item.scope-nacional {
        background: #e6f4ec;
        color: #1f5d3e;
        border-color: #bfdcc9;
      }

      .layout-meta-item.scope-internacional {
        background: #eaf2ff;
        color: #1f4aa8;
        border-color: #c7d9ff;
      }

      @media (max-width: 768px) {
        .scope-bar-outer {
          padding-top: 1.5rem;
          padding-bottom: 0.35rem;
        }

        .layout-scope-wrap {
          width: calc(100% - 1.5rem);
          gap: 0.45rem 0.7rem;
        }
      }
    </style>
  </body>
</html>

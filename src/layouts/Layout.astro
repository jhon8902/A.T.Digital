---
interface Props {
  title: string;
  bodyClass?: string;
  class?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
}

const {
  title,
  bodyClass,
  class: classProp,
  description = "Auto-Tech-Digital: la guía más completa sobre autos eléctricos, híbridos, lanzamientos y noticias automotrices en Colombia.",
  ogImage = "/img/og-default.webp",
  ogType = "website",
  canonical,
} = Astro.props;

const siteUrl = "https://autotechdigital.netlify.app";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage.startsWith("http")
  ? ogImage
  : `${siteUrl}${ogImage}`;

// ✅ Si pasas class, úsalo como bodyClass
const finalBodyClass = bodyClass ?? classProp;

// 🔹 Detectamos si el bodyClass corresponde a una nota
let categoria = "";
if (finalBodyClass) {
  const classTokens = finalBodyClass
    .split(/\s+/)
    .map((token) => token.trim())
    .filter(Boolean);

  const noteCategoryToken = classTokens.find(
    (token) => token.startsWith("nota-") && token !== "nota-page",
  );

  if (noteCategoryToken) {
    categoria = noteCategoryToken.replace("nota-", "").toLowerCase();
  }
}

// 🔹 Definimos el CSS de categoría que se cargará dinámicamente
let categoriaCSS = "";
switch (categoria) {
  case "electricos":
  case "eléctricos":
    categoriaCSS = "/css/electricos.css";
    break;
  case "hibridos":
    categoriaCSS = "/css/hibridos.css";
    break;
  case "noticias":
    categoriaCSS = "/css/noticias.css";
    break;
  case "lanzamientos":
    categoriaCSS = "/css/lanzamientos.css";
    break;
  case "automatch":
    categoriaCSS = "/css/automatch.css";
    break;
  default:
    categoriaCSS = "";
    break;
}
import Header from "../components/header/Header.astro";
import Footer from "../components/footer/footer.astro";
import "swiper/css";
import "swiper/css/pagination";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- SEO Básico -->
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Auto-Tech-Digital" />
    <meta name="theme-color" content="#08341f" />

    <!-- Open Graph (Facebook, WhatsApp, LinkedIn) -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Auto-Tech-Digital" />
    <meta property="og:locale" content="es_CO" />

    <!-- Twitter / X Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:site" content="@autotechdigital" />

    <!-- Tailwind CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css"
      rel="stylesheet"
    />

    <!-- Fuentes -->
    <link
      href="https://fonts.googleapis.com/css2?family=Lora&family=Montserrat:wght@400;700&family=Roboto:wght@400;700&family=Source+Sans+Pro:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Days+One&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Font Awesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />

    <!-- Estilos globales -->
    <link rel="stylesheet" href="/css/base.css" />
    <link rel="stylesheet" href="/css/common.css" />

    <!-- Estilos específicos según la categoría (solo para notas) -->
    {categoriaCSS && <link rel="stylesheet" href={categoriaCSS} />}

    <!-- Estilos del footer -->
    <link rel="stylesheet" href="/css/footer.css" />
  </head>

  <body class={finalBodyClass}>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      // Observador global para animar títulos principales (h1, h2)
      document.addEventListener("DOMContentLoaded", function () {
        const targets = document.querySelectorAll("h1, h2");
        if (!targets || targets.length === 0) return;

        targets.forEach((el) => el.classList.add("animated-title"));

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("in-view");
              }
            });
          },
          { threshold: 0.15 },
        );

        targets.forEach((el) => io.observe(el));
      });
    </script>
  </body>
</html>
